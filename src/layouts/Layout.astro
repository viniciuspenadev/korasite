---
import "@/styles/global.css"
import { BRAND } from "@/lib/brand"

interface Props {
  title?:       string
  description?: string
  ogImage?:     string
  ogType?:      string
  breadcrumbs?: { name: string; url: string }[]
}

const {
  title       = "CRM e Atendimento no WhatsApp com IA | Kora",
  description = "Plataforma de atendimento e CRM no WhatsApp: multiatendimento, funil de vendas, agendamento e IA num só lugar. Vários atendentes, um número. Peça uma demonstração.",
  ogImage     = "/og.png",
  ogType      = "website",
  breadcrumbs,
} = Astro.props

const canonical = new URL(Astro.url.pathname, Astro.site).toString()
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content="#fbfbfd" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type"        content={ogType} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:image"       content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale"      content="pt_BR" />
    <meta property="og:site_name"   content={BRAND.name} />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={new URL(ogImage, Astro.site).toString()} />

    <!-- Breadcrumb (rich result no Google) — só quando a página informa a trilha -->
    {breadcrumbs && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: breadcrumbs.map((b, i) => ({
          "@type": "ListItem",
          position: i + 1,
          name: b.name,
          item: b.url,
        })),
      })} />
    )}

    <!-- Tipografia Kora — Bricolage Grotesque (display) + Hanken Grotesk (corpo).
         Pareamento grotesco moderno: personalidade no título, calma no corpo.
         font-display=swap evita texto invisível (FOIT). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
    />

    <link rel="icon" type="image/png" href="/logo_kora_curto.png" />

    <!-- SEO Schema Markup (JSON-LD) -->
    <script type="application/ld+json" is:inline set:html={`
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Organization",
            "@id": "${canonical}#organization",
            "name": "Kora",
            "url": "${canonical}",
            "logo": "${new URL('/logo_kora_curto.png', Astro.site).toString()}",
            "sameAs": [
              "https://www.instagram.com/kora_app"
            ]
          },
          {
            "@type": "SoftwareApplication",
            "name": "Kora",
            "applicationCategory": "BusinessApplication",
            "operatingSystem": "WebBrowser",
            "offers": {
              "@type": "Offer",
              "price": "0",
              "priceCurrency": "BRL"
            },
            "description": "${description}"
          }
        ]
      }
    `} />

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-5MYZSHWHNZ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-5MYZSHWHNZ');
    </script>
  </head>
  <body class="bg-[var(--color-paper)] text-slate-900 antialiased">
    <slot />

    <!-- Reveal genérico: revela qualquer [data-reveal] ao entrar no viewport.
         Mora no Layout (não num componente) pra não quebrar se uma seção for
         trocada/removida. Cabeçalhos de FlowAnimation/AdvancedFeatures dependem disto. -->
    <script>
      const reveals = document.querySelectorAll<HTMLElement>("[data-reveal]")
      if (reveals.length && "IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("in-view")
                io.unobserve(e.target)
              }
            }
          },
          // threshold 0 (não 0.15) pra disparar mesmo em elementos muito altos
          // que ficam clipados por um ancestral overflow:hidden (ex.: a grade de
          // features no mobile, que tem 1 coluna e fica gigante).
          { threshold: 0, rootMargin: "0px 0px -80px 0px" }
        )
        reveals.forEach((el) => io.observe(el))
      } else {
        reveals.forEach((el) => el.classList.add("in-view"))
      }
    </script>

    <!-- Kora — chat widget -->
    <script is:inline async src="https://kora.bluedigitalhub.com.br/w/blue-digital-hub"></script>
    
    <!-- Lenis Smooth Scroll (Configuração Estável e Rápida) -->
    <script is:inline src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js"></script>
    <script is:inline>
      const __noLenis = new URLSearchParams(location.search).has('nolenis');
      if (__noLenis && location.hash) {
        // Modo screenshot: reancorar após o layout estabilizar (fontes/imagens)
        const __reanchor = () => {
          const el = document.querySelector(location.hash);
          if (el) el.scrollIntoView({ behavior: 'auto', block: 'start' });
        };
        window.addEventListener('load', () => { setTimeout(__reanchor, 1500); });
      }
      document.addEventListener('DOMContentLoaded', () => {
        if (__noLenis) return;
        const lenis = new Lenis({
          lerp: 0.15,           // Alta responsividade (início imediato)
          smoothWheel: true,
          wheelMultiplier: 1.1, // Rolagem natural
        });

        function raf(time) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }

        requestAnimationFrame(raf);
      });
    </script>
    <style is:global>
      /* CSS OBRIGATÓRIO PARA O LENIS FUNCIONAR */
      html.lenis, html.lenis body {
        height: auto;
      }
      .lenis.lenis-smooth {
        scroll-behavior: auto !important;
      }
      .lenis.lenis-smooth [data-lenis-prevent] {
        overscroll-behavior: contain;
      }
      .lenis.lenis-stopped {
        overflow: hidden;
      }
      .lenis.lenis-smooth iframe {
        pointer-events: none;
      }
    </style>
  </body>
</html>
