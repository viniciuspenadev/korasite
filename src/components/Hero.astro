---
import { waLink } from "@/lib/brand"

/**
 * Hero do site Kora.
 *
 * Phone mockup com 3 conversas que ciclam a cada 8s, mostrando o produto
 * atendendo diferentes segmentos (varejo, clínica estética, imobiliária).
 *
 * - Header WhatsApp tem avatar + nome dinâmicos (atualizados via JS).
 * - Cada [data-conv] container empilha por absolute; só o [data-active] é
 *   visível. CSS no global.css faz cada [data-msg] entrar com stagger
 *   via --delay var.
 */

type Side = "in" | "out"

interface Msg {
  side:      Side
  text?:     string
  who?:      string                       // badge "Atendente IA" ou nome humano
  whoIcon?:  "bot" | "person"
  whoColor?: string                       // tailwind text-color class pro badge
  image?:    { emoji: string; bg: string }
  time:      string
  delay:     number                       // segundos no stagger
}

interface Conv {
  business: string
  initial:  string
  color:    string
  messages: Msg[]
}

const CONVERSATIONS: Conv[] = [
  {
    business: "Loja Bella · Moda",
    initial:  "B",
    color:    "#ec4899",
    messages: [
      { side: "in",  text: "Oi! Vocês ainda têm em estoque o vestido floral?", time: "14:22", delay: 0.5 },
      { side: "out", who: "Atendente IA", whoIcon: "bot", whoColor: "text-primary-700",
        text: "Oi! Temos sim, nos tamanhos P, M e G. Te mando foto?", time: "14:22", delay: 0.9 },
      { side: "out", image: { emoji: "👗", bg: "from-rose-200 to-rose-300" }, time: "14:23", delay: 1.3 },
      { side: "in",  text: "Lindo! Quero o tamanho M ❤️", time: "14:24", delay: 1.7 },
      { side: "out", who: "Marina · vendedora", whoIcon: "person", whoColor: "text-violet-700",
        text: "Oi linda! Já separei aqui. Posso passar o pix?", time: "14:24", delay: 2.1 },
    ],
  },
  {
    business: "Clínica Vita · Estética",
    initial:  "V",
    color:    "#a855f7",
    messages: [
      { side: "in",  text: "Olá, queria agendar uma limpeza de pele.", time: "10:15", delay: 0.5 },
      { side: "out", who: "Atendente IA", whoIcon: "bot", whoColor: "text-primary-700",
        text: "Oi! Posso te ajudar 💆‍♀️ Quando seria melhor pra você?", time: "10:15", delay: 0.9 },
      { side: "in",  text: "Sexta à tarde dá?", time: "10:16", delay: 1.3 },
      { side: "out", who: "Atendente IA", whoIcon: "bot", whoColor: "text-primary-700",
        text: "Tenho 14h ✨ ou 16h. Qual prefere?", time: "10:16", delay: 1.7 },
      { side: "in",  text: "16h tá ótimo!", time: "10:17", delay: 2.1 },
      { side: "out", who: "Dra. Patrícia", whoIcon: "person", whoColor: "text-violet-700",
        text: "Anotei! Te espero sexta às 16h 🌸", time: "10:17", delay: 2.5 },
    ],
  },
  {
    business: "Imob Vista · Imóveis",
    initial:  "I",
    color:    "#f97316",
    messages: [
      { side: "in",  text: "Boa tarde! Vi o anúncio do apto 2qts em Pinheiros.", time: "16:42", delay: 0.5 },
      { side: "out", who: "Atendente IA", whoIcon: "bot", whoColor: "text-primary-700",
        text: "Boa tarde! 🏠 Disponível: R$ 4.200/mês, mobiliado.", time: "16:42", delay: 0.9 },
      { side: "in",  text: "Faz vista pra rua?", time: "16:43", delay: 1.3 },
      { side: "out", image: { emoji: "🏙️", bg: "from-sky-200 to-sky-300" }, time: "16:43", delay: 1.7 },
      { side: "out", who: "Atendente IA", whoIcon: "bot", whoColor: "text-primary-700",
        text: "Vista frontal, claríssimo. Quando pode visitar?", time: "16:43", delay: 2.1 },
      { side: "out", who: "Carlos · corretor", whoIcon: "person", whoColor: "text-violet-700",
        text: "Aqui é o Carlos 👋 Te confirmo amanhã às 15h?", time: "16:44", delay: 2.5 },
    ],
  },
]

// Dados leves pro script client-side (sem mensagens)
const HEADER_DATA = CONVERSATIONS.map((c) => ({
  business: c.business,
  initial:  c.initial,
  color:    c.color,
}))

const FIRST = CONVERSATIONS[0]
---

<section class="relative overflow-hidden bg-[var(--color-paper)] pt-32 pb-24 lg:pt-40 lg:pb-32">
  <!-- Atmosfera "grotesco moderno": estrutura, não blur.
       Grid técnico fino + uma tinta fria sutil no topo. Sem blobs borrados. -->
  <div class="absolute inset-0 -z-10 pointer-events-none">
    <!-- tinta fria sutil descendo do topo -->
    <div class="absolute inset-x-0 top-0 h-[60%] bg-gradient-to-b from-primary-50/60 to-transparent"></div>
    <!-- grid técnico fino -->
    <div
      class="absolute inset-0 opacity-[0.04]"
      style="background-image: linear-gradient(to right, var(--color-ink) 1px, transparent 1px), linear-gradient(to bottom, var(--color-ink) 1px, transparent 1px); background-size: 56px 56px; mask-image: radial-gradient(ellipse 80% 60% at 50% 35%, #000 40%, transparent 100%);"
    ></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center">
    <!-- Coluna esquerda: copy + CTA -->
    <div class="animate-[fadeUp_0.6s_ease-out_both] text-center lg:text-left">

      <h1 class="text-[3rem] sm:text-[3.5rem] lg:text-[3.8rem] xl:text-[4.5rem] font-bold tracking-tight leading-[1.05]">
        <span class="text-primary-600">Centralize</span>
        <span class="text-slate-900"> todos os canais<br />de comunicação.</span>
      </h1>

      <p class="text-base lg:text-lg text-slate-600 mt-7 max-w-xl leading-relaxed mx-auto lg:mx-0">
        Toda a operação de atendimento da sua empresa centralizado. Atendimento,
        vendas e gestão pra todo o time, sem perder nenhuma conversa.
      </p>

      <div class="mt-10 flex flex-col items-center lg:items-start gap-4">
        <!-- Badge chamativo -->
        <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-emerald-50 border border-emerald-100 text-emerald-700 text-xs font-bold tracking-wide shadow-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          LIBERADO: 3 DIAS GRÁTIS
        </div>
        
        <div class="flex items-center justify-center lg:justify-start gap-5 flex-wrap w-full">
          <a
            href="https://kora.bluedigitalhub.com.br/signup"
            class="group relative inline-flex items-center gap-2.5 bg-gradient-to-r from-primary-600 to-violet-600 hover:from-primary-500 hover:to-violet-500 text-white font-semibold px-8 py-4 rounded-xl text-base transition-all shadow-[0_4px_20px_rgba(79,70,229,0.25)] hover:shadow-[0_6px_25px_rgba(79,70,229,0.4)] ring-1 ring-inset ring-white/20 hover:-translate-y-0.5"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="opacity-90">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Testar Grátis Agora
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="transition-transform group-hover:translate-x-1">
              <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#produto" class="text-slate-600 hover:text-slate-900 text-sm font-semibold inline-flex items-center gap-1.5 group px-2 py-1 rounded-lg transition-colors hover:bg-slate-50">
            Ver como funciona
            <span class="transition-transform group-hover:translate-y-0.5">↓</span>
          </a>
        </div>
        
        <p class="mt-2 text-[13px] text-slate-500 text-center lg:text-left flex items-center justify-center lg:justify-start gap-1.5">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-emerald-500"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Sem cartão de crédito. Acesso imediato à plataforma.
        </p>
      </div>
    </div>

    <!-- Coluna direita: Opção 2 - Foto 2 com bubbles animados ciclicamente -->
    <div class="relative animate-[fadeUp_0.8s_ease-out_0.15s_both] flex justify-center items-center py-10 lg:py-0">
      


      <!-- Imagem central (maior e sem borda) com chat overlay no bottom 30% -->
      <div class="relative z-10 w-full max-w-[380px] lg:max-w-[480px]">
        <img src="/photo_2.webp" alt="Apresentação da Plataforma Kora" width="1792" height="2400" fetchpriority="high" class="w-full h-auto object-contain" />

        <!-- Chat overlay: cobre os ~33% inferiores da imagem -->
        <div class="absolute inset-x-0 bottom-0 h-[33%] pointer-events-none" id="bubble-cycle-container" aria-hidden="true">
          <div class="absolute inset-x-0 top-0 h-10 bg-gradient-to-b from-transparent to-white/0 pointer-events-none z-10"></div>

          <!-- GRUPO 1: IA — pré-atendimento -->
          <div data-bubble-group data-active class="absolute inset-0 transition-opacity duration-500 flex flex-col justify-end gap-[6px] px-3 pb-3" style="opacity: 1;">
            <div class="bubble-enter flex justify-end" style="--delay: 0.3s">
              <div class="bg-[#DCF8C6]/95 backdrop-blur-sm rounded-2xl rounded-tr-sm shadow-md px-3 py-2 max-w-[80%]">
                <p class="text-[11px] text-slate-800 leading-snug">Oi! Vi o Instagram de vocês e queria saber mais 😊</p>
              </div>
            </div>
            <div class="bubble-enter flex justify-start gap-1.5 items-end" style="--delay: 1.3s">
              <div class="shrink-0 size-[22px] rounded-full bg-primary-100 flex items-center justify-center ring-1 ring-primary-200">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" class="text-primary-600"><path d="M12 2a2 2 0 0 1 2 2v2h4a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4V4a2 2 0 0 1 2-2Zm-3 8a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Zm6 0a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Z"/></svg>
              </div>
              <div class="bg-white/92 backdrop-blur-sm rounded-2xl rounded-tl-sm shadow-md px-3 py-2 max-w-[72%]">
                <p class="text-[9px] font-bold text-primary-600 mb-0.5 tracking-wide uppercase">Assistente IA</p>
                <p class="text-[11px] text-slate-800 leading-snug">Oii, que bom que chegou até a gente! 😄 Você já treina ou tá voltando do zero?</p>
              </div>
            </div>
            <div class="bubble-enter flex justify-end" style="--delay: 2.3s">
              <div class="bg-[#DCF8C6]/95 backdrop-blur-sm rounded-2xl rounded-tr-sm shadow-md px-3 py-2 max-w-[80%]">
                <p class="text-[11px] text-slate-800 leading-snug">Quero voltar depois de um tempo parado 😅</p>
              </div>
            </div>
          </div>

          <!-- GRUPO 2: IA passa pra Bia -->
          <div data-bubble-group class="absolute inset-0 transition-opacity duration-500 flex flex-col justify-end gap-[6px] px-3 pb-3" style="opacity: 0;">
            <div class="bubble-enter flex justify-start gap-1.5 items-end" style="--delay: 0.3s">
              <div class="shrink-0 size-[22px] rounded-full bg-primary-100 flex items-center justify-center ring-1 ring-primary-200">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" class="text-primary-600"><path d="M12 2a2 2 0 0 1 2 2v2h4a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4V4a2 2 0 0 1 2-2Zm-3 8a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Zm6 0a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Z"/></svg>
              </div>
              <div class="bg-white/92 backdrop-blur-sm rounded-2xl rounded-tl-sm shadow-md px-3 py-2 max-w-[72%]">
                <p class="text-[9px] font-bold text-primary-600 mb-0.5 tracking-wide uppercase">Assistente IA</p>
                <p class="text-[11px] text-slate-800 leading-snug">Temos programa especial pra quem tá voltando 💪 Que horas prefere treinar?</p>
              </div>
            </div>
            <div class="bubble-enter flex justify-end" style="--delay: 1.3s">
              <div class="bg-[#DCF8C6]/95 backdrop-blur-sm rounded-2xl rounded-tr-sm shadow-md px-3 py-2 max-w-[80%]">
                <p class="text-[11px] text-slate-800 leading-snug">Trabalho cedo, precisa ser bem de manhã</p>
              </div>
            </div>
            <div class="bubble-enter flex justify-start gap-1.5 items-end" style="--delay: 2.3s">
              <img src="/bia_avatar.png" alt="Bia" class="shrink-0 size-[22px] rounded-full object-cover shadow ring-1 ring-violet-200" />
              <div class="bg-white/92 backdrop-blur-sm rounded-2xl rounded-tl-sm shadow-md px-3 py-2 max-w-[72%]">
                <p class="text-[9px] font-bold text-violet-600 mb-0.5 tracking-wide uppercase">Bia · Consultora</p>
                <p class="text-[11px] text-slate-800 leading-snug">Oi! Aqui é a Bia 😊 Abrimos às 5h! Tenho turma de funcional às 6h que é perfeita!</p>
              </div>
            </div>
          </div>

          <!-- GRUPO 3: Bia fecha -->
          <div data-bubble-group class="absolute inset-0 transition-opacity duration-500 flex flex-col justify-end gap-[6px] px-3 pb-3" style="opacity: 0;">
            <div class="bubble-enter flex justify-end" style="--delay: 0.3s">
              <div class="bg-[#DCF8C6]/95 backdrop-blur-sm rounded-2xl rounded-tr-sm shadow-md px-3 py-2 max-w-[80%]">
                <p class="text-[11px] text-slate-800 leading-snug">Tem personal também? 🏋️</p>
              </div>
            </div>
            <div class="bubble-enter flex justify-start gap-1.5 items-end" style="--delay: 1.3s">
              <img src="/bia_avatar.png" alt="Bia" class="shrink-0 size-[22px] rounded-full object-cover shadow ring-1 ring-violet-200" />
              <div class="bg-white/92 backdrop-blur-sm rounded-2xl rounded-tl-sm shadow-md px-3 py-2 max-w-[72%]">
                <p class="text-[9px] font-bold text-violet-600 mb-0.5 tracking-wide uppercase">Bia · Consultora</p>
                <p class="text-[11px] text-slate-800 leading-snug">Tem! 🏆 A partir de R$ 89/mês. Posso reservar uma aula experimental gratuita pra você?</p>
              </div>
            </div>
            <div class="bubble-enter flex justify-end" style="--delay: 2.3s">
              <div class="bg-[#DCF8C6]/95 backdrop-blur-sm rounded-2xl rounded-tr-sm shadow-md px-3 py-2 max-w-[80%]">
                <p class="text-[11px] text-slate-800 leading-snug">Quero sim! Me manda o link 🙌</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- BACKUP DO CELULAR ANTIGO (Oculto) -->
    <div class="hidden" id="backup-celular" aria-hidden="true">
      <!-- Coluna direita: iPhone realista com 3 conversas cyclical -->
      <div class="relative animate-[fadeUp_0.8s_ease-out_0.15s_both]">
      <div class="relative mx-auto" style="max-width: 320px;">

        <!-- Siri-style orb: blobs azul Kora animados ATRÁS do phone.
             Puro CSS (transform + blur), GPU-accelerated, zero JS.
             -inset-24 estende o container 96px pra todos os lados pros
             blobs vazarem atrás do phone. pointer-events-none não interfere. -->
        <div class="absolute -inset-24 pointer-events-none overflow-visible" aria-hidden="true">
          <div
            class="siri-blob absolute size-72 rounded-full"
            style="top: 4%; left: -8%; background: #004add; filter: blur(70px); opacity: 0.55; animation: siriDrift1 14s ease-in-out infinite;"
          ></div>
          <div
            class="siri-blob absolute size-64 rounded-full"
            style="top: 32%; right: -12%; background: #5e85ff; filter: blur(65px); opacity: 0.6; animation: siriDrift2 18s ease-in-out infinite;"
          ></div>
          <div
            class="siri-blob absolute size-72 rounded-full"
            style="bottom: 2%; left: 18%; background: #a78bfa; filter: blur(80px); opacity: 0.45; animation: siriDrift3 22s ease-in-out infinite;"
          ></div>
        </div>

        <!-- Botões laterais -->
        <div class="absolute -left-[2px] top-[78px]  w-[3px] h-7  bg-slate-700 rounded-l-sm shadow-inner z-10"></div>
        <div class="absolute -left-[2px] top-[130px] w-[3px] h-12 bg-slate-700 rounded-l-sm shadow-inner z-10"></div>
        <div class="absolute -left-[2px] top-[185px] w-[3px] h-12 bg-slate-700 rounded-l-sm shadow-inner z-10"></div>
        <div class="absolute -right-[2px] top-[125px] w-[3px] h-20 bg-slate-700 rounded-r-sm shadow-inner z-10"></div>

        <!-- Frame externo titânio -->
        <div class="relative bg-gradient-to-br from-slate-700 via-slate-800 to-slate-950 rounded-[2.75rem] p-[3px] shadow-[0_30px_70px_-15px_rgba(15,23,42,0.45)]">

          <!-- Bezel preto -->
          <div class="relative bg-slate-950 rounded-[2.6rem] p-[7px]">

            <!-- Tela -->
            <div class="relative bg-[#E5DDD5] rounded-[2.15rem] overflow-hidden" style="aspect-ratio: 9 / 19.5;">

              <!-- WhatsApp chrome verde (avatar + nome dinâmicos via JS) -->
              <div class="absolute top-0 inset-x-0 z-10" style="height: 92px;">
                <div class="absolute inset-0 bg-[#075E54]"></div>
                <div class="absolute bottom-0 inset-x-0 px-3 pb-2.5 flex items-center gap-2.5 text-white">
                  <svg width="11" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="opacity-90">
                    <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <!-- Avatar dinâmico (atualizado pelo script) -->
                  <div
                    id="hero-conv-avatar"
                    class="size-8 rounded-full shrink-0 flex items-center justify-center font-bold text-xs text-white transition-colors duration-300"
                    style={`background: ${FIRST.color};`}
                  >{FIRST.initial}</div>
                  <div class="flex-1 min-w-0">
                    <!-- Nome dinâmico (atualizado pelo script) -->
                    <p id="hero-conv-name" class="text-[13px] font-semibold truncate leading-tight">{FIRST.business}</p>
                    <p class="text-[10px] opacity-80 leading-tight mt-0.5">online</p>
                  </div>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="opacity-85"><path d="M20 4h-3.17l-1.84-2H9.01L7.17 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2Zm-8 13c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5Z"/></svg>
                  <svg width="3" height="14" viewBox="0 0 4 16" fill="currentColor" class="opacity-85"><circle cx="2" cy="2" r="2"/><circle cx="2" cy="8" r="2"/><circle cx="2" cy="14" r="2"/></svg>
                </div>
              </div>

              <!-- Dynamic Island -->
              <div class="absolute top-[7px] left-1/2 -translate-x-1/2 z-30 bg-black rounded-full" style="width: 95px; height: 26px;"></div>

              <!-- Status bar (sobre o chrome verde) -->
              <div class="absolute top-0 inset-x-0 z-20 flex items-center justify-between text-white text-[12px] font-semibold pointer-events-none" style="height: 36px; padding: 12px 22px 0;">
                <span class="tabular-nums">14:22</span>
                <div class="flex items-center gap-[5px]">
                  <svg width="17" height="10" viewBox="0 0 17 10" fill="currentColor" aria-hidden="true">
                    <rect x="0"   y="6" width="3" height="4"  rx="0.5"/>
                    <rect x="4.5" y="4" width="3" height="6"  rx="0.5"/>
                    <rect x="9"   y="2" width="3" height="8"  rx="0.5"/>
                    <rect x="13.5" y="0" width="3" height="10" rx="0.5"/>
                  </svg>
                  <svg width="15" height="11" viewBox="0 0 15 11" fill="currentColor" aria-hidden="true">
                    <path d="M7.5 11l-2-2a2.83 2.83 0 0 1 4 0l-2 2z"/>
                    <path d="M3.5 7l1.4 1.4a3.7 3.7 0 0 1 5.2 0L11.5 7c-2.2-2.2-5.8-2.2-8 0z" opacity="0.95"/>
                    <path d="M0.5 4l1.4 1.4a8 8 0 0 1 11.2 0L14.5 4c-3.9-3.9-10.1-3.9-14 0z" opacity="0.9"/>
                  </svg>
                  <svg width="25" height="11" viewBox="0 0 25 11" fill="none" aria-hidden="true">
                    <rect x="0.5" y="0.5" width="21" height="10" rx="2.5" stroke="currentColor" stroke-opacity="0.6"/>
                    <rect x="2" y="2" width="16" height="7" rx="1" fill="currentColor"/>
                    <rect x="22.5" y="3.5" width="1.5" height="4" rx="0.6" fill="currentColor" opacity="0.7"/>
                  </svg>
                </div>
              </div>

              <!-- Conversas cyclical (3 containers empilhados; só [data-active] visível) -->
              {CONVERSATIONS.map((conv, ci) => (
                <div
                  data-conv
                  data-active={ci === 0 ? "" : null}
                  class="absolute inset-x-0 bottom-[18px] px-2.5 py-3 space-y-2 overflow-hidden transition-opacity duration-500"
                  style={`top: 92px; opacity: ${ci === 0 ? 1 : 0};`}
                >
                  {conv.messages.map((msg) => (
                    msg.image ? (
                      <div class={`flex ${msg.side === "in" ? "justify-start" : "justify-end"}`} data-msg style={`--delay: ${msg.delay}s`}>
                        <div class={`max-w-[78%] ${msg.side === "in" ? "bg-white rounded-tl-sm" : "bg-[#DCF8C6] rounded-tr-sm"} rounded-lg p-1 shadow-sm`}>
                          <div class={`aspect-square w-28 bg-gradient-to-br ${msg.image.bg} rounded flex items-center justify-center`}>
                            <span class="text-2xl">{msg.image.emoji}</span>
                          </div>
                          <p class="text-[9px] text-slate-400 text-right mt-0.5 pr-1">{msg.time} ✓✓</p>
                        </div>
                      </div>
                    ) : (
                      <div class={`flex ${msg.side === "in" ? "justify-start" : "justify-end"}`} data-msg style={`--delay: ${msg.delay}s`}>
                        <div class={`${msg.side === "in" ? "max-w-[75%] bg-white rounded-tl-sm" : "max-w-[80%] bg-[#DCF8C6] rounded-tr-sm"} rounded-lg px-2.5 py-1.5 shadow-sm`}>
                          {msg.who && (
                            <p class={`text-[9px] font-semibold ${msg.whoColor} mb-0.5 flex items-center gap-1`}>
                              {msg.whoIcon === "bot" ? (
                                <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a2 2 0 0 1 2 2v2h4a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4V4a2 2 0 0 1 2-2Zm-3 8a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Zm6 0a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Z"/></svg>
                              ) : (
                                <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm0 2c-4 0-8 2-8 5v1h16v-1c0-3-4-5-8-5Z"/></svg>
                              )}
                              {msg.who}
                            </p>
                          )}
                          <p class="text-[12px] text-slate-800 leading-snug">{msg.text}</p>
                          <p class="text-[9px] text-slate-400 text-right mt-0.5">{msg.time}{msg.side === "out" ? " ✓✓" : ""}</p>
                        </div>
                      </div>
                    )
                  ))}

                  <!-- Typing indicator no final de cada conv (delay = última msg + 0.4s) -->
                  <div class="flex justify-start" data-msg style={`--delay: ${conv.messages[conv.messages.length - 1].delay + 0.4}s`}>
                    <div class="bg-white rounded-lg rounded-tl-sm px-2.5 py-2 shadow-sm">
                      <div class="flex items-center gap-1">
                        <span class="size-1.5 bg-slate-400 rounded-full animate-[pulseSoft_1s_ease-in-out_infinite]"></span>
                        <span class="size-1.5 bg-slate-400 rounded-full animate-[pulseSoft_1s_ease-in-out_0.2s_infinite]"></span>
                        <span class="size-1.5 bg-slate-400 rounded-full animate-[pulseSoft_1s_ease-in-out_0.4s_infinite]"></span>
                      </div>
                    </div>
                  </div>
                </div>
              ))}

              <!-- Home indicator -->
              <div class="absolute bottom-[6px] left-1/2 -translate-x-1/2 w-[110px] h-[4px] bg-slate-900/70 rounded-full z-40"></div>

              <!-- Reflexo sutil -->
              <div class="absolute inset-0 pointer-events-none z-50 rounded-[2.15rem] bg-gradient-to-br from-white/[0.04] via-transparent to-transparent"></div>
            </div>
          </div>
        </div>

        <!-- Badges flutuantes — fora do phone via right-full / left-full (verde = melhoria) -->
        <div class="absolute right-full top-1/4 mr-3 bg-white rounded-2xl shadow-xl border border-slate-100 px-4 py-3 animate-[fadeUp_0.6s_ease-out_1.5s_both] hidden xl:block">
          <p class="text-[10px] font-semibold uppercase tracking-wide text-slate-400">Tempo de resposta</p>
          <p class="text-2xl font-bold text-slate-900 tabular-nums">12<span class="text-sm font-medium text-slate-500">s</span></p>
          <p class="text-[10px] text-emerald-600 font-medium mt-0.5">↓ 87% vs antes</p>
        </div>

        <div class="absolute left-full bottom-1/4 ml-3 bg-white rounded-2xl shadow-xl border border-slate-100 px-4 py-3 animate-[fadeUp_0.6s_ease-out_1.8s_both] hidden xl:block">
          <p class="text-[10px] font-semibold uppercase tracking-wide text-slate-400">Conversão</p>
          <p class="text-2xl font-bold text-slate-900 tabular-nums">34<span class="text-sm font-medium text-slate-500">%</span></p>
          <p class="text-[10px] text-emerald-600 font-medium mt-0.5">↑ 2,1× a média</p>
        </div>
      </div>
    </div>
    <!-- Fim do BACKUP -->
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  .animate-float-delayed-1 {
    animation: float 6s ease-in-out infinite;
    animation-delay: -2s;
  }
  .animate-float-delayed-2 {
    animation: float 6s ease-in-out infinite;
    animation-delay: -4s;
  }

  /* Bubble entry animation */
  [data-active] .bubble-enter {
    animation: bubbleEnter 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    animation-delay: var(--delay);
  }
  @keyframes bubbleEnter {
    from { opacity: 0; transform: translateY(15px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  
  .bubble-enter {
    opacity: 0;
  }

  /* ── Hero rotating platform word ── */
  .hero-rotate-outer {
    /* altura = 1 linha; clipa o track que desliza */
    height: 1.08em;
    line-height: 1.08;
  }
  /* 6 itens: cada passo = 1/6 = 16.6667%
     Pausa em cada palavra ~2.5s, troca rápida 0.4s → ciclo total ~18s */
  @keyframes heroSlideUp {
    0%          { transform: translateY(0); }
    14%         { transform: translateY(0); }        /* pausa WhatsApp  */
    16.6667%    { transform: translateY(-16.6667%); } /* → Instagram     */
    30.6667%    { transform: translateY(-16.6667%); } /* pausa Instagram */
    33.3333%    { transform: translateY(-33.3333%); } /* → Facebook      */
    47.3333%    { transform: translateY(-33.3333%); } /* pausa Facebook  */
    50%         { transform: translateY(-50%); }      /* → Telegram      */
    64%         { transform: translateY(-50%); }      /* pausa Telegram  */
    66.6667%    { transform: translateY(-66.6667%); } /* → Google        */
    80.6667%    { transform: translateY(-66.6667%); } /* pausa Google    */
    83.3333%    { transform: translateY(-83.3333%); } /* → WhatsApp(dup) */
    100%        { transform: translateY(-83.3333%); } /* fim (reset sem jump) */
  }
  .hero-rotate-track {
    animation: heroSlideUp 18s cubic-bezier(0.76, 0, 0.24, 1) infinite;
    will-change: transform;
  }
  .hero-rotate-item {
    height: 1.08em;
    line-height: 1.08;
  }

  /* ── Bubbles mobile: compacta tudo em telas pequenas ── */
  @media (max-width: 480px) {
    /* Overlay menor pra não cobrir demais a foto */
    #bubble-cycle-container {
      height: 36% !important;
    }
    /* Grupos: menos gap e padding interno */
    #bubble-cycle-container [data-bubble-group] {
      gap: 4px !important;
      padding: 0 8px 8px !important;
    }
    /* Bolhas: padding menor, max-width menor — seleciona os divs de conteúdo */
    #bubble-cycle-container [data-bubble-group] > div > div:last-child {
      padding: 5px 10px !important;
      max-width: 82% !important;
    }
    /* Texto das mensagens menor */
    #bubble-cycle-container p.leading-snug {
      font-size: 9.5px !important;
      line-height: 1.35 !important;
    }
    /* Label "Assistente IA" / "Bia" */
    #bubble-cycle-container p.uppercase {
      font-size: 7.5px !important;
      margin-bottom: 1px !important;
    }
    /* Avatar menor */
    #bubble-cycle-container img.rounded-full,
    #bubble-cycle-container div.rounded-full {
      width: 18px !important;
      height: 18px !important;
      min-width: 18px !important;
    }
    /* SVG dentro do avatar IA */
    #bubble-cycle-container div.rounded-full svg {
      width: 9px !important;
      height: 9px !important;
    }
    /* Gap entre avatar e bubble */
    #bubble-cycle-container .gap-1\.5 {
      gap: 5px !important;
    }
  }
</style>

<script define:vars={{ HEADER_DATA }}>
  // Cycle conversations do backup a cada 8s.
  const convElements = Array.from(document.querySelectorAll("[data-conv]"))
  const avatarEl    = document.getElementById("hero-conv-avatar")
  const nameEl      = document.getElementById("hero-conv-name")

  const prefersReducedMotion =
    typeof window !== "undefined" &&
    window.matchMedia("(prefers-reduced-motion: reduce)").matches

  if (convElements.length > 1 && avatarEl && nameEl && !prefersReducedMotion) {
    let current = 0

    function cycleNext() {
      const currentEl = convElements[current]
      const nextIndex = (current + 1) % HEADER_DATA.length
      const nextEl    = convElements[nextIndex]

      currentEl.style.opacity = "0"
      window.setTimeout(() => {
        currentEl.removeAttribute("data-active")
        const data = HEADER_DATA[nextIndex]
        avatarEl.style.background = data.color
        avatarEl.textContent      = data.initial
        nameEl.textContent        = data.business
        nextEl.setAttribute("data-active", "")
        nextEl.style.opacity = "1"
        current = nextIndex
      }, 400)
    }
    window.setInterval(cycleNext, 8000)
  }
</script>

<script>
  // Ciclo das bubbles da nova Option 2 a cada 7s.
  const prefersReducedMotionNew = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!prefersReducedMotionNew) {
    const bubbleGroups = Array.from(document.querySelectorAll("[data-bubble-group]"));
    if (bubbleGroups.length > 0) {
      let currentBubble = 0;
      setInterval(() => {
        const currentEl = bubbleGroups[currentBubble];
        const nextIndex = (currentBubble + 1) % bubbleGroups.length;
        const nextEl = bubbleGroups[nextIndex];

        currentEl.style.opacity = "0";
        setTimeout(() => {
          currentEl.removeAttribute("data-active");
          nextEl.setAttribute("data-active", "");
          nextEl.style.opacity = "1";
          currentBubble = nextIndex;
        }, 500);
      }, 7000);
    }
  }
</script>
