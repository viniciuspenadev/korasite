---
/**
 * "Como funciona" — menu fixo à esquerda + cards que empilham (sticky stack).
 *
 * Padrão: cada card é `position: sticky` com um `top` levemente crescente, então
 * conforme o usuário rola, o próximo card sobe e empilha por cima do anterior
 * (deixando uma fresta do topo do card de baixo aparecendo). O menu lateral
 * acende o item da seção ativa via IntersectionObserver (scrollspy).
 *
 * Identidade Kora "grotesco moderno": cards navy profundo, acento azul,
 * verde só como semântico. Mockups claros (janela de app) por cima do navy.
 */

const items = [
  { id: "dashboard",  label: "Dashboard" },
  { id: "chat",       label: "Chat Interno" },
  { id: "integracao", label: "Integração" },
  { id: "crm",        label: "CRM" },
]

// Ícones (Lucide-style, stroke 2) por id — SVG, nunca emoji.
const icons: Record<string, string> = {
  dashboard:  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>`,
  chat:       `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  integracao: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>`,
  crm:        `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/><path d="M15 3v18"/></svg>`,
  meta:       `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
}
---

<section id="produto" class="relative bg-[var(--color-paper)] py-24 lg:py-32">
  <!-- Atmosfera: grid técnico sutil -->
  <div class="absolute inset-0 -z-10 pointer-events-none opacity-[0.04]"
       style="background-image: linear-gradient(to right, var(--color-ink) 1px, transparent 1px), linear-gradient(to bottom, var(--color-ink) 1px, transparent 1px); background-size: 56px 56px; mask-image: radial-gradient(ellipse 70% 50% at 50% 0%, #000 30%, transparent 100%);"></div>

  <div class="max-w-6xl mx-auto px-6">

    <!-- Header -->
    <div class="max-w-2xl mb-12 lg:mb-16">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary-600 mb-4">
        Como funciona
      </p>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 tracking-tight leading-[1.05]">
        Tudo que sua operação<br />precisa, num lugar só.
      </h2>
      <p class="text-lg text-slate-600 mt-6 leading-relaxed">
        Do primeiro contato ao fechamento — atendimento, automação, gestão e dados.
        Role pra ver cada parte.
      </p>
    </div>

    <!-- Layout: rail fixo (esq) + cards empilháveis (dir) -->
    <div class="grid grid-cols-1 lg:grid-cols-[220px_1fr] gap-8 lg:gap-14 items-start">

      <!-- ── RAIL fixo (desktop) ───────────────────────────── -->
      <aside class="hidden lg:block lg:sticky lg:top-28 self-start">
        <nav class="flex flex-col gap-1 border-l border-slate-200" aria-label="Seções">
          {items.map((it, i) => (
            <a
              href={`#cf-${it.id}`}
              data-rail
              data-index={i}
              class="rail-item group relative -ml-px flex items-center gap-3 border-l-2 border-transparent pl-4 py-2.5 text-sm font-medium text-slate-500 transition-colors hover:text-slate-900"
            >
              <span class="rail-icon size-5 text-slate-400 transition-colors" set:html={icons[it.id]} />
              <span>{it.label}</span>
            </a>
          ))}
        </nav>
      </aside>

      <!-- ── CARDS empilháveis ─────────────────────────────── -->
      <div class="cf-cards relative flex flex-col">

        <!-- CARD 1 — Dashboard -->
        <article id="cf-dashboard" data-card data-index="0" class="cf-card" style="--i: 0">
          <div class="cf-card-inner grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
            <div>
              <span class="cf-badge">Dashboard</span>
              <h3 class="cf-title">Sua operação inteira<br /><span class="text-primary-400">numa tela só.</span></h3>
              <p class="cf-copy">Conversão, valor ganho, tempo de resposta e leads por origem — em tempo real, sem montar planilha nem dashboard externo.</p>
              <ul class="cf-list">
                <li>KPIs ao vivo por canal, campanha e atendente</li>
                <li>Funil de conversão por etapa</li>
                <li>Tempo de 1ª resposta e cumprimento de SLA</li>
              </ul>
            </div>
            <!-- Mockup: dashboard -->
            <div class="cf-mock">
              <div class="cf-winbar"><span></span><span></span><span></span><em>app.kora.com.br · Relatórios</em></div>
              <div class="p-4">
                <div class="grid grid-cols-2 gap-2 mb-3">
                  <div class="cf-kpi"><p class="cf-kpi-l">Conversão</p><p class="cf-kpi-v">34<span>%</span></p><p class="cf-kpi-up">↑ 4 pp</p></div>
                  <div class="cf-kpi"><p class="cf-kpi-l">Valor ganho</p><p class="cf-kpi-v">R$ 12,4<span>k</span></p><p class="cf-kpi-up">↑ 18%</p></div>
                  <div class="cf-kpi"><p class="cf-kpi-l">1ª resposta</p><p class="cf-kpi-v">12<span>s</span></p><p class="cf-kpi-up">↓ 87%</p></div>
                  <div class="cf-kpi"><p class="cf-kpi-l">Leads novos</p><p class="cf-kpi-v">218</p><p class="cf-kpi-up">↑ 24%</p></div>
                </div>
                <div class="bg-slate-50 border border-slate-100 rounded-lg p-3">
                  <p class="text-[10px] uppercase font-semibold tracking-wider text-slate-400 mb-2.5">Funil de conversão</p>
                  <div class="space-y-1.5">
                    <div class="flex items-center gap-2"><span class="text-[10px] text-slate-600 w-16 shrink-0">Triagem</span><div class="flex-1 h-3 bg-primary-50 rounded-sm overflow-hidden"><div class="h-full bg-primary-600" style="width:100%"></div></div><span class="text-[10px] font-bold text-slate-700 tabular-nums w-9 text-right">218</span></div>
                    <div class="flex items-center gap-2"><span class="text-[10px] text-slate-600 w-16 shrink-0">Negociação</span><div class="flex-1 h-3 bg-primary-50 rounded-sm overflow-hidden"><div class="h-full bg-primary-500" style="width:68%"></div></div><span class="text-[10px] font-bold text-slate-700 tabular-nums w-9 text-right">148</span></div>
                    <div class="flex items-center gap-2"><span class="text-[10px] text-slate-600 w-16 shrink-0">Ganho</span><div class="flex-1 h-3 bg-emerald-100 rounded-sm overflow-hidden"><div class="h-full bg-emerald-600" style="width:34%"></div></div><span class="text-[10px] font-bold text-emerald-700 tabular-nums w-9 text-right">74</span></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </article>

        <!-- CARD 2 — Chat Interno -->
        <article id="cf-chat" data-card data-index="1" class="cf-card" style="--i: 1">
          <div class="cf-card-inner grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
            <div>
              <span class="cf-badge">Chat Interno</span>
              <h3 class="cf-title">Seu time alinhado,<br /><span class="text-primary-400">sem o cliente ver.</span></h3>
              <p class="cf-copy">Comentários internos, menções e transferência com contexto acontecem na mesma conversa. A decisão é rápida e o cliente nunca percebe os bastidores.</p>
              <ul class="cf-list">
                <li>Notas internas e @menções entre atendentes</li>
                <li>Transferência com histórico completo</li>
                <li>Supervisão em tempo real do atendimento</li>
              </ul>
            </div>
            <!-- Mockup: conversa com nota interna -->
            <div class="cf-mock">
              <div class="cf-winbar"><span></span><span></span><span></span><em>app.kora.com.br · Conversas</em></div>
              <div class="p-4 bg-[#E5DDD5] space-y-2.5">
                <div class="flex justify-start">
                  <div class="max-w-[80%] bg-white rounded-2xl rounded-tl-md px-3.5 py-2 shadow-sm">
                    <p class="text-sm text-slate-800">Posso parcelar em 3x sem juros?</p>
                    <p class="text-[10px] text-slate-400 text-right mt-1">14:02</p>
                  </div>
                </div>
                <!-- Nota interna (amarela, só o time vê) -->
                <div class="flex justify-center">
                  <div class="max-w-[92%] bg-amber-50 border border-amber-200 rounded-xl px-3 py-2 shadow-sm">
                    <p class="text-[10px] font-bold text-amber-700 flex items-center gap-1 mb-0.5">
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 1v6M12 17v6M4.2 4.2l4.3 4.3M15.5 15.5l4.3 4.3M1 12h6M17 12h6"/></svg>
                      Nota interna · só o time vê
                    </p>
                    <p class="text-xs text-amber-900 leading-snug"><span class="font-semibold">@Marina</span> esse cliente é VIP, pode liberar 3x sim 👍</p>
                  </div>
                </div>
                <div class="flex justify-end">
                  <div class="max-w-[85%] bg-[#DCF8C6] rounded-2xl rounded-tr-md px-3.5 py-2 shadow-sm">
                    <p class="text-[10px] font-semibold text-primary-700 mb-0.5">Marina · vendedora</p>
                    <p class="text-sm text-slate-800">Consigo sim! 3x sem juros pra você 💙</p>
                    <p class="text-[10px] text-slate-400 text-right mt-1">14:03 ✓✓</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </article>

        <!-- CARD 3 — Integração -->
        <article id="cf-integracao" data-card data-index="2" class="cf-card" style="--i: 2">
          <div class="cf-card-inner grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
            <div>
              <span class="cf-badge">Integração</span>
              <h3 class="cf-title">Conecta com tudo<br /><span class="text-primary-400">que você já usa.</span></h3>
              <p class="cf-copy">WhatsApp oficial, Instagram, IA, CRM, Webhooks e voz com qualidade humana. Tudo num fluxo só, sem ferramenta solta.</p>
              <ul class="cf-list">
                <li>Canais e ferramentas num inbox único</li>
                <li>Webhooks pra plugar qualquer sistema</li>
                <li>Voz (ElevenLabs) e IA nativas</li>
              </ul>
            </div>
            <!-- Mockup: grid de integrações -->
            <div class="cf-mock p-4">
              <div class="grid grid-cols-2 gap-2.5">
                <div class="cf-int"><span class="cf-int-ic text-emerald-600"><svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.21 3.07.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.07-.12-.27-.2-.57-.35M12.05 21.8h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.99 2.9a9.82 9.82 0 0 1 2.89 6.99c0 5.45-4.44 9.88-9.88 9.88"/></svg></span><div><p class="cf-int-t">WhatsApp</p><p class="cf-int-s">API oficial Meta</p></div></div>
                <div class="cf-int"><span class="cf-int-ic text-pink-600"><svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85C2.38 3.92 3.9 2.38 7.15 2.23 8.42 2.17 8.8 2.16 12 2.16M12 0C8.74 0 8.33.01 7.05.07 2.7.27.27 2.69.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.2 4.36 2.62 6.78 6.98 6.98C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c4.35-.2 6.78-2.62 6.98-6.98.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.2-4.35-2.62-6.78-6.98-6.98C15.67.01 15.26 0 12 0m0 5.84A6.16 6.16 0 1 0 12 18.16 6.16 6.16 0 0 0 12 5.84m0 10.16A4 4 0 1 1 12 8a4 4 0 0 1 0 8m6.41-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88"/></svg></span><div><p class="cf-int-t">Instagram</p><p class="cf-int-s">Directs no inbox</p></div></div>
                <div class="cf-int"><span class="cf-int-ic text-primary-600"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M12 2a2 2 0 0 1 2 2v2h4a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4V4a2 2 0 0 1 2-2Z"/><circle cx="9" cy="13" r="1" fill="currentColor"/><circle cx="15" cy="13" r="1" fill="currentColor"/></svg></span><div><p class="cf-int-t">IA</p><p class="cf-int-s">Respostas e fluxos</p></div></div>
                <div class="cf-int"><span class="cf-int-ic text-slate-700"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M15 3v18"/></svg></span><div><p class="cf-int-t">CRM</p><p class="cf-int-s">Pipeline visual</p></div></div>
                <div class="cf-int"><span class="cf-int-ic text-violet-600"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M18 16.98h-5.99c-1.66 0-3.01-1.34-3.01-3s1.34-3 3.01-3H18M6 7.01h6c1.66 0 3 1.34 3 3s-1.34 3-3 3H6"/><circle cx="18" cy="16.98" r="2.5"/><circle cx="6" cy="7.01" r="2.5"/></svg></span><div><p class="cf-int-t">Webhooks</p><p class="cf-int-s">Plugue qualquer API</p></div></div>
                <div class="cf-int"><span class="cf-int-ic text-amber-600"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v4"/></svg></span><div><p class="cf-int-t">ElevenLabs</p><p class="cf-int-s">Voz humana</p></div></div>
              </div>
            </div>
          </div>
        </article>

        <!-- CARD 4 — CRM -->
        <article id="cf-crm" data-card data-index="3" class="cf-card" style="--i: 3">
          <div class="cf-card-inner grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
            <div>
              <span class="cf-badge">CRM</span>
              <h3 class="cf-title">Funil visual, do lead<br /><span class="text-primary-400">ao fechamento.</span></h3>
              <p class="cf-copy">Arrasta-e-solta, etapas customizáveis e histórico completo em cada card. Você enxerga o que está pra fechar agora e o que precisa de atenção.</p>
              <ul class="cf-list">
                <li>Kanban arrastável, etapas por pipeline</li>
                <li>Valor estimado e ticket médio por etapa</li>
                <li>Histórico do contato em cada card</li>
              </ul>
            </div>
            <!-- Mockup: kanban -->
            <div class="cf-mock">
              <div class="cf-winbar"><span></span><span></span><span></span><em>app.kora.com.br · Funil</em></div>
              <div class="p-3 bg-slate-50/60">
                <div class="grid grid-cols-3 gap-2">
                  <div class="bg-white rounded-lg border border-slate-200 p-2">
                    <div class="flex items-center justify-between mb-2"><p class="text-[10px] font-semibold text-slate-700">Triagem</p><span class="text-[9px] text-slate-400 tabular-nums">3</span></div>
                    <div class="space-y-1.5">
                      <div class="bg-slate-50 border border-slate-100 rounded p-1.5"><p class="text-[9px] font-semibold text-slate-700 truncate">Pedro N.</p><p class="text-[8px] text-slate-500">orçamento</p></div>
                      <div class="bg-slate-50 border border-slate-100 rounded p-1.5"><p class="text-[9px] font-semibold text-slate-700 truncate">Ana B.</p><p class="text-[8px] text-slate-500">consulta</p></div>
                    </div>
                  </div>
                  <div class="bg-white rounded-lg border border-slate-200 p-2">
                    <div class="flex items-center justify-between mb-2"><p class="text-[10px] font-semibold text-slate-700">Negociação</p><span class="text-[9px] text-amber-700 font-bold tabular-nums">R$ 2,1k</span></div>
                    <div class="space-y-1.5">
                      <div class="bg-amber-50 border border-amber-200 rounded p-1.5"><p class="text-[9px] font-semibold text-slate-700 truncate">Maria S.</p><p class="text-[8px] text-amber-700 font-bold">R$ 1.290</p></div>
                      <div class="bg-amber-50 border border-amber-200 rounded p-1.5"><p class="text-[9px] font-semibold text-slate-700 truncate">Lucas T.</p><p class="text-[8px] text-amber-700 font-bold">R$ 850</p></div>
                    </div>
                  </div>
                  <div class="bg-emerald-50 rounded-lg border border-emerald-200 p-2">
                    <div class="flex items-center justify-between mb-2"><p class="text-[10px] font-semibold text-emerald-700">Ganho</p><span class="text-[9px] font-bold text-emerald-700 tabular-nums">R$ 4,2k</span></div>
                    <div class="space-y-1.5">
                      <div class="bg-white border border-emerald-200 rounded p-1.5"><p class="text-[9px] font-semibold text-slate-700 truncate">João P.</p><p class="text-[8px] text-emerald-700 font-bold">R$ 780</p></div>
                      <div class="bg-white border border-emerald-200 rounded p-1.5"><p class="text-[9px] font-semibold text-slate-700 truncate">Fernanda D.</p><p class="text-[8px] text-emerald-700 font-bold">R$ 1.420</p></div>
                    </div>
                  </div>
                </div>
                <div class="mt-3 pt-2 border-t border-slate-200/70 flex items-center justify-between text-[9px] flex-wrap gap-1">
                  <span class="text-slate-500">Conversão <span class="font-bold text-emerald-700">34%</span></span>
                  <span class="text-slate-500">Ticket <span class="font-bold text-slate-800">R$ 1.420</span></span>
                  <span class="text-slate-500"><span class="font-bold text-emerald-700">3</span> fechados hoje</span>
                </div>
              </div>
            </div>
          </div>
        </article>

      </div>
    </div>
  </div>
</section>

<style>
  /* ── Tokens visuais do bloco ───────────────────────────── */
  .cf-card {
    background: #0b1020;                 /* navy profundo (--color-ink) */
    border-radius: 1.75rem;
    border: 1px solid rgb(255 255 255 / 0.08);
    box-shadow: 0 24px 60px -24px rgb(2 6 23 / 0.55);
    padding: 1.5rem;
    overflow: hidden;
    /* Empilhamento também no MOBILE: sticky abaixo da barra de nav (4rem),
       com top crescente por card pra fresta "em leque". O card é opaco (navy),
       então cobre o anterior. */
    position: sticky;
    top: calc(5rem + var(--i) * 0.8rem);
  }
  /* respiro entre os cards pra haver percurso de scroll antes de empilhar */
  .cf-card + .cf-card { margin-top: 1.5rem; }

  @media (min-width: 1024px) {
    .cf-card {
      top: calc(6.5rem + var(--i) * 1.15rem);
      padding: 2.5rem;
      min-height: 420px;
    }
    .cf-card + .cf-card { margin-top: 2.5rem; }
  }

  .cf-badge {
    display: inline-flex; align-items: center;
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--color-primary-300);
    background: rgb(0 74 221 / 0.14);
    border: 1px solid rgb(94 133 255 / 0.25);
    border-radius: 9999px; padding: 0.25rem 0.7rem; margin-bottom: 1rem;
  }
  .cf-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3.5vw, 2.25rem);
    font-weight: 700; line-height: 1.1; letter-spacing: -0.025em;
    color: #fff;
  }
  .cf-copy { color: rgb(203 213 225 / 1); margin-top: 1rem; line-height: 1.6; font-size: 0.975rem; max-width: 30rem; }
  .cf-list { margin-top: 1.25rem; display: flex; flex-direction: column; gap: 0.55rem; }
  .cf-list li {
    position: relative; padding-left: 1.5rem;
    font-size: 0.85rem; color: rgb(148 163 184 / 1);
  }
  .cf-list li::before {
    content: ""; position: absolute; left: 0; top: 0.45em;
    width: 0.85rem; height: 0.5rem;
    border-left: 2px solid var(--color-primary-400);
    border-bottom: 2px solid var(--color-primary-400);
    transform: rotate(-45deg);
  }

  /* Janela de app (mockup claro sobre o card navy) */
  .cf-mock {
    background: #fff; border-radius: 1rem; overflow: hidden;
    border: 1px solid rgb(255 255 255 / 0.1);
    box-shadow: 0 20px 45px -20px rgb(2 6 23 / 0.6);
  }
  .cf-winbar {
    display: flex; align-items: center; gap: 0.375rem;
    background: var(--color-slate-50, #f8fafc); border-bottom: 1px solid #e2e8f0;
    padding: 0.6rem 0.75rem;
  }
  .cf-winbar span { width: 0.6rem; height: 0.6rem; border-radius: 9999px; }
  .cf-winbar span:nth-child(1) { background: #fb7185; }
  .cf-winbar span:nth-child(2) { background: #fbbf24; }
  .cf-winbar span:nth-child(3) { background: #34d399; }
  .cf-winbar em { font-style: normal; font-size: 0.625rem; color: #94a3b8; font-weight: 500; margin-left: 0.5rem; }

  .cf-kpi { background: rgb(248 250 252 / 0.8); border: 1px solid #f1f5f9; border-radius: 0.5rem; padding: 0.6rem; }
  .cf-kpi-l { font-size: 0.55rem; text-transform: uppercase; font-weight: 600; letter-spacing: 0.05em; color: #94a3b8; }
  .cf-kpi-v { font-size: 1.35rem; font-weight: 700; color: #0f172a; font-variant-numeric: tabular-nums; line-height: 1; margin-top: 0.2rem; }
  .cf-kpi-v span { font-size: 0.8rem; color: #64748b; }
  .cf-kpi-up { font-size: 0.6rem; color: #059669; font-weight: 600; margin-top: 0.35rem; }

  .cf-int { display: flex; align-items: center; gap: 0.6rem; background: #fff; border: 1px solid #e2e8f0; border-radius: 0.75rem; padding: 0.7rem; }
  .cf-int-ic { display: inline-flex; align-items: center; justify-content: center; width: 2rem; height: 2rem; border-radius: 0.5rem; background: #f8fafc; border: 1px solid #f1f5f9; flex-shrink: 0; }
  .cf-int-t { font-size: 0.8rem; font-weight: 700; color: #0f172a; line-height: 1.1; }
  .cf-int-s { font-size: 0.65rem; color: #94a3b8; }

  /* Rail ativo */
  .rail-item.is-active { color: #0f172a; border-left-color: var(--color-primary-600); }
  .rail-item.is-active .rail-icon { color: var(--color-primary-600); }

  /* Reduced motion: sem sticky (cards em fluxo normal) pra evitar enjoo */
  @media (prefers-reduced-motion: reduce) {
    .cf-card { position: static !important; min-height: 0 !important; }
    .cf-card + .cf-card { margin-top: 1.25rem; }
  }

  /* ── Mobile pequeno: compacta os cards pra caber na tela ── */
  @media (max-width: 480px) {
    .cf-card {
      padding: 1.1rem;
      border-radius: 1.25rem;
      top: calc(4.5rem + var(--i) * 0.55rem);
    }
    .cf-card + .cf-card { margin-top: 0.85rem; }

    /* Grid: texto em cima, mockup embaixo — 1 coluna */
    .cf-card-inner {
      grid-template-columns: 1fr !important;
      gap: 1rem !important;
    }

    /* Badge */
    .cf-badge {
      font-size: 0.62rem;
      padding: 0.2rem 0.55rem;
      margin-bottom: 0.6rem;
    }

    /* Título */
    .cf-title { font-size: 1.3rem; line-height: 1.15; }

    /* Descrição */
    .cf-copy { font-size: 0.83rem; margin-top: 0.5rem; }

    /* Bullets */
    .cf-list { margin-top: 0.65rem; gap: 0.35rem; }
    .cf-list li { font-size: 0.77rem; }

    /* Mockup: full width, altura limitada pra não vazar */
    .cf-mock {
      width: 100%;
      max-height: 220px;
      overflow: hidden;
      border-radius: 0.75rem;
    }

    /* Textos dentro do mockup menores */
    .cf-mock .text-sm  { font-size: 0.7rem !important; }
    .cf-mock .text-xs  { font-size: 0.65rem !important; }
    .cf-mock .text-\[10px\] { font-size: 8px !important; }
    .cf-mock .text-\[9px\]  { font-size: 7px !important; }
    .cf-mock .text-\[8px\]  { font-size: 7px !important; }

    /* KPIs: valor menor */
    .cf-kpi-v { font-size: 1rem !important; }

    /* Padding interno do mockup */
    .cf-mock > div:not(.cf-winbar) { padding: 0.6rem !important; }
    .cf-mock .p-4  { padding: 0.6rem !important; }
    .cf-mock .p-3  { padding: 0.5rem !important; }
    .cf-mock .p-6  { padding: 0.75rem !important; }
    .cf-mock .gap-2   { gap: 0.35rem !important; }
    .cf-mock .gap-2\.5 { gap: 0.4rem !important; }

    /* Integrações: grid 2 colunas mais compacto */
    .cf-int { padding: 0.45rem 0.5rem; gap: 0.4rem; }
    .cf-int-ic { width: 1.5rem; height: 1.5rem; }
  }
</style>

<script>
  // Scrollspy: acende o item do rail correspondente ao card mais "à frente" (topo).
  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-card]'))
  const rails = Array.from(document.querySelectorAll<HTMLElement>('[data-rail]'))

  if (cards.length && rails.length && 'IntersectionObserver' in window) {
    const visible = new Set<number>()

    const setActive = (idx: number) => {
      rails.forEach((r) => {
        const i = Number(r.dataset.index)
        r.classList.toggle('is-active', i === idx)
      })
    }

    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          const i = Number((e.target as HTMLElement).dataset.index)
          if (e.isIntersecting) visible.add(i)
          else visible.delete(i)
        }
        // O card "ativo" é o de maior índice na faixa (o que está empilhado por cima)
        if (visible.size) setActive(Math.max(...visible))
      },
      // Faixa fina perto do topo (onde o card empilhado fica)
      { rootMargin: '-15% 0px -75% 0px', threshold: 0 }
    )
    cards.forEach((c) => io.observe(c))
    setActive(0)
  }
</script>
