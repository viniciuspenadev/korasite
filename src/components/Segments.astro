---
/**
 * "Pra quem é" — segmentos de PME que ressoam com o produto.
 * Cada card é um espelho: o visitante se reconhece em um deles.
 */

const segments = [
  {
    icon:    "shopping",
    name:    "Varejo & e-commerce",
    tagline: "Loja de roupa, ótica, móveis. Cada lead com origem rastreada até o caixa.",
  },
  {
    icon:    "stethoscope",
    name:    "Clínicas & estética",
    tagline: "Confirma consulta, faz pré-atendimento, follow-up pós-procedimento sem atendente sobrecarregado.",
  },
  {
    icon:    "house",
    name:    "Imobiliárias",
    tagline: "Distribui lead pra corretor, evita lead esquecido, mede campanha por anúncio.",
  },
  {
    icon:    "book",
    name:    "Educação & cursos",
    tagline: "Captação de matrículas, dúvidas pré-venda, acompanhamento de turma.",
  },
  {
    icon:    "utensils",
    name:    "Restaurantes & delivery",
    tagline: "Pedido pelo WhatsApp, status do pedido, fidelização em escala.",
  },
  {
    icon:    "briefcase",
    name:    "Serviços B2C",
    tagline: "Oficina, salão, advocacia, contador. Agenda + lembrete + cobrança automáticos.",
  },
] as const

const icons: Record<typeof segments[number]["icon"], string> = {
  shopping:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>`,
  stethoscope: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.8 2.3A.3.3 0 105 2H4a2 2 0 00-2 2v5a6 6 0 006 6v0a6 6 0 006-6V4a2 2 0 00-2-2h-1a.2.2 0 10.3.3"/><path d="M8 15v1a6 6 0 006 6v0a6 6 0 006-6v-4"/><circle cx="20" cy="10" r="2"/></svg>`,
  house:       `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  book:        `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>`,
  utensils:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h0a2 2 0 002-2V2"/><path d="M5 11v11"/><path d="M19 2v20"/><path d="M19 14c0-3-2-5-5-5-3 0-5 2-5 5"/></svg>`,
  briefcase:   `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>`,
}
---

<section id="para-quem" class="relative bg-slate-50 py-24 lg:py-32">
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center max-w-2xl mx-auto mb-14">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary-600 mb-4">
        Pra quem é
      </p>
      <h2 class="text-4xl sm:text-5xl font-bold text-slate-900 tracking-tight leading-[1.1]">
        Se você vende ou atende<br />
        pelo WhatsApp, é pra você.
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {segments.map((s) => (
        <article class="group bg-white border border-slate-200 rounded-2xl p-6 hover:border-primary-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary-600/5 transition-all cursor-default">
          <div class="size-10 rounded-lg bg-primary-50 text-primary-700 flex items-center justify-center mb-4 group-hover:bg-primary-600 group-hover:text-white transition-colors">
            <span class="size-5" set:html={icons[s.icon]}></span>
          </div>
          <h3 class="text-base font-bold text-slate-900 tracking-tight">
            {s.name}
          </h3>
          <p class="text-sm text-slate-600 mt-1.5 leading-relaxed">
            {s.tagline}
          </p>
        </article>
      ))}
    </div>

    <p class="text-center text-sm text-slate-500 mt-12">
      Não viu seu segmento? <a href="#cta-final" class="text-primary-700 font-semibold underline-offset-4 hover:underline">Fala com a gente</a>, provavelmente atende.
    </p>
  </div>
</section>
