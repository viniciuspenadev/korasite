---
/**
 * 4 diferenciais que separam Kora dos concorrentes (Botconversa, ManyChat, Funnels).
 * Tom: confiante mas humano. Sem hyperbole. Cada card argumenta UMA coisa.
 *
 * Visual: bloco AZUL ESCURO no meio do site — quebra a sequência de seções
 * claras e ancora a leitura ("este é o momento sério, presta atenção").
 */

const features = [
  {
    title: "Vários números. Uma operação.",
    body:  "Cada número de WhatsApp com seu atendente, horário e regra. Tudo no mesmo painel, no mesmo histórico, sem alternar entre apps.",
    icon:  "stack",
    badge: "Sem amarração",
  },
  {
    title: "IA que sabe a hora do humano.",
    body:  "Treina com o tom da sua marca, responde a qualquer hora do dia, e passa pro humano no momento certo. Conversa fluida que entende contexto.",
    icon:  "spark",
    badge: "Com toque humano",
  },
  {
    title: "Relatórios que você abre.",
    body:  "Conversão por anúncio, ticket médio por atendente, funil ao vivo, tempo de 1ª resposta. Tudo pronto, sem precisar montar.",
    icon:  "chart",
    badge: "ROI claro",
  },
  {
    title: "Brasileiro, com servidor no Brasil.",
    body:  "Dados no Brasil, LGPD por padrão, suporte em PT-BR de gente real. Você é dono dos seus dados; exporta a qualquer hora.",
    icon:  "shield",
    badge: "LGPD-ready",
  },
] as const

const icons: Record<typeof features[number]["icon"], string> = {
  stack:  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
  spark:  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 5.8L20 11l-6.1 2.2L12 19l-1.9-5.8L4 11l6.1-2.2L12 3z"/></svg>`,
  chart:  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-5"/></svg>`,
  shield: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l9 4v6c0 5.5-3.8 10.7-9 12-5.2-1.3-9-6.5-9-12V6l9-4z"/><path d="M9 12l2 2 4-4"/></svg>`,
}
---

<section class="relative bg-primary-950 py-24 lg:py-32 overflow-hidden">
  <!-- Decorativo: blobs azul + grid sutil -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-32 -left-32 w-[36rem] h-[36rem] bg-primary-600 rounded-full blur-[120px] opacity-25"></div>
    <div class="absolute -bottom-40 -right-20 w-[32rem] h-[32rem] bg-primary-500 rounded-full blur-[120px] opacity-20"></div>
    <!-- grid lines -->
    <div
      class="absolute inset-0 opacity-[0.05]"
      style="background-image: linear-gradient(to right, white 1px, transparent 1px), linear-gradient(to bottom, white 1px, transparent 1px); background-size: 64px 64px;"
    ></div>
    <!-- top fade pra suavizar borda com seção anterior -->
    <div class="absolute top-0 inset-x-0 h-32 bg-gradient-to-b from-primary-950 to-transparent"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6">

    <div data-reveal class="max-w-2xl mb-16">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary-300 mb-4">
        Por que Kora
      </p>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tight leading-[1.05]">
        Kora não é um Bot.<br />
        É a sua operação<br />
        <span class="bg-gradient-to-r from-primary-200 to-primary-400 bg-clip-text text-transparent">
          de WhatsApp inteira.
        </span>
      </h2>
      <p class="text-lg text-slate-300 mt-6 leading-relaxed">
        Cada decisão de produto da Kora resolve um problema real de quem vende e atende pelo WhatsApp todo dia.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
      {features.map((f) => (
        <article class="group relative bg-white/[0.04] backdrop-blur-sm border border-white/10 rounded-2xl p-7 hover:bg-white/[0.07] hover:border-primary-400/30 transition-all">
          <!-- Icon badge -->
          <div class="size-11 rounded-xl bg-primary-500/15 ring-1 ring-primary-400/30 text-primary-200 flex items-center justify-center mb-5 group-hover:bg-primary-500/25 group-hover:text-primary-100 transition-colors">
            <span class="size-5" set:html={icons[f.icon]}></span>
          </div>

          <!-- Title -->
          <h3 class="text-xl lg:text-2xl font-bold text-white tracking-tight leading-tight">
            {f.title}
          </h3>

          <!-- Body -->
          <p class="text-base text-slate-300 mt-3 leading-relaxed">
            {f.body}
          </p>

          <!-- Badge bottom -->
          <span class="inline-flex items-center gap-1.5 mt-6 text-[11px] font-semibold uppercase tracking-wider text-primary-200 bg-primary-500/10 rounded-full px-2.5 py-1 ring-1 ring-primary-400/20">
            <span class="size-1 rounded-full bg-primary-300"></span>
            {f.badge}
          </span>
        </article>
      ))}
    </div>
  </div>

  <!-- Bottom fade pra suavizar borda com seção seguinte (Segments slate-50) -->
  <div class="absolute bottom-0 inset-x-0 h-32 bg-gradient-to-t from-primary-950 to-transparent pointer-events-none"></div>
</section>
