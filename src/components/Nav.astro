---
import { BRAND, waLink } from "@/lib/brand"

const icons: Record<string, string> = {
  users:       `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  bot:         `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="7" width="16" height="13" rx="2"/><path d="M12 7V4M8 3h8"/><circle cx="9" cy="13" r="1" fill="currentColor"/><circle cx="15" cy="13" r="1" fill="currentColor"/></svg>`,
  kanban:      `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M15 3v18"/></svg>`,
  chat:        `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  megaphone:   `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l15-6v14L3 13z"/><path d="M3 11v2a2 2 0 0 0 2 2h1l1 5h3l-1-5"/></svg>`,
  chart:       `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 15l3-4 3 2 4-6"/></svg>`,
  calendar:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>`,
  shopping:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>`,
  stethoscope: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.8 2.3A.3.3 0 105 2H4a2 2 0 00-2 2v5a6 6 0 006 6 6 6 0 006-6V4a2 2 0 00-2-2h-1a.2.2 0 10.3.3"/><path d="M8 15v1a6 6 0 006 6 6 6 0 006-6v-4"/><circle cx="20" cy="10" r="2"/></svg>`,
  house:       `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  book:        `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>`,
  utensils:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7a2 2 0 002 2 2 2 0 002-2V2"/><path d="M5 11v11"/><path d="M19 2v20"/><path d="M19 14c0-3-2-5-5-5"/></svg>`,
  briefcase:   `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>`,
}

const recursos = [
  { icon: "users",     title: "Multiatendimento", desc: "Todo o time no mesmo número.", href: "/recursos/multiatendimento-whatsapp", badge: "Novo" },
  { icon: "calendar",  title: "Agenda",           desc: "Agendamento dentro do WhatsApp.", href: "/recursos/agendamento-whatsapp", badge: "Novo" },
  { icon: "bot",       title: "Atendente IA",     desc: "Apoio que não deixa lead sem resposta.", href: "/recursos/atendimento-ia-whatsapp", badge: "Novo" },
  { icon: "kanban",    title: "CRM & Funil",      desc: "Funil visual, do lead ao fechamento.", href: "/recursos/crm-whatsapp", badge: "Novo" },
  { icon: "chat",      title: "Chat Interno",     desc: "Time alinhado, cliente não vê.", href: "/#produto" },
  { icon: "megaphone", title: "Disparos",         desc: "Campanhas pelo número oficial.", href: "/#produto" },
  { icon: "chart",     title: "Relatórios",       desc: "Métricas em tempo real.",      href: "/#produto" },
]

const solucoes = [
  { icon: "shopping",    title: "Varejo & e-commerce",   desc: "Do anúncio ao caixa.",        href: "/#para-quem" },
  { icon: "stethoscope", title: "Clínicas & estética",   desc: "Agenda e follow-up.",         href: "/#para-quem" },
  { icon: "house",       title: "Imobiliárias",          desc: "Lead pro corretor certo.",    href: "/#para-quem" },
  { icon: "book",        title: "Educação & cursos",     desc: "Matrículas e turmas.",        href: "/#para-quem" },
  { icon: "utensils",    title: "Restaurantes & delivery", desc: "Pedido e fidelização.",     href: "/#para-quem" },
  { icon: "briefcase",   title: "Serviços B2C",          desc: "Agenda, lembrete e cobrança.", href: "/#para-quem" },
]

// Conteúdos em destaque (coluna "Direto do blog" do painel Recursos)
const featuredPosts = [
  { img: "/blog/images/CRM-para-WhatsApp-convertido-de-jpg.webp", title: "CRM para WhatsApp: o guia completo", href: "/blog/crm-para-whatsapp-guia-completo" },
  { img: "/blog/images/IA-no-atendimento-convertido-de-jpg.webp", title: "IA no atendimento sem perder o toque humano", href: "/blog/ia-no-atendimento-sem-perder-toque-humano" },
]
---

<header class="fixed top-0 inset-x-0 z-50 backdrop-blur-md bg-[var(--color-paper)]/80 border-b border-slate-200/70 transition-colors duration-300" id="global-nav">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="inline-flex items-center shrink-0">
      <img src={BRAND.logo} alt={BRAND.name} width="110" height="32" class="h-8 lg:h-9 w-auto select-none" draggable="false" id="nav-logo" />
    </a>

    <!-- Menu desktop -->
    <div class="hidden lg:flex items-center gap-1">

      <!-- Recursos (painel) -->
      <div class="relative" data-dropdown>
        <button type="button" data-trigger aria-haspopup="true" aria-expanded="false"
          class="inline-flex items-center gap-1 text-sm font-medium text-slate-600 hover:text-slate-900 px-3 py-2 rounded-lg hover:bg-slate-100/70 transition-colors">
          Recursos
          <svg class="dd-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="dd-panel absolute left-0 top-full pt-3" data-panel>
          <div class="w-[680px] rounded-2xl bg-white border border-slate-200 shadow-[0_24px_60px_-20px_rgba(2,6,23,0.30)] p-2.5 grid grid-cols-[212px_1fr] gap-2.5 items-stretch">

            <!-- Esquerda: Direto do blog (imagens em rotação) -->
            <div class="rounded-xl bg-slate-50 border border-slate-100 p-2.5 flex flex-col">
              <p class="px-1 pb-2 text-[11px] font-bold uppercase tracking-wider text-slate-400">Direto do blog</p>
              <a id="feat-link" href={featuredPosts[0].href} data-feat-card class="group/f flex-1 min-h-0 flex flex-col">
                <span class="block flex-1 min-h-0 rounded-lg overflow-hidden ring-1 ring-slate-200/70">
                  <img id="feat-img" src={featuredPosts[0].img} alt={featuredPosts[0].title} width="320" height="320" loading="lazy" class="feat-fade w-full h-full object-cover object-right transition duration-500 group-hover/f:scale-[1.04]" />
                </span>
                <span id="feat-title" class="feat-fade block shrink-0 text-[12px] font-bold text-slate-800 leading-snug mt-2.5 group-hover/f:text-primary-700 transition-colors">{featuredPosts[0].title}</span>
              </a>
              <div class="flex items-center gap-1.5 mt-3">
                {featuredPosts.map((_, i) => (<span data-feat-dot data-active={i === 0 ? "" : null} class="feat-dot"></span>))}
                <a href="/blog" class="ml-auto text-[11px] font-semibold text-primary-600 hover:text-primary-700">Ver o blog →</a>
              </div>
              <script type="application/json" id="feat-data" is:inline set:html={JSON.stringify(featuredPosts)}></script>
            </div>

            <!-- Direita: recursos da plataforma -->
            <div class="flex flex-col">
              <p class="px-3 pt-1.5 pb-2 text-[11px] font-bold uppercase tracking-wider text-slate-400">Recursos da plataforma</p>
              <div class="grid grid-cols-2 gap-0.5">
                {recursos.map((it) => (
                  <a href={it.href} class="dd-item group/i flex items-start gap-3 rounded-xl p-2.5 hover:bg-slate-50 transition-colors">
                    <span class="dd-ic" set:html={icons[it.icon]} />
                    <span class="min-w-0">
                      <span class="flex items-center gap-1.5">
                        <span class="text-[13px] font-bold text-slate-800 group-hover/i:text-primary-700 transition-colors">{it.title}</span>
                        {it.badge && <span class="text-[9px] font-bold uppercase tracking-wide text-emerald-700 bg-emerald-50 border border-emerald-100 rounded px-1 py-0.5">{it.badge}</span>}
                      </span>
                      <span class="block text-[11px] text-slate-500 leading-snug mt-0.5">{it.desc}</span>
                    </span>
                  </a>
                ))}
              </div>
              <a href="/recursos" class="mt-auto flex items-center justify-between rounded-xl bg-slate-50 px-3 py-2.5 text-[13px] font-semibold text-slate-700 hover:bg-slate-100 transition-colors">
                Ver todos os recursos
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Soluções (painel) -->
      <div class="relative" data-dropdown>
        <button type="button" data-trigger aria-haspopup="true" aria-expanded="false"
          class="inline-flex items-center gap-1 text-sm font-medium text-slate-600 hover:text-slate-900 px-3 py-2 rounded-lg hover:bg-slate-100/70 transition-colors">
          Soluções
          <svg class="dd-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="dd-panel absolute left-0 top-full pt-3" data-panel>
          <div class="w-[480px] rounded-2xl bg-white border border-slate-200 shadow-[0_24px_60px_-20px_rgba(2,6,23,0.30)] p-2.5">
            <p class="px-3 pt-1.5 pb-2 text-[11px] font-bold uppercase tracking-wider text-slate-400">Pra quem é</p>
            <div class="grid grid-cols-2 gap-0.5">
              {solucoes.map((it) => (
                <a href={it.href} class="dd-item group/i flex items-start gap-3 rounded-xl p-2.5 hover:bg-slate-50 transition-colors">
                  <span class="dd-ic" set:html={icons[it.icon]} />
                  <span class="min-w-0">
                    <span class="block text-[13px] font-bold text-slate-800 group-hover/i:text-primary-700 transition-colors">{it.title}</span>
                    <span class="block text-[11px] text-slate-500 leading-snug mt-0.5">{it.desc}</span>
                  </span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <a href="/#faq"  class="text-sm font-medium text-slate-600 hover:text-slate-900 px-3 py-2 rounded-lg hover:bg-slate-100/70 transition-colors">Preços</a>
      <a href="/blog"  class="text-sm font-medium text-slate-600 hover:text-slate-900 px-3 py-2 rounded-lg hover:bg-slate-100/70 transition-colors">Blog</a>
    </div>

    <!-- Direita: CTA + hambúrguer -->
    <div class="flex items-center gap-2">
      <a href={waLink()} target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[var(--color-primary-600)] hover:bg-[var(--color-primary-700)] text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        <span class="hidden sm:inline">{BRAND.whatsappCta}</span>
      </a>

      <button type="button" id="nav-toggle"
        class="lg:hidden inline-flex items-center justify-center size-10 -mr-2 rounded-lg text-slate-700 hover:bg-slate-100 transition-colors"
        aria-label="Abrir menu" aria-expanded="false" aria-controls="nav-mobile-menu">
        <svg id="nav-icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg id="nav-icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>
  </nav>

  <!-- Painel mobile (acordeão) -->
  <div id="nav-mobile-menu" class="lg:hidden hidden border-t border-slate-200/70 bg-[var(--color-paper)]/97 backdrop-blur-md max-h-[calc(100vh-4rem)] overflow-y-auto">
    <nav class="max-w-6xl mx-auto px-6 py-3 flex flex-col">

      <!-- Recursos -->
      <button type="button" data-acc-trigger aria-expanded="false" class="flex items-center justify-between py-3 text-base font-semibold text-slate-800">
        Recursos
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="transition-transform"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <div class="hidden pb-2 grid grid-cols-1 gap-0.5">
        {recursos.map((it) => (
          <a href={it.href} class="flex items-center gap-3 py-2 pl-2 text-sm text-slate-600 hover:text-slate-900">
            <span class="dd-ic dd-ic-sm" set:html={icons[it.icon]} />
            {it.title}
            {it.badge && <span class="text-[9px] font-bold uppercase text-emerald-700 bg-emerald-50 border border-emerald-100 rounded px-1 py-0.5">{it.badge}</span>}
          </a>
        ))}
        <!-- Direto do blog -->
        <p class="px-2 pt-3 pb-1 text-[10px] font-bold uppercase tracking-wider text-slate-400">Direto do blog</p>
        {featuredPosts.map((p) => (
          <a href={p.href} class="flex items-center gap-3 py-1.5 pl-2">
            <img src={p.img} alt={p.title} width="80" height="48" loading="lazy" class="w-20 h-12 rounded-md object-cover object-right ring-1 ring-slate-200/70 shrink-0" />
            <span class="text-[13px] font-semibold text-slate-700 leading-snug">{p.title}</span>
          </a>
        ))}
      </div>

      <!-- Soluções -->
      <button type="button" data-acc-trigger aria-expanded="false" class="flex items-center justify-between py-3 text-base font-semibold text-slate-800 border-t border-slate-100">
        Soluções
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="transition-transform"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <div class="hidden pb-2 grid grid-cols-1 gap-0.5">
        {solucoes.map((it) => (
          <a href={it.href} class="flex items-center gap-3 py-2 pl-2 text-sm text-slate-600 hover:text-slate-900">
            <span class="dd-ic dd-ic-sm" set:html={icons[it.icon]} />
            {it.title}
          </a>
        ))}
      </div>

      <a href="/#faq" class="py-3 text-base font-semibold text-slate-800 border-t border-slate-100">Preços</a>
      <a href="/blog" class="py-3 text-base font-semibold text-slate-800 border-t border-slate-100">Blog</a>
    </nav>
  </div>
</header>

<style>
  .dd-panel {
    opacity: 0; visibility: hidden; transform: translateY(-6px);
    transition: opacity .18s ease, transform .18s ease, visibility .18s;
    pointer-events: none;
  }
  [data-dropdown][data-open] .dd-panel { opacity: 1; visibility: visible; transform: translateY(0); pointer-events: auto; }
  .dd-chevron { transition: transform .2s ease; }
  [data-dropdown][data-open] .dd-chevron { transform: rotate(180deg); }

  .dd-ic {
    display: inline-flex; align-items: center; justify-content: center;
    width: 2.1rem; height: 2.1rem; flex-shrink: 0;
    border-radius: 0.6rem; background: var(--color-primary-50); color: var(--color-primary-700);
  }
  .dd-item:hover .dd-ic { background: var(--color-primary-600); color: #fff; }
  .dd-ic :global(svg) { width: 1.1rem; height: 1.1rem; }
  .dd-ic-sm { width: 1.6rem; height: 1.6rem; border-radius: 0.45rem; }
  .dd-ic-sm :global(svg) { width: 0.9rem; height: 0.9rem; }

  /* Destaque "Direto do blog" */
  .feat-fade { transition: opacity .35s ease; }
  .feat-fade.is-fading { opacity: 0; }
  .feat-dot { width: .4rem; height: .4rem; border-radius: 9999px; background: #cbd5e1; transition: width .3s ease, background .3s ease; }
  .feat-dot[data-active] { width: 1rem; background: var(--color-primary-600); }
</style>

<script is:inline>
  (() => {
    const nav = document.getElementById('global-nav')
    if (!nav) return

    // ── Dropdowns desktop ──────────────────────────────
    const dropdowns = Array.from(nav.querySelectorAll('[data-dropdown]'))
    let closeTimer = null

    const closeAll = (except) => {
      dropdowns.forEach((d) => {
        if (d === except) return
        d.removeAttribute('data-open')
        d.querySelector('[data-trigger]')?.setAttribute('aria-expanded', 'false')
      })
    }
    const open = (d) => {
      clearTimeout(closeTimer); closeAll(d)
      d.setAttribute('data-open', '')
      d.querySelector('[data-trigger]')?.setAttribute('aria-expanded', 'true')
    }
    const close = (d) => {
      d.removeAttribute('data-open')
      d.querySelector('[data-trigger]')?.setAttribute('aria-expanded', 'false')
    }

    dropdowns.forEach((d) => {
      const trigger = d.querySelector('[data-trigger]')
      d.addEventListener('mouseenter', () => open(d))
      d.addEventListener('mouseleave', () => { closeTimer = setTimeout(() => close(d), 130) })
      trigger?.addEventListener('click', (e) => {
        e.preventDefault()
        d.hasAttribute('data-open') ? close(d) : open(d)
      })
      d.addEventListener('focusout', (e) => { if (!d.contains(e.relatedTarget)) close(d) })
    })

    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAll(null) })
    document.addEventListener('click', (e) => { if (!nav.contains(e.target)) closeAll(null) })

    // ── Menu mobile ────────────────────────────────────
    const toggle = document.getElementById('nav-toggle')
    const menu   = document.getElementById('nav-mobile-menu')
    const iconO  = document.getElementById('nav-icon-open')
    const iconC  = document.getElementById('nav-icon-close')
    const setMobile = (o) => {
      menu.classList.toggle('hidden', !o)
      iconO?.classList.toggle('hidden', o)
      iconC?.classList.toggle('hidden', !o)
      toggle.setAttribute('aria-expanded', String(o))
      toggle.setAttribute('aria-label', o ? 'Fechar menu' : 'Abrir menu')
    }
    toggle?.addEventListener('click', () => setMobile(menu.classList.contains('hidden')))
    menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setMobile(false)))
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu && !menu.classList.contains('hidden')) setMobile(false)
    })

    // ── Acordeões mobile ───────────────────────────────
    nav.querySelectorAll('[data-acc-trigger]').forEach((t) => {
      t.addEventListener('click', () => {
        const panel = t.nextElementSibling
        const willOpen = panel.classList.contains('hidden')
        panel.classList.toggle('hidden', !willOpen)
        t.setAttribute('aria-expanded', String(willOpen))
        t.querySelector('svg')?.classList.toggle('rotate-180', willOpen)
      })
    })

    // ── Rotação dos posts em destaque (painel Recursos) ─
    let featData = []
    try { featData = JSON.parse(document.getElementById('feat-data')?.textContent || '[]') } catch (_) {}
    const featLink  = document.getElementById('feat-link')
    const featImg   = document.getElementById('feat-img')
    const featTitle = document.getElementById('feat-title')
    const featCard  = nav.querySelector('[data-feat-card]')
    const featDots  = Array.from(nav.querySelectorAll('[data-feat-dot]'))
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    if (featData.length > 1 && featLink && featImg && featTitle && !reduceMotion) {
      let fi = 0, featTimer = null
      const showFeat = (i) => {
        featImg.classList.add('is-fading'); featTitle.classList.add('is-fading')
        setTimeout(() => {
          const p = featData[i]
          featLink.href = p.href; featImg.src = p.img; featImg.alt = p.title; featTitle.textContent = p.title
          featDots.forEach((d, di) => d.toggleAttribute('data-active', di === i))
          featImg.classList.remove('is-fading'); featTitle.classList.remove('is-fading')
        }, 350)
      }
      const startFeat = () => { stopFeat(); featTimer = setInterval(() => { fi = (fi + 1) % featData.length; showFeat(fi) }, 4500) }
      function stopFeat() { if (featTimer) clearInterval(featTimer) }
      startFeat()
      // pausa no hover pra não trocar o link embaixo do cursor
      featCard?.addEventListener('mouseenter', stopFeat)
      featCard?.addEventListener('mouseleave', startFeat)
    }
  })()
</script>
