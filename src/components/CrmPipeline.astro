---
/**
 * CRM Pipeline — kanban "vivo" e realista: cada card é uma CONVERSA de cliente
 * (com a logo do canal + uma linha da mensagem). Um card entra na 1ª etapa,
 * é "pego" e arrastado pra outra coluna; ao soltar, os cards de baixo descem
 * pra abrir espaço (reflow). A coreografia é feita em JS (posições reais).
 *
 * Posição: entre LogoMarquee e FlowAnimation. O board "mergulha" na BG escura
 * da FlowAnimation via margem negativa (ponte claro→escuro).
 */

type Channel = "whatsapp" | "instagram" | "facebook" | "telegram"
type Conv = { name: string; channel: Channel; msg: string }

const channels: Record<Channel, { color: string; svg: string }> = {
  whatsapp: {
    color: "#25D366",
    svg: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.21 3.07.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.07-.12-.27-.2-.57-.35M12.05 21.8h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.99 2.9a9.82 9.82 0 0 1 2.89 6.99c0 5.45-4.44 9.88-9.88 9.88"/></svg>`,
  },
  instagram: {
    color: "#E1306C",
    svg: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85C2.38 3.92 3.9 2.38 7.15 2.23 8.42 2.17 8.8 2.16 12 2.16M12 0C8.74 0 8.33.01 7.05.07 2.7.27.27 2.69.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.2 4.36 2.62 6.78 6.98 6.98C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c4.35-.2 6.78-2.62 6.98-6.98.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.2-4.35-2.62-6.78-6.98-6.98C15.67.01 15.26 0 12 0m0 5.84A6.16 6.16 0 1 0 12 18.16 6.16 6.16 0 0 0 12 5.84m0 10.16A4 4 0 1 1 12 8a4 4 0 0 1 0 8m6.41-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88"/></svg>`,
  },
  facebook: {
    color: "#1877F2",
    svg: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.97h-1.52c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8V24C19.61 23.1 24 18.1 24 12.07"/></svg>`,
  },
  telegram: {
    color: "#229ED9",
    svg: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.94 2.5C6.7 2.5 2.44 6.76 2.44 12s4.26 9.5 9.5 9.5 9.5-4.26 9.5-9.5-4.25-9.5-9.5-9.5m4.42 6.5-1.48 6.96c-.1.49-.4.61-.81.38l-2.24-1.65-1.08 1.04c-.12.12-.22.22-.45.22l.16-2.28 4.15-3.75c.18-.16-.04-.25-.28-.09l-5.13 3.23-2.21-.69c-.48-.15-.49-.48.1-.71l8.63-3.33c.4-.15.75.09.62.7"/></svg>`,
  },
}

const board: { label: string; dot: string; pill: string; base: number; cards: Conv[] }[] = [
  { label: "Lead Novo", dot: "bg-primary-500", pill: "text-primary-700 bg-primary-50", base: 0, cards: [] },
  {
    label: "Amostra Enviada", dot: "bg-emerald-500", pill: "text-emerald-700 bg-emerald-50", base: 2,
    cards: [
      { name: "Lucas Araujo", channel: "whatsapp", msg: "Perfeito, pode mandar o orçamento?" },
      { name: "Julia Lima", channel: "instagram", msg: "Vi o story, ainda tem disponível?" },
    ],
  },
  {
    label: "Orçamento", dot: "bg-amber-400", pill: "text-amber-700 bg-amber-50", base: 2,
    cards: [
      { name: "Pedro Santos", channel: "facebook", msg: "Recebi a proposta, vou analisar." },
      { name: "Ana Costa", channel: "telegram", msg: "Qual o prazo de entrega?" },
    ],
  },
  {
    label: "Pedido", dot: "bg-violet-500", pill: "text-violet-700 bg-violet-50", base: 2,
    cards: [
      { name: "Maria Silva", channel: "whatsapp", msg: "Fechado! Acabei de fazer o pix 🙌" },
      { name: "Camila Souza", channel: "instagram", msg: "Amei, muito obrigada!" },
    ],
  },
]

// Card que viaja pelas etapas
const traveler: Conv = { name: "Bruno Dias", channel: "whatsapp", msg: "Boa tarde! Quais são os planos?" }
---

<section id="crm-pipeline" class="relative bg-[var(--color-paper)] pt-24 lg:pt-32 pb-0">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-12">
      <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.12em] text-emerald-700 bg-emerald-50 border border-emerald-100 rounded-full px-3 py-1 mb-5">
        CRM Pipeline
      </span>
      <h2 class="text-4xl sm:text-5xl font-bold text-slate-900 tracking-tight leading-[1.05]">
        Acompanhe seus leads<br />em tempo real.
      </h2>
      <p class="text-base lg:text-lg text-slate-600 mt-5 leading-relaxed">
        Cada card é uma conversa real — Instagram, Facebook, WhatsApp ou Telegram.
        Veja o lead entrar, ser trabalhado pela equipe e avançar até a conclusão.
      </p>
      <a href="/recursos/crm-whatsapp" class="inline-flex items-center gap-1.5 mt-5 text-sm font-semibold text-primary-600 hover:text-primary-700 group">
        Conheça o CRM para WhatsApp
        <span class="transition-transform group-hover:translate-x-0.5">→</span>
      </a>
    </div>

    <!-- Board (mergulha na seção azul via margem negativa) -->
    <div class="relative z-10 -mb-28 lg:-mb-40">
      <div class="bg-white rounded-3xl border border-slate-200 shadow-[0_30px_70px_-25px_rgba(2,6,23,0.45)] p-3 sm:p-5 lg:p-6">
        <div class="crm-board relative grid grid-cols-4 gap-2 sm:gap-3 lg:gap-4">

          {board.map((col, ci) => (
            <div data-col={ci} class="rounded-2xl bg-slate-50/70 border border-slate-100 p-2 sm:p-2.5 lg:p-3 min-h-[280px] sm:min-h-[340px] lg:min-h-[380px]">
              <div class="flex items-center justify-between mb-2.5 px-0.5">
                <span class={`inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-[8px] sm:text-[10px] font-bold uppercase tracking-wide ${col.pill}`}>
                  <span class={`size-1.5 rounded-full ${col.dot}`}></span>
                  <span class="hidden sm:inline">{col.label}</span>
                  <span class="sm:hidden">{col.label.split(" ")[0]}</span>
                </span>
                <span class="crm-count text-[10px] sm:text-xs font-semibold text-slate-400 tabular-nums" data-base={col.base}>{col.base}</span>
              </div>

              <!-- container fixo (referência de posição) + inner que desce no reflow -->
              <div class="col-cards relative">
                <div class="col-cards-inner space-y-2">
                  {col.cards.map((c) => (
                    <div class="conv">
                      <div class="conv-top">
                        <span class="conv-ch" style={`color:${channels[c.channel].color}`} set:html={channels[c.channel].svg} />
                        <span class="conv-name">{c.name}</span>
                      </div>
                      <p class="conv-msg">{c.msg}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))}

          <!-- Card VIAJANTE (overlay absoluto, movido por JS) -->
          <div class="crm-drag absolute z-30 pointer-events-none" aria-hidden="true">
            <div class="crm-drag-inner">
              <div class="conv conv--drag">
                <div class="conv-top">
                  <span class="conv-ch" style={`color:${channels[traveler.channel].color}`} set:html={channels[traveler.channel].svg} />
                  <span class="conv-name">{traveler.name}</span>
                </div>
                <p class="conv-msg">{traveler.msg}</p>
              </div>
              <!-- cursor "agarrando" -->
              <svg class="crm-cursor" viewBox="0 0 24 24" fill="none">
                <path d="M7 11V7a2 2 0 0 1 4 0v4M11 11V5a2 2 0 0 1 4 0v6M15 11V7a2 2 0 0 1 4 0v8a6 6 0 0 1-6 6h-1a6 6 0 0 1-6-6v-2a2 2 0 0 1 4 0" fill="white" stroke="#0f172a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Card de conversa */
  .conv {
    background: #fff; border: 1px solid #e2e8f0; border-radius: 0.75rem;
    box-shadow: 0 1px 2px rgb(2 6 23 / 0.04);
    padding: 0.5rem 0.6rem;
  }
  .conv-top { display: flex; align-items: center; gap: 0.4rem; }
  .conv-ch { display: inline-flex; flex-shrink: 0; }
  .conv-ch :global(svg) { width: 0.85rem; height: 0.85rem; }
  .conv-name { font-size: 0.72rem; font-weight: 700; color: #1e293b; line-height: 1.1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .conv-msg {
    font-size: 0.66rem; color: #64748b; margin-top: 0.2rem; line-height: 1.25;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  @media (min-width: 640px) {
    .conv { padding: 0.6rem 0.7rem; border-radius: 0.85rem; }
    .conv-ch :global(svg) { width: 1rem; height: 1rem; }
    .conv-name { font-size: 0.8rem; }
    .conv-msg { font-size: 0.72rem; }
  }

  /* Reflow suave dos cards quando abre espaço */
  .col-cards-inner { transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1); will-change: transform; }

  /* Card viajante */
  .crm-drag {
    top: 0; left: 0; opacity: 0;
    transition: transform 0.7s cubic-bezier(0.45, 0, 0.25, 1), opacity 0.35s ease;
    will-change: transform, opacity;
  }
  .crm-drag-inner {
    position: relative;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.3s ease;
    transform-origin: 60% 60%;
  }
  .conv--drag { border-color: var(--color-primary-500); border-width: 2px; }
  .crm-drag.is-lifting .crm-drag-inner {
    transform: rotate(-4deg) scale(1.05);
    filter: drop-shadow(0 16px 22px rgb(0 74 221 / 0.30));
  }
  .crm-cursor {
    position: absolute; right: -6px; bottom: -8px; width: 1.25rem; height: 1.25rem;
    opacity: 0; transition: opacity 0.25s ease; filter: drop-shadow(0 2px 3px rgb(0 0 0 / 0.25));
  }
  .crm-drag.is-lifting .crm-cursor { opacity: 1; }

  @media (prefers-reduced-motion: reduce) {
    .crm-drag, .crm-drag-inner, .col-cards-inner { transition: none !important; }
  }
</style>

<script>
  const section = document.getElementById("crm-pipeline")
  if (section) {
    const boardEl = section.querySelector<HTMLElement>(".crm-board")!
    const drag = section.querySelector<HTMLElement>(".crm-drag")!
    const cols = Array.from(section.querySelectorAll<HTMLElement>("[data-col]"))
    const counts = Array.from(section.querySelectorAll<HTMLElement>(".crm-count"))
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches

    const innerOf = (i: number) => cols[i].querySelector<HTMLElement>(".col-cards-inner")!
    const cardsBox = (i: number) => cols[i].querySelector<HTMLElement>(".col-cards")!

    // Posição (relativa ao board) do topo da área de cards da coluna i
    function slot(i: number) {
      const b = boardEl.getBoundingClientRect()
      const c = cardsBox(i).getBoundingClientRect()
      return { x: c.left - b.left, y: c.top - b.top, w: c.width }
    }

    let delta = 70 // altura do espaço aberto (recalculado no 1º enter)

    function setWidth() { drag.style.width = slot(0).w + "px" }
    function moveTo(i: number) {
      const s = slot(i)
      drag.style.transform = `translate(${s.x}px, ${s.y}px)`
    }
    function openRoom(i: number) { innerOf(i).style.transform = `translateY(${delta}px)` }
    function closeRoom(i: number) { innerOf(i).style.transform = "translateY(0)" }
    function closeAll() { cols.forEach((_, i) => closeRoom(i)) }
    function lift(on: boolean) { drag.classList.toggle("is-lifting", on) }
    function updateCounts(current: number) {
      counts.forEach((el, i) => {
        const base = Number(el.dataset.base)
        el.textContent = String(base + (i === current ? 1 : 0))
      })
    }

    function enter() {
      setWidth()
      delta = drag.offsetHeight + 8
      const s = slot(0)
      drag.style.transition = "none"
      drag.style.transform = `translate(${s.x}px, ${s.y - 18}px)`
      drag.style.opacity = "0"
      void drag.offsetHeight // reflow
      drag.style.transition = ""
      drag.style.transform = `translate(${s.x}px, ${s.y}px)`
      drag.style.opacity = "1"
    }

    const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms))
    let started = false

    async function hop(from: number, to: number) {
      lift(true); await sleep(450)            // pega o card
      openRoom(to)                            // abre espaço na coluna destino
      if (from > 0) closeRoom(from)           // fecha espaço na origem
      moveTo(to); updateCounts(to)            // arrasta
      await sleep(720)
      lift(false); await sleep(950)           // solta e assenta
    }

    async function run() {
      while (true) {
        closeAll(); updateCounts(0)
        enter(); await sleep(1300)            // entra na 1ª etapa
        await hop(0, 1)                        // → Contato Realizado
        await hop(1, 2)                        // → Cadastrado
        await hop(2, 3)                        // → Concluído
        await sleep(1500)
        drag.style.opacity = "0"; await sleep(750)
      }
    }

    if (reduce) {
      // Estático: card parado na 1ª etapa
      setWidth(); const s = slot(0)
      drag.style.transition = "none"
      drag.style.transform = `translate(${s.x}px, ${s.y}px)`
      drag.style.opacity = "1"
      updateCounts(0)
    } else {
      // Começa só quando entra na viewport
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting && !started) { started = true; run(); io.disconnect() }
        }
      }, { threshold: 0.25 })
      io.observe(boardEl)
      // Recalcula largura do card viajante em resize
      window.addEventListener("resize", () => { if (started) setWidth() }, { passive: true })
    }
  }
</script>
