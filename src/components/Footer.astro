---
import { BRAND, waLink } from "@/lib/brand"

const currentYear = new Date().getFullYear()
---

<footer class="relative bg-slate-950 border-t border-slate-800 pt-16 pb-10">
  <div class="max-w-6xl mx-auto px-6">

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Coluna 1: marca -->
      <div class="col-span-2 lg:col-span-1">
        <img
          src={BRAND.logoWhite}
          alt={BRAND.name}
          width="100"
          height="28"
          class="h-7 w-auto opacity-90"
        />
        <p class="text-sm text-slate-400 mt-4 leading-relaxed max-w-xs">
          Centralize a operação do seu WhatsApp pra toda empresa, e venda mais.
        </p>
      </div>

      <!-- Coluna 2: navegação -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-4">Produto</p>
        <ul class="space-y-2.5">
          <li><a href="#produto"   class="text-sm text-slate-300 hover:text-white transition-colors">Como funciona</a></li>
          <li><a href="#para-quem" class="text-sm text-slate-300 hover:text-white transition-colors">Pra quem é</a></li>
          <li><a href="#faq"       class="text-sm text-slate-300 hover:text-white transition-colors">Dúvidas</a></li>
        </ul>
      </div>

      <!-- Coluna 3: legal -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-4">Legal</p>
        <ul class="space-y-2.5">
          <li><a href="/termos"      class="text-sm text-slate-300 hover:text-white transition-colors">Termos de uso</a></li>
          <li><a href="/privacidade" class="text-sm text-slate-300 hover:text-white transition-colors">Privacidade</a></li>
          <li><a href="/lgpd"        class="text-sm text-slate-300 hover:text-white transition-colors">LGPD</a></li>
        </ul>
      </div>

      <!-- Coluna 4: contato -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-4">Contato</p>
        <ul class="space-y-2.5">
          <li>
            <a href={waLink()} target="_blank" rel="noopener noreferrer" class="text-sm text-slate-300 hover:text-white transition-colors inline-flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12.05 21.785h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
              WhatsApp
            </a>
          </li>
          <li>
            <a href={BRAND.instagram} target="_blank" rel="noopener noreferrer" class="text-sm text-slate-300 hover:text-white transition-colors inline-flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              Instagram
            </a>
          </li>
          <li>
            <a href={BRAND.linkedin} target="_blank" rel="noopener noreferrer" class="text-sm text-slate-300 hover:text-white transition-colors inline-flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Linha de baixo: copyright + tagline -->
    <div class="pt-8 border-t border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-slate-500">
        © {currentYear} {BRAND.name}. Feito no Brasil 🇧🇷
      </p>
      <p class="text-xs text-slate-500">
        WhatsApp é marca registrada da Meta Platforms. Kora não é afiliada ao Meta.
      </p>
    </div>
  </div>
</footer>
