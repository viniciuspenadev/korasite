---

<section class="relative bg-primary-950 py-24 lg:py-32 overflow-hidden" id="features-old-identity">
  <!-- Decorativo: blobs azul + grid sutil (da identidade antiga) -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-32 -left-32 w-[36rem] h-[36rem] bg-primary-600 rounded-full blur-[120px] opacity-25"></div>
    <div class="absolute -bottom-40 -right-20 w-[32rem] h-[32rem] bg-primary-500 rounded-full blur-[120px] opacity-20"></div>
    <!-- grid lines -->
    <div
      class="absolute inset-0 opacity-[0.05]"
      style="background-image: linear-gradient(to right, white 1px, transparent 1px), linear-gradient(to bottom, white 1px, transparent 1px); background-size: 64px 64px;"
    ></div>
    <!-- top fade pra suavizar borda com seção anterior -->
    <div class="absolute top-0 inset-x-0 h-32 bg-gradient-to-b from-primary-950 to-transparent"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6">

    <!-- Header com Título Antigo -->
    <div data-reveal class="max-w-2xl mb-16 mx-auto text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary-300 mb-4">
        Por que Kora
      </p>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tight leading-[1.05]">
        Kora não é um Bot.<br />
        É a sua operação<br />
        <span class="text-primary-300">
          de WhatsApp inteira.
        </span>
      </h2>
      <p class="text-lg text-slate-300 mt-6 leading-relaxed">
        Cada decisão de produto da Kora resolve um problema real de quem vende e atende pelo WhatsApp todo dia.
      </p>
    </div>

    <!-- Expanding Container -->
    <div id="features-expand-container" class="relative overflow-hidden transition-[max-height] duration-700 ease-in-out" style="max-height: 480px;">
      
      <!-- Features Grid: 3 colunas para acomodar os 12 itens de forma bonita -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" data-reveal>
        {features.map((f) => (
          <article class="group relative bg-white/[0.04] backdrop-blur-sm border border-white/10 rounded-2xl p-7 hover:bg-white/[0.07] hover:border-primary-400/30 transition duration-300">
            
            <!-- Icon badge -->
            <div class="size-11 rounded-xl bg-primary-500/15 ring-1 ring-primary-400/30 text-primary-200 flex items-center justify-center mb-5 group-hover:bg-primary-500/25 group-hover:text-primary-100 transition-colors">
              <div class="size-5" set:html={f.icon} />
            </div>

            <!-- Title -->
            <h3 class="text-xl font-bold text-white tracking-tight leading-tight mb-3">
              {f.title}
            </h3>

            <!-- Body -->
            <p class="text-[15px] text-slate-300 leading-[1.6]">
              {f.body}
            </p>
            
          </article>
        ))}
      </div>

      <!-- Fade Overlay for unexpanded state -->
      <div id="features-fade-overlay" class="absolute bottom-0 inset-x-0 h-48 bg-gradient-to-t from-primary-950 via-primary-950/80 to-transparent pointer-events-none transition-opacity duration-500"></div>
    </div>

    <!-- Expand Button -->
    <div id="features-expand-btn-wrapper" class="mt-8 flex justify-center transition-opacity duration-500">
      <button id="btn-expand-features" class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-white/5 border border-white/10 text-slate-300 font-medium text-sm hover:bg-white/10 hover:text-white transition-colors">
        Muito mais
        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
      </button>
    </div>
  </div>

  <!-- Bottom fade pra suavizar borda com seção seguinte -->
  <div class="absolute bottom-0 inset-x-0 h-32 bg-gradient-to-t from-primary-950 to-transparent pointer-events-none"></div>
</section>

<style>
  /* Entrance animations (Stagger) */
  #features-old-identity [data-reveal] article {
    opacity: 0;
    transform: translateY(20px);
  }
  
  #features-old-identity [data-reveal].is-revealed article {
    animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  #features-old-identity article:nth-child(1) { animation-delay: 0.05s; }
  #features-old-identity article:nth-child(2) { animation-delay: 0.10s; }
  #features-old-identity article:nth-child(3) { animation-delay: 0.15s; }
  #features-old-identity article:nth-child(4) { animation-delay: 0.20s; }
  #features-old-identity article:nth-child(5) { animation-delay: 0.25s; }
  #features-old-identity article:nth-child(6) { animation-delay: 0.30s; }
  #features-old-identity article:nth-child(7) { animation-delay: 0.35s; }
  #features-old-identity article:nth-child(8) { animation-delay: 0.40s; }
  #features-old-identity article:nth-child(9) { animation-delay: 0.45s; }
  #features-old-identity article:nth-child(10) { animation-delay: 0.50s; }
  #features-old-identity article:nth-child(11) { animation-delay: 0.55s; }
  #features-old-identity article:nth-child(12) { animation-delay: 0.60s; }
</style>

<script>
  const section = document.getElementById('features-old-identity');
  if (section) {
    const reveals = section.querySelectorAll('[data-reveal]');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0, rootMargin: "0px 0px -40px 0px" });

    reveals.forEach(r => observer.observe(r));
  }

  // Expand functionality
  const btnExpand = document.getElementById('btn-expand-features');
  const container = document.getElementById('features-expand-container');
  const overlay = document.getElementById('features-fade-overlay');
  const btnWrapper = document.getElementById('features-expand-btn-wrapper');

  if (btnExpand && container && overlay && btnWrapper) {
    btnExpand.addEventListener('click', () => {
      // Set to scrollHeight to animate to full height
      container.style.maxHeight = `${container.scrollHeight}px`;
      overlay.style.opacity = '0';
      
      // Hide button wrapper
      btnWrapper.style.opacity = '0';
      setTimeout(() => {
        btnWrapper.style.display = 'none';
        // After transition, remove max-height so it responds to window resize properly
        container.style.maxHeight = 'none'; 
      }, 700);
    });
  }
</script>
