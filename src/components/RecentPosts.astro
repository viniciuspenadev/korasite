---
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const recentPosts = sortedPosts.slice(0, 3);
---

<section class="py-24 bg-white relative">
  <!-- Divisor visual (círculo) -->
  <div class="absolute -top-6 left-1/2 -translate-x-1/2 w-12 h-12 bg-slate-900 rounded-full border-4 border-white shadow-sm flex items-center justify-center z-10">
    <div class="w-4 h-4 bg-[var(--color-primary-600)] rounded-full"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 pt-8">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-bold text-slate-900 mb-4">Últimos artigos da Kora Blog</h2>
      <p class="text-slate-500 max-w-2xl mx-auto">Fique por dentro das novidades e dicas sobre automação no WhatsApp.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {recentPosts.map(post => (
        <a href={`/blog/${post.slug}`} class="group flex flex-col bg-white rounded-2xl overflow-hidden border border-slate-100 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_20px_40px_rgb(0,0,0,0.08)] hover:-translate-y-1 transition-all duration-300">
          <div class="aspect-video w-full overflow-hidden relative">
            {post.data.image ? (
              <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            ) : (
              <div class="w-full h-full bg-slate-100 flex items-center justify-center">
                <span class="text-slate-400">Kora Blog</span>
              </div>
            )}
            <div class="absolute top-4 left-4">
              <span class="px-3 py-1 bg-white/90 backdrop-blur text-[var(--color-primary-600)] text-xs font-bold rounded-full shadow-sm">
                {post.data.category}
              </span>
            </div>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <time class="text-xs font-semibold text-slate-400 mb-3">
              {post.data.date.toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}
            </time>
            <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-[var(--color-primary-600)] transition-colors line-clamp-2">
              {post.data.title}
            </h3>
            <p class="text-slate-500 text-sm line-clamp-3 mb-6">
              {post.data.description}
            </p>
            <div class="mt-auto text-sm font-semibold text-[var(--color-primary-600)] flex items-center gap-1 group-hover:gap-2 transition-all">
              Continuar lendo <span aria-hidden="true">&rarr;</span>
            </div>
          </div>
        </a>
      ))}
    </div>
    
    <div class="mt-16 text-center">
      <a href="/blog" class="inline-flex items-center justify-center px-8 py-4 bg-[var(--color-primary-600)] hover:bg-[var(--color-primary-700)] rounded-xl text-white font-bold transition-colors shadow-lg shadow-blue-500/20">
        Ver todos os artigos
      </a>
    </div>
  </div>
</section>
