---
/**
 * FlowAnimation — Animação do fluxo Kora
 * Chatbot premium à esquerda → Hub central com glow → Canais coloridos à direita
 */
---

<section class="relative bg-[#020617] py-24 lg:py-32 overflow-hidden" id="flow-animation">
  <!-- Background decoration: Premium glows -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <!-- Center glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-primary-600/10 rounded-full blur-[120px] mix-blend-screen"></div>
    <!-- Hub accent glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] bg-indigo-500/20 rounded-full blur-[80px]"></div>
    
    <!-- Grid overlay for tech feel -->
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNDAiIGhlaWdodD0iNDAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4wMykiLz48L3N2Zz4=')] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_50%,#000_20%,transparent_100%)]"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="text-center mb-20" data-reveal>
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-500/10 border border-primary-500/20 text-primary-400 text-xs font-semibold tracking-wide uppercase mb-6">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-primary-500"></span>
        </span>
        Omnichannel
      </div>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight leading-tight">
        Um único sistema,<br/>
        <span class="bg-gradient-to-r from-indigo-400 via-primary-400 to-sky-400 bg-clip-text text-transparent">infinitos canais</span>
      </h2>
      <p class="text-slate-400 mt-6 max-w-2xl mx-auto text-lg leading-relaxed">
        Não importa de onde seu cliente vem. O Kora centraliza o atendimento e distribui automaticamente para a equipe certa.
      </p>
    </div>

    <!-- Flow Container -->
    <div class="flow-container relative w-full max-w-5xl mx-auto" data-reveal>

      <!-- SVG Lines (desktop) drawn by JS -->
      <svg id="flow-svg" class="flow-lines absolute inset-0 w-full h-full pointer-events-none overflow-visible" style="z-index: 0;">
        <defs>
          <linearGradient id="lineGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#4f46e5" stop-opacity="0.1" />
            <stop offset="50%" stop-color="#6366f1" stop-opacity="0.6" />
            <stop offset="100%" stop-color="#818cf8" stop-opacity="0.1" />
          </linearGradient>
          <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
            <feGaussianBlur stdDeviation="4" result="blur" />
            <feComposite in="SourceGraphic" in2="blur" operator="over" />
          </filter>
        </defs>
      </svg>

      <!-- The layout grid -->
      <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr_320px] gap-8 lg:gap-0 items-center relative z-10">

        <!-- LEFT/TOP: Channels (Origem) -->
        <div class="flow-sources grid grid-cols-4 lg:grid-cols-1 gap-2 lg:gap-4 mx-auto lg:mx-0 w-full relative z-10">
          
          <!-- WhatsApp Card -->
          <div class="flow-source relative group" style="--src-delay: 0.2s">
            <div class="absolute -inset-0.5 bg-gradient-to-r from-emerald-500 to-green-500 rounded-xl lg:rounded-2xl blur opacity-10 group-hover:opacity-30 transition duration-500"></div>
            <div class="relative flex flex-col lg:flex-row items-center gap-2 lg:gap-4 bg-slate-900 border border-slate-800 rounded-xl lg:rounded-2xl p-2 lg:p-4 transition-all duration-300 hover:-translate-y-1 lg:hover:translate-x-1 lg:hover:-translate-y-0 hover:border-emerald-500/50 text-center lg:text-left h-full justify-center lg:justify-start lg:pl-8">
              <div class="size-8 lg:size-10 bg-emerald-500/10 rounded-xl flex items-center justify-center border border-emerald-500/20 shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#10b981" class="scale-75 lg:scale-100"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              </div>
              <h4 class="text-slate-200 font-semibold text-[10px] lg:text-[15px] leading-tight break-words">WhatsApp</h4>
            </div>
            <!-- Target node for the line -->
            <div class="src-target absolute left-1/2 bottom-0 lg:left-auto lg:right-0 lg:top-1/2 w-1 h-1"></div>
          </div>

          <!-- Instagram Card -->
          <div class="flow-source relative group" style="--src-delay: 0.4s">
            <div class="absolute -inset-0.5 bg-gradient-to-r from-pink-500 to-rose-500 rounded-xl lg:rounded-2xl blur opacity-10 group-hover:opacity-30 transition duration-500"></div>
            <div class="relative flex flex-col lg:flex-row items-center gap-2 lg:gap-4 bg-slate-900 border border-slate-800 rounded-xl lg:rounded-2xl p-2 lg:p-4 transition-all duration-300 hover:-translate-y-1 lg:hover:translate-x-1 lg:hover:-translate-y-0 hover:border-pink-500/50 text-center lg:text-left h-full justify-center lg:justify-start lg:pl-8">
              <div class="size-8 lg:size-10 rounded-xl flex items-center justify-center border border-white/5 shrink-0" style="background: linear-gradient(45deg, rgba(240,148,51,0.15), rgba(230,104,60,0.15), rgba(220,39,67,0.15), rgba(204,35,102,0.15), rgba(188,24,136,0.15));">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="url(#igGrad2)" class="scale-75 lg:scale-100"><defs><linearGradient id="igGrad2" x1="0%" y1="100%" x2="100%" y2="0%"><stop offset="0%" stop-color="#f09433"/><stop offset="25%" stop-color="#e6683c"/><stop offset="50%" stop-color="#dc2743"/><stop offset="75%" stop-color="#cc2366"/><stop offset="100%" stop-color="#bc1888"/></linearGradient></defs><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </div>
              <h4 class="text-slate-200 font-semibold text-[10px] lg:text-[15px] leading-tight break-words">Instagram</h4>
            </div>
            <div class="src-target absolute left-1/2 bottom-0 lg:left-auto lg:right-0 lg:top-1/2 w-1 h-1"></div>
          </div>

          <!-- Messenger Card -->
          <div class="flow-source relative group" style="--src-delay: 0.6s">
            <div class="absolute -inset-0.5 bg-gradient-to-r from-blue-500 to-indigo-500 rounded-xl lg:rounded-2xl blur opacity-10 group-hover:opacity-30 transition duration-500"></div>
            <div class="relative flex flex-col lg:flex-row items-center gap-2 lg:gap-4 bg-slate-900 border border-slate-800 rounded-xl lg:rounded-2xl p-2 lg:p-4 transition-all duration-300 hover:-translate-y-1 lg:hover:translate-x-1 lg:hover:-translate-y-0 hover:border-blue-500/50 text-center lg:text-left h-full justify-center lg:justify-start lg:pl-8">
              <div class="size-8 lg:size-10 bg-blue-500/10 rounded-xl flex items-center justify-center border border-blue-500/20 shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#3b82f6" class="scale-75 lg:scale-100"><path d="M12 2C6.36 2 2 6.13 2 11.7c0 2.91 1.2 5.42 3.17 7.21V22l2.93-1.63c.84.23 1.72.36 2.65.36h.25c5.64 0 10-4.13 10-9.7S17.64 2 12 2zm1.05 13.07l-2.54-2.72L5.8 15.07l4.76-5.07 2.6 2.72 4.65-2.72-4.76 5.07z"/></svg>
              </div>
              <h4 class="text-slate-200 font-semibold text-[10px] lg:text-[15px] leading-tight break-words">Messenger</h4>
            </div>
            <div class="src-target absolute left-1/2 bottom-0 lg:left-auto lg:right-0 lg:top-1/2 w-1 h-1"></div>
          </div>

          <!-- Chat Kora Card -->
          <div class="flow-source relative group" style="--src-delay: 0.8s">
            <div class="absolute -inset-0.5 bg-gradient-to-r from-teal-500 to-cyan-500 rounded-xl lg:rounded-2xl blur opacity-10 group-hover:opacity-30 transition duration-500"></div>
            <div class="relative flex flex-col lg:flex-row items-center gap-2 lg:gap-4 bg-slate-900 border border-slate-800 rounded-xl lg:rounded-2xl p-2 lg:p-4 transition-all duration-300 hover:-translate-y-1 lg:hover:translate-x-1 lg:hover:-translate-y-0 hover:border-teal-500/50 text-center lg:text-left h-full justify-center lg:justify-start lg:pl-8">
              <div class="size-8 lg:size-10 bg-teal-500/10 rounded-xl flex items-center justify-center border border-teal-500/20 shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#14b8a6" class="scale-75 lg:scale-100"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
              </div>
              <h4 class="text-slate-200 font-semibold text-[10px] lg:text-[15px] leading-tight break-words">Chat Site</h4>
            </div>
            <div class="src-target absolute left-1/2 bottom-0 lg:left-auto lg:right-0 lg:top-1/2 w-1 h-1"></div>
          </div>
        </div>

        <!-- CENTER/MIDDLE: The Core Hub -->
        <div class="flow-hub flex items-center justify-center lg:mx-auto relative w-full h-[120px] lg:h-auto z-20 my-6 lg:my-0">
          <div class="relative flex items-center justify-center">
            <!-- Core Block -->
            <div class="relative w-28 h-14 lg:w-40 lg:h-20 bg-slate-900 rounded-2xl border border-indigo-500/50 shadow-[0_0_40px_rgba(79,70,229,0.4)] flex items-center justify-center overflow-hidden z-20 group">
              <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/20 to-primary-500/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              
              <!-- Kora Logo inside Core -->
              <div class="relative z-10 px-4 flex items-center justify-center">
                <img src="/logo_kora_branco.png" alt="Kora Logo" class="h-5 lg:h-8 object-contain drop-shadow-[0_0_8px_rgba(255,255,255,0.2)]" />
              </div>
            </div>
            
            <!-- Connection points for JS lines (invisible, just for positioning) -->
            <div id="hub-center" class="absolute inset-0 m-auto size-2 pointer-events-none opacity-0"></div>
          </div>
        </div>

        <!-- RIGHT/BOTTOM: Departments -->
        <div class="flow-targets grid grid-cols-3 lg:grid-cols-1 gap-2 lg:gap-5 mx-auto lg:mx-0 w-full relative z-10">
          <!-- Department Vendas -->
          <div class="flow-target relative group" style="--tgt-delay: 1.1s">
            <div class="absolute -inset-0.5 bg-gradient-to-r from-indigo-500 to-primary-500 rounded-xl lg:rounded-2xl blur opacity-10 group-hover:opacity-30 transition duration-500"></div>
            <div class="relative flex flex-col lg:flex-row items-center justify-between bg-slate-900 border border-slate-800 rounded-xl lg:rounded-2xl p-2 lg:p-4 transition-all duration-300 hover:translate-y-1 lg:hover:-translate-x-1 lg:hover:translate-y-0 hover:border-indigo-500/50 h-full">
              <div class="flex flex-col items-center lg:items-start text-center lg:text-left">
                <h4 class="text-slate-200 font-semibold text-[10px] sm:text-xs lg:text-sm leading-tight">Comercial</h4>
                <p class="text-slate-500 text-[8px] sm:text-[10px] lg:text-xs mt-0.5 hidden sm:block lg:block">Vendas</p>
              </div>
              <div class="flex -space-x-1 lg:-space-x-2 mt-2 lg:mt-0 justify-center">
                <img src={`https://api.dicebear.com/7.x/notionists/svg?seed=Ana`} alt="Avatar" class="size-6 lg:size-8 rounded-full ring-2 ring-slate-900 bg-emerald-100" />
                <img src={`https://api.dicebear.com/7.x/notionists/svg?seed=Pedro`} alt="Avatar" class="size-6 lg:size-8 rounded-full ring-2 ring-slate-900 bg-sky-100" />
                <div class="size-6 lg:size-8 rounded-full ring-2 ring-slate-900 bg-slate-800 flex items-center justify-center text-[8px] lg:text-[10px] font-bold text-white">+3</div>
              </div>
            </div>
            <!-- Target node for the line -->
            <div class="tgt-target absolute left-1/2 top-0 lg:left-0 lg:top-1/2 w-1 h-1"></div>
          </div>

          <!-- Department Suporte -->
          <div class="flow-target relative group" style="--tgt-delay: 1.4s">
            <div class="absolute -inset-0.5 bg-gradient-to-r from-purple-500 to-fuchsia-500 rounded-xl lg:rounded-2xl blur opacity-10 group-hover:opacity-30 transition duration-500"></div>
            <div class="relative flex flex-col lg:flex-row items-center justify-between bg-slate-900 border border-slate-800 rounded-xl lg:rounded-2xl p-2 lg:p-4 transition-all duration-300 hover:translate-y-1 lg:hover:-translate-x-1 lg:hover:translate-y-0 hover:border-purple-500/50 h-full">
              <div class="flex flex-col items-center lg:items-start text-center lg:text-left">
                <h4 class="text-slate-200 font-semibold text-[10px] sm:text-xs lg:text-sm leading-tight">Suporte</h4>
                <p class="text-slate-500 text-[8px] sm:text-[10px] lg:text-xs mt-0.5 hidden sm:block lg:block">Atendimento</p>
              </div>
              <div class="flex -space-x-1 lg:-space-x-2 mt-2 lg:mt-0 justify-center">
                <img src={`https://api.dicebear.com/7.x/notionists/svg?seed=Julia`} alt="Avatar" class="size-6 lg:size-8 rounded-full ring-2 ring-slate-900 bg-purple-100" />
                <img src={`https://api.dicebear.com/7.x/notionists/svg?seed=Bia`} alt="Avatar" class="size-6 lg:size-8 rounded-full ring-2 ring-slate-900 bg-yellow-100" />
                <div class="size-6 lg:size-8 rounded-full ring-2 ring-slate-900 bg-slate-800 flex items-center justify-center text-[8px] lg:text-[10px] font-bold text-white">+1</div>
              </div>
            </div>
            <div class="tgt-target absolute left-1/2 top-0 lg:left-0 lg:top-1/2 w-1 h-1"></div>
          </div>

          <!-- Department Financeiro -->
          <div class="flow-target relative group" style="--tgt-delay: 1.7s">
            <div class="absolute -inset-0.5 bg-gradient-to-r from-amber-500 to-orange-500 rounded-xl lg:rounded-2xl blur opacity-10 group-hover:opacity-30 transition duration-500"></div>
            <div class="relative flex flex-col lg:flex-row items-center justify-between bg-slate-900 border border-slate-800 rounded-xl lg:rounded-2xl p-2 lg:p-4 transition-all duration-300 hover:translate-y-1 lg:hover:-translate-x-1 lg:hover:translate-y-0 hover:border-amber-500/50 h-full">
              <div class="flex flex-col items-center lg:items-start text-center lg:text-left">
                <h4 class="text-slate-200 font-semibold text-[10px] sm:text-xs lg:text-sm leading-tight">Financeiro</h4>
                <p class="text-slate-500 text-[8px] sm:text-[10px] lg:text-xs mt-0.5 hidden sm:block lg:block">Cobranças</p>
              </div>
              <div class="flex -space-x-1 lg:-space-x-2 mt-2 lg:mt-0 justify-center">
                <img src={`https://api.dicebear.com/7.x/notionists/svg?seed=Carlos`} alt="Avatar" class="size-6 lg:size-8 rounded-full ring-2 ring-slate-900 bg-orange-100" />
              </div>
            </div>
            <div class="tgt-target absolute left-1/2 top-0 lg:left-0 lg:top-1/2 w-1 h-1"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Source entrance */
  .flow-source {
    opacity: 0;
    transform: translateX(-20px);
  }
  @media (max-width: 1023px) {
    .flow-source { transform: translateY(-20px); }
  }

  .flow-animation-active .flow-source {
    animation: flowSlideSrc 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--src-delay, 0s);
  }

  @keyframes flowSlideSrc {
    from { opacity: 0; transform: var(--tw-translate-x) var(--tw-translate-y); }
    to { opacity: 1; transform: translate(0, 0); }
  }

  /* Target entrance */
  .flow-target {
    opacity: 0;
    transform: translateX(20px);
  }
  @media (max-width: 1023px) {
    .flow-target { transform: translateY(20px); }
  }

  .flow-animation-active .flow-target {
    animation: flowSlideTgt 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--tgt-delay, 0s);
  }

  @keyframes flowSlideTgt {
    from { opacity: 0; transform: var(--tw-translate-x) var(--tw-translate-y); }
    to { opacity: 1; transform: translate(0, 0); }
  }

  /* Hub entrance */
  .flow-hub {
    opacity: 0;
    transform: scale(0.6) rotate(-10deg);
  }

  .flow-animation-active .flow-hub {
    animation: flowHubIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s forwards;
  }

  @keyframes flowHubIn {
    from { opacity: 0; transform: scale(0.6) rotate(-10deg); }
    to { opacity: 1; transform: scale(1) rotate(0); }
  }

  /* Floating animation for hub icons */
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
  }

  /* SVG Line appearance */
  .flow-lines {
    opacity: 0;
    transition: opacity 1s ease-out;
  }

  .flow-animation-active .flow-lines {
    opacity: 1;
    transition-delay: 0.6s;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .flow-msg, .flow-channel, .flow-hub, .flow-chat, .flow-lines {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>

<style is:global>
  .path-bg {
    fill: none;
    stroke: rgba(99, 102, 241, 0.25); /* slightly brighter so it's visible as a track */
    stroke-width: 2px;
  }
  
  .data-packet {
    fill: #38bdf8; /* sky-400 */
    filter: url(#glow);
  }

  @media (prefers-reduced-motion: reduce) {
    .data-packet { display: none !important; }
  }
</style>

<script>
  // Intersection Observer + dynamic SVG Bezier line drawing
  const flowSection = document.getElementById('flow-animation');
  if (flowSection) {
    const container = flowSection.querySelector('.flow-container');
    const svg = document.getElementById('flow-svg');

    function drawLines() {
      if (!svg || !container) return;
      // Clear previous paths
      svg.innerHTML = `
        <defs>
          <linearGradient id="lineGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#4f46e5" stop-opacity="0.1" />
            <stop offset="50%" stop-color="#6366f1" stop-opacity="0.8" />
            <stop offset="100%" stop-color="#0ea5e9" stop-opacity="0.2" />
          </linearGradient>
          <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
            <feGaussianBlur stdDeviation="3" result="blur" />
            <feComposite in="SourceGraphic" in2="blur" operator="over" />
          </filter>
        </defs>
      `;

      const rect = container.getBoundingClientRect();
      const hubCenter = container.querySelector('#hub-center');
      const sources = container.querySelectorAll('.flow-source');
      const targets = container.querySelectorAll('.flow-target');

      if (!hubCenter || sources.length === 0 || targets.length === 0) return;

      const hubRect = hubCenter.getBoundingClientRect();

      // Hub exact center relative to container
      const hx = hubRect.left - rect.left + hubRect.width / 2;
      const hy = hubRect.top - rect.top + hubRect.height / 2;

      const ns = 'http://www.w3.org/2000/svg';
      
      // Helper to draw a glowing path with animated data packets
      const drawPath = (dStr, numPackets = 1) => {
        // Background solid faint line
        const bgPath = document.createElementNS(ns, 'path');
        bgPath.setAttribute('d', dStr);
        bgPath.setAttribute('class', 'path-bg');
        bgPath.setAttribute('fill', 'none');
        svg.appendChild(bgPath);
        
        for (let i = 0; i < numPackets; i++) {
          const circle = document.createElementNS(ns, 'circle');
          circle.setAttribute('class', 'data-packet');
          
          // Pulse animation for the ball radius
          const pulse = document.createElementNS(ns, 'animate');
          pulse.setAttribute('attributeName', 'r');
          pulse.setAttribute('values', '2.5;5;2.5');
          pulse.setAttribute('dur', (Math.random() * 0.5 + 1.0).toFixed(2) + 's');
          pulse.setAttribute('repeatCount', 'indefinite');
          circle.appendChild(pulse);
          
          // Motion animation along the path
          const animate = document.createElementNS(ns, 'animateMotion');
          const dur = (Math.random() * 1.5 + 2.5).toFixed(2); // 2.5s to 4s
          const delay = ((i / numPackets) * parseFloat(dur) + Math.random() * 0.5).toFixed(2);
          
          animate.setAttribute('dur', `${dur}s`);
          animate.setAttribute('begin', `-${delay}s`);
          animate.setAttribute('repeatCount', 'indefinite');
          animate.setAttribute('path', dStr);
          
          circle.appendChild(animate);
          svg.appendChild(circle);
        }
      };

      // Determine if we are on desktop layout
      const isDesktop = window.innerWidth >= 1024;

      // 1. Curves: Sources (Top/Left) → Hub
      sources.forEach(src => {
        const target = src.querySelector('.src-target');
        if (!target) return;
        const sRect = target.getBoundingClientRect();
        
        let d1 = '';
        if (isDesktop) {
          const sx = sRect.right - rect.left - 5;
          const sy = sRect.top - rect.top + sRect.height/2;
          const cpDist = Math.max(40, Math.abs(hx - sx) / 2);
          // Bezier control points to make a nice horizontal S-curve into the hub
          d1 = `M ${sx} ${sy} C ${sx + cpDist} ${sy}, ${hx - cpDist} ${hy}, ${hx} ${hy}`;
        } else {
          // Mobile: Vertical S-curve from bottom of source to top of hub
          const sx = sRect.left - rect.left + sRect.width/2;
          const sy = sRect.bottom - rect.top + 2;
          const cpDist = Math.max(20, Math.abs(hy - sy) / 2);
          d1 = `M ${sx} ${sy} C ${sx} ${sy + cpDist}, ${hx} ${hy - cpDist}, ${hx} ${hy}`;
        }
        
        drawPath(d1, 1); // 1 ball flowing into hub from each channel
      });

      // 2. Curves: Hub → Targets (Bottom/Right)
      targets.forEach(tgt => {
        const target = tgt.querySelector('.tgt-target');
        if (!target) return;
        const targetRect = target.getBoundingClientRect();
        
        let d2 = '';
        if (isDesktop) {
          const tx = targetRect.left - rect.left + 5;
          const ty = targetRect.top - rect.top + targetRect.height/2;
          const cpDist = Math.max(40, Math.abs(tx - hx) / 2);
          // Bezier control points for smooth horizontal spread
          d2 = `M ${hx} ${hy} C ${hx + cpDist} ${hy}, ${tx - cpDist} ${ty}, ${tx} ${ty}`;
        } else {
          // Mobile: Vertical S-curve from bottom of hub to top of target
          const tx = targetRect.left - rect.left + targetRect.width/2;
          const ty = targetRect.top - rect.top - 2;
          const cpDist = Math.max(20, Math.abs(ty - hy) / 2);
          d2 = `M ${hx} ${hy} C ${hx} ${hy + cpDist}, ${tx} ${ty - cpDist}, ${tx} ${ty}`;
        }

        drawPath(d2, 1); // 1 ball flowing to each department
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && container) {
            container.classList.add('flow-animation-active');
            // Wait for entry animations to finish before drawing exact lines
            setTimeout(drawLines, 800);
            // Only observe once
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 }
    );
    observer.observe(flowSection);

    // Redraw on resize
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        if (container.classList.contains('flow-animation-active')) {
          drawLines();
        }
      }, 100);
    });
  }
</script>
