---
/**
 * ValueBento.astro
 * Bento Box de Proposta de Valor
 */
---

<section class="relative bg-[#020617] py-24 lg:py-32 overflow-hidden" id="value-bento">
  <div class="max-w-7xl mx-auto px-6 relative z-10">

    <!-- Header -->
    <div class="text-center mb-20" data-reveal>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight leading-tight mb-6">
        Conexões inteligentes que organizam e <br class="hidden sm:block" />
        <span class="text-primary-400">impulsionam seu negócio</span>
      </h2>
      <p class="text-slate-400 max-w-2xl mx-auto text-lg leading-relaxed">
        Transforme cada ponto de contato em uma oportunidade, centralizando conversas e oportunidades em um só lugar.
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

      <!-- Card 1: Experiência do Cliente (Vertical) -->
      <div class="lg:col-span-6 lg:row-span-2 relative rounded-3xl overflow-hidden h-[500px] lg:h-full bg-slate-900 border border-white/5 group" data-reveal>
        <!-- Background Image -->
        <img src="/woman-smartphone.png" alt="Mulher usando celular para acessar o sistema Kora" loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
        <!-- Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-[#020617] via-[#020617]/60 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-primary-950/40 to-transparent"></div>

        <!-- Hover Glow Border -->
        <div class="absolute inset-0 rounded-3xl ring-1 ring-inset ring-white/10 group-hover:ring-primary-500/50 transition duration-500 z-20 pointer-events-none"></div>

        <!-- Floating WhatsApp Message -->
        <div class="absolute top-8 left-6 sm:left-8 bg-white rounded-tr-2xl rounded-br-2xl rounded-bl-2xl rounded-tl-sm p-3 shadow-2xl flex items-start gap-3 w-[280px] sm:w-[320px] z-10 transform transition-transform duration-500 group-hover:-translate-y-2 group-hover:shadow-primary-500/20 animate-float">
          <div class="size-10 rounded-full bg-slate-200 overflow-hidden shrink-0 border border-slate-100">
            <!-- Avatar estático placeholder -->
            <img src="https://i.pravatar.cc/100?img=12" class="w-full h-full object-cover" alt="Atendente" />
          </div>
          <div class="relative w-full">
            <p class="text-[11px] font-bold text-primary-700">Maurício <span class="text-slate-400 font-normal ml-1">Atendimento</span></p>
            <p class="text-[13px] text-slate-700 leading-snug mt-0.5 mb-2">Olá Patrícia, Tudo bem!<br/>Já resolvemos a troca do seu pedido!</p>
            <span class="text-[9px] text-slate-400 absolute bottom-[-4px] right-0 font-medium">13:42</span>
          </div>
        </div>

        <!-- Content Bottom -->
        <div class="absolute bottom-8 left-6 sm:left-8 right-6 sm:right-8 z-10">
          <div class="inline-flex border border-primary-400/30 rounded-full px-4 py-1.5 text-xs font-semibold text-white mb-5 bg-primary-500/10 backdrop-blur-md">
            Experiência do Cliente
          </div>
          <h3 class="text-3xl sm:text-4xl font-bold text-white mb-4 tracking-tight">Contato mais próximo do cliente</h3>
          <p class="text-slate-300 leading-relaxed text-sm sm:text-base max-w-md">
            Converse com seus clientes de forma contextual e eficiente, criando proximidade, confiança e melhores resultados comerciais.
          </p>
        </div>
      </div>

      <!-- Right Column Stack -->
      <div class="lg:col-span-6 flex flex-col gap-6">
        
        <!-- Card 2: Chatbot (Horizontal Top) -->
        <div class="flex-1 relative rounded-3xl bg-white/[0.03] backdrop-blur-sm border border-white/10 overflow-hidden p-8 group flex flex-col justify-end min-h-[320px] lg:min-h-0" data-reveal>
          <!-- Hover Glow -->
          <div class="absolute inset-0 rounded-3xl ring-1 ring-inset ring-white/5 group-hover:ring-primary-500/40 transition duration-500 pointer-events-none z-20"></div>
          
          <!-- Background Decoration: Abstract UI -->
          <div class="absolute top-0 right-0 left-0 h-48 pointer-events-none overflow-hidden opacity-80 z-0">
            <!-- UI Element 1: Graph -->
            <div class="absolute top-6 left-6 bg-slate-900/80 backdrop-blur-md border border-slate-700/50 rounded-xl p-4 w-40 transform transition-transform duration-700 group-hover:-translate-y-1">
              <div class="flex items-center gap-2 mb-3">
                <div class="size-5 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center">
                  <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
                </div>
                <div class="h-1.5 w-16 bg-slate-700 rounded-full"></div>
              </div>
              <div class="text-xs text-slate-400 mb-1">Total vendido</div>
              <div class="text-sm font-bold text-white flex items-center gap-2">
                R$ 28.448,00
                <span class="text-[9px] bg-emerald-500/20 text-emerald-400 px-1.5 py-0.5 rounded">+5%</span>
              </div>
            </div>

            <!-- UI Element 2: Chat lines -->
            <div class="absolute top-12 right-6 bg-slate-900/80 backdrop-blur-md border border-slate-700/50 rounded-xl p-4 w-56 transform transition-transform duration-700 delay-100 group-hover:-translate-y-1">
               <div class="flex items-center gap-3">
                  <div class="size-8 rounded-full bg-slate-700 shrink-0"></div>
                  <div class="flex flex-col gap-2 w-full">
                    <div class="h-2.5 w-24 bg-primary-500/50 rounded-full"></div>
                    <div class="h-2.5 w-full bg-slate-700 rounded-full"></div>
                    <div class="h-2.5 w-3/4 bg-slate-700 rounded-full"></div>
                  </div>
               </div>
            </div>

            <!-- Connecting lines -->
            <svg class="absolute top-16 left-48 w-40 h-10 stroke-slate-700 stroke-[1.5] fill-none stroke-dasharray-4" viewBox="0 0 160 40">
              <path d="M0,20 C40,20 60,0 80,0 S120,20 160,20" />
              <!-- glowing dot moving on path -->
              <circle r="3" fill="#5e85ff">
                <animateMotion dur="3s" repeatCount="indefinite" path="M0,20 C40,20 60,0 80,0 S120,20 160,20" />
              </circle>
            </svg>
          </div>

          <div class="relative z-10 mt-auto pt-48">
            <div class="inline-flex border border-primary-400/30 rounded-full px-4 py-1.5 text-xs font-semibold text-white mb-4 bg-primary-500/10 backdrop-blur-md">
              Chatbot
            </div>
            <h3 class="text-2xl sm:text-3xl font-bold text-white mb-3 tracking-tight">Transforme conversas em vendas</h3>
            <p class="text-slate-400 text-sm sm:text-base leading-relaxed">
              Conduza cada conversa com contexto, velocidade e follow-up automático, transformando interesse em decisões de compra e oportunidades de faturamento.
            </p>
          </div>
        </div>

        <!-- Card 3: Integrações (Horizontal Bottom) -->
        <div class="flex-1 relative rounded-3xl bg-white/[0.03] backdrop-blur-sm border border-white/10 overflow-hidden p-8 group flex flex-col justify-end min-h-[320px] lg:min-h-0" data-reveal>
          <!-- Hover Glow -->
          <div class="absolute inset-0 rounded-3xl ring-1 ring-inset ring-white/5 group-hover:ring-primary-500/40 transition duration-500 pointer-events-none z-20"></div>
          
          <!-- Background Decoration: Orbits -->
          <div class="absolute -top-10 -right-20 w-[400px] h-[400px] pointer-events-none z-0 opacity-60">
            <!-- Orbit 1 -->
            <div class="absolute inset-0 rounded-full border border-slate-700/50 orbit-spin-1">
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 size-8 bg-slate-800 border border-slate-600 rounded-full flex items-center justify-center text-purple-400 shadow-lg shadow-purple-500/20 orbit-counter-spin-1">
                <svg class="size-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </div>
            </div>
            <!-- Orbit 2 -->
            <div class="absolute inset-16 rounded-full border border-slate-700/50 orbit-spin-2">
              <div class="absolute top-1/2 -right-4 -translate-y-1/2 size-8 bg-slate-800 border border-slate-600 rounded-full flex items-center justify-center text-sky-400 shadow-lg shadow-sky-500/20 orbit-counter-spin-2">
                <svg class="size-4" viewBox="0 0 24 24" fill="currentColor"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
              </div>
            </div>
            <!-- Orbit 3 -->
            <div class="absolute inset-32 rounded-full border border-slate-700/50 orbit-spin-3">
              <div class="absolute bottom-2 left-6 size-8 bg-slate-800 border border-slate-600 rounded-full flex items-center justify-center text-emerald-400 shadow-lg shadow-emerald-500/20 orbit-counter-spin-3">
                <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21" /><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1Z" /><path d="M14 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1Z" /><path d="M9.5 13.5c.5 1 1.5 1 2.5 1s2-.5 2.5-1" /></svg>
              </div>
            </div>
            <!-- Center Core -->
            <div class="absolute inset-0 m-auto size-12 bg-gradient-to-br from-primary-500 to-primary-700 rounded-full shadow-[0_0_40px_rgba(0,74,221,0.5)] flex items-center justify-center text-white">
              <svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            </div>
          </div>

          <div class="relative z-10 mt-auto pt-40">
            <div class="inline-flex border border-primary-400/30 rounded-full px-4 py-1.5 text-xs font-semibold text-white mb-4 bg-primary-500/10 backdrop-blur-md">
              Integrações
            </div>
            <h3 class="text-2xl sm:text-3xl font-bold text-white mb-3 tracking-tight">Ecossistema Conectado</h3>
            <p class="text-slate-400 text-sm sm:text-base leading-relaxed">
              Unifique e organize todo o seu ecossistema tecnológico em uma única interface, conectando sistemas, dados e processos de forma ágil e segura.
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- CTA Area -->
    <div class="mt-16 text-center" data-reveal>
      <a href="#cta-final" class="inline-flex items-center justify-center rounded-xl bg-primary-600 px-8 py-4 text-sm font-bold text-white shadow-lg shadow-primary-900/30 ring-1 ring-inset ring-white/10 transition hover:bg-primary-500 hover:-translate-y-1">
        Falar com um especialista
      </a>
    </div>

  </div>
</section>

<style>
  /* Entrance animations */
  #value-bento [data-reveal] {
    opacity: 0;
    transform: translateY(30px);
  }
  
  #value-bento [data-reveal].is-revealed {
    animation: fadeUpBento 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeUpBento {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Float animation for WhatsApp card */
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }

  /* Stroke Dasharray for SVG path */
  .stroke-dasharray-4 {
    stroke-dasharray: 4 4;
  }

  /* Orbit Animations */
  .orbit-spin-1 { animation: spin 20s linear infinite; }
  .orbit-counter-spin-1 { animation: spin-reverse 20s linear infinite; }
  
  .orbit-spin-2 { animation: spin 25s linear infinite reverse; }
  .orbit-counter-spin-2 { animation: spin 25s linear infinite; } /* Reverse of reverse is normal spin */
  
  .orbit-spin-3 { animation: spin 15s linear infinite; }
  .orbit-counter-spin-3 { animation: spin-reverse 15s linear infinite; }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes spin-reverse {
    from { transform: rotate(360deg); }
    to { transform: rotate(0deg); }
  }
</style>

<script>
  const section = document.getElementById('value-bento');
  if (section) {
    const reveals = section.querySelectorAll('[data-reveal]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    
    reveals.forEach(r => observer.observe(r));
  }
</script>
