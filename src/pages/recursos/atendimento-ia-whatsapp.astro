---
import Layout from "@/layouts/Layout.astro"
import Nav from "@/components/Nav.astro"
import Footer from "@/components/Footer.astro"
import { BRAND, waLink } from "@/lib/brand"

const title = "Atendimento com IA no WhatsApp: nenhum lead sem resposta | Kora"
const description =
  "A IA da Kora é apoio, não protagonista: responde na hora pra nenhum lead ficar esquecido, qualifica e entrega pro seu time fechar. Você no controle da gestão."

const breadcrumbs = [
  { name: "Início", url: new URL("/", Astro.site).toString() },
  { name: "Recursos", url: new URL("/recursos/", Astro.site).toString() },
  { name: "Atendimento com IA no WhatsApp", url: new URL(Astro.url.pathname, Astro.site).toString() },
]
---

<Layout title={title} description={description} ogType="article" breadcrumbs={breadcrumbs}>
  <Nav />

  <header style="background:#0b0c1e" class="relative pt-40 pb-28 overflow-hidden text-center px-6">
    <div class="absolute inset-0 z-0 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[680px] h-[680px] bg-primary-600/15 rounded-full blur-[130px]"></div>
      <div class="absolute inset-0 opacity-[0.05]" style="background-image:linear-gradient(to right,#fff 1px,transparent 1px),linear-gradient(to bottom,#fff 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse 60% 50% at 50% 0%,#000 30%,transparent 100%)"></div>
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <span class="inline-flex items-center gap-2 mb-6 text-xs font-bold tracking-[0.18em] uppercase px-3.5 py-1.5 rounded-full text-primary-300 bg-primary-500/10 border border-primary-400/25">
        <span class="size-1.5 rounded-full bg-primary-400"></span>Recurso
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight text-white">
        Nenhum lead esquecido<br />por <span class="text-primary-400">falta de resposta.</span>
      </h1>
      <p class="text-lg text-slate-300/90 mt-7 leading-relaxed max-w-xl mx-auto">
        A IA da Kora não rouba a cena. Ela é o apoio que responde na hora quando o seu
        time não pode — e devolve o lead qualificado pra pessoa certa fechar.
      </p>
      <div class="mt-9 flex items-center justify-center gap-4 flex-wrap">
        <a href={waLink("Quero usar a IA da Kora como apoio do meu atendimento.")} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-500 text-white font-semibold px-6 py-3.5 rounded-xl text-sm transition-colors ring-1 ring-inset ring-white/15">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.21 3.07.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.07-.12-.27-.2-.57-.35M12.05 21.8h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.99 2.9a9.82 9.82 0 0 1 2.89 6.99c0 5.45-4.44 9.88-9.88 9.88"/></svg>
          Solicitar demonstração
        </a>
        <a href="/recursos/crm-whatsapp" class="text-slate-300 hover:text-white text-sm font-semibold transition-colors">Ver o CRM →</a>
      </div>
    </div>
  </header>

  <main style="background:#fff" class="pb-24">
    <article class="ia-prose max-w-3xl mx-auto px-6 pt-16">

      <p class="ia-lead">
        Tem coisa pior que pagar por um lead e perdê-lo porque ninguém respondeu a
        tempo? Madrugada, fim de semana, hora de pico — é nesses buracos que a venda
        escapa. O <strong>atendimento com IA no WhatsApp</strong> da Kora existe pra
        fechar esses buracos, sem tirar o seu time do controle.
      </p>

      <h2>A IA é apoio, não protagonista</h2>
      <p>
        A gente não acredita em robô fingindo ser gente. A IA da Kora tem um papel
        claro e modesto: <strong>segurar o cliente no primeiro contato</strong> pra ele
        nunca ficar no vácuo — e passar pro humano assim que faz sentido. Quem fecha a
        venda e cuida do relacionamento continua sendo o seu time.
      </p>

      <h2>Nenhum lead no esquecimento</h2>
      <p>
        No segundo em que a mensagem chega, a IA acolhe, tira as dúvidas iniciais e
        qualifica. O cliente nunca espera; e quando o seu time abre o WhatsApp, o lead
        já está morno, organizado e com contexto.
      </p>

      <!-- VISUAL A: conversa com handoff IA → humano -->
      <div class="ia-chat">
        <div class="ia-chat-head">
          <span class="ia-avatar" style="background:#0ea5e9">M</span>
          <div><p class="ia-chat-name">Móveis Bella · Loja</p><p class="ia-chat-on">online</p></div>
        </div>
        <div class="ia-chat-body">
          <p class="ia-time">domingo · 22:47</p>
          <div class="ia-row out"><div class="ia-bubble out">Boa noite! Vi o anúncio, ainda dá pra comprar? 🛋️</div></div>
          <div class="ia-row in"><div class="ia-bubble in">
            <p class="ia-tag ia-tag--ai">Assistente IA</p>
            Boa noite! Dá sim 😊 Temos pronta entrega. Posso já te passar os valores e separar pra você?
          </div></div>
          <div class="ia-row out"><div class="ia-bubble out">Pode! Quero 2 unidades</div></div>
          <div class="ia-row in"><div class="ia-bubble in">
            <p class="ia-tag ia-tag--ai">Assistente IA</p>
            Anotado: 2 unidades 📝 Deixo tudo pronto pro nosso time confirmar com você logo cedo.
          </div></div>
          <div class="ia-handoff"><span></span>08:12 · Marina assumiu a conversa<span></span></div>
          <div class="ia-row in"><div class="ia-bubble in">
            <p class="ia-tag ia-tag--human">Marina · vendedora</p>
            Bom dia! 👋 Vi que você quer 2 unidades. Fecho seu pedido agora e já te mando o pix?
          </div></div>
        </div>
      </div>

      <h2>Você define até onde a IA vai</h2>
      <p>
        Aqui não tem IA solta. <strong>Você está no comando</strong>: define o que ela
        pode responder, em que momento ela passa pro humano e com que tom ela fala (o da
        sua marca). É uma ferramenta de gestão, configurada do seu jeito — não uma caixa-preta.
      </p>

      <!-- VISUAL B: painel de controle (gestão) -->
      <div class="ia-panel">
        <div class="ia-winbar"><span></span><span></span><span></span><em>app.kora.com.br · IA de apoio</em></div>
        <div class="p-4 sm:p-5">
          <div class="ia-ctrl">
            <p class="ia-ctrl-h"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg> A IA responde sozinha</p>
            <div class="ia-tags">
              <span>Dúvidas iniciais</span><span>Preço e prazo</span><span>Horário e endereço</span><span>Disponibilidade</span>
            </div>
          </div>
          <div class="ia-ctrl">
            <p class="ia-ctrl-h ia-ctrl-h--amber"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2.5"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg> Passa pro humano quando</p>
            <div class="ia-tags ia-tags--amber">
              <span>Cliente quer fechar</span><span>Pede desconto</span><span>Reclamação</span><span>Sai do script</span>
            </div>
          </div>
          <div class="ia-ctrl-row">
            <div class="ia-toggle">
              <span class="ia-toggle-l">Tom de voz</span>
              <span class="ia-chip">Casual, próximo</span>
            </div>
            <div class="ia-toggle">
              <span class="ia-toggle-l">Ativa fora do horário</span>
              <span class="ia-switch"><span></span></span>
            </div>
          </div>
        </div>
      </div>

      <h2>O humano no centro</h2>
      <p>
        Quando a conversa esquenta, ela vai pro atendente certo <strong>com todo o
        histórico junto</strong> — sem "aguarde", sem repetir tudo. A IA preparou o
        terreno; a pessoa fecha. Pro cliente, é a sua empresa do começo ao fim — nunca
        a sensação de estar falando com um robô.
      </p>

      <h2>Gestão: enxergue o que a IA está segurando pra você</h2>
      <p>
        Mais do que responder rápido, você <strong>gere</strong>. Veja quantos leads a
        IA atendeu fora do horário, quantos viraram conversa qualificada e o tempo de
        primeira resposta despencar. A IA trabalha nos bastidores; a gestão da operação
        e do relacionamento com o cliente continua nas suas mãos.
      </p>

      <div class="ia-stats">
        <div class="ia-stat"><p class="ia-stat-v">34</p><p class="ia-stat-l">leads atendidos fora do horário <span>esta semana</span></p></div>
        <div class="ia-stat"><p class="ia-stat-v">71<span class="ia-stat-u">%</span></p><p class="ia-stat-l">qualificados pela IA <span>antes do humano</span></p></div>
        <div class="ia-stat"><p class="ia-stat-v">8<span class="ia-stat-u">s</span></p><p class="ia-stat-l">tempo de 1ª resposta <span class="ia-stat-down">↓ 96%</span></p></div>
      </div>

      <div class="mt-10 rounded-2xl bg-slate-50 border border-slate-200 p-6 sm:p-8 text-center">
        <p class="text-lg font-bold text-slate-900">Pare de perder lead por falta de resposta — sem terceirizar pra um robô.</p>
        <p class="text-sm text-slate-600 mt-1.5">Demonstração gratuita · sem compromisso.</p>
        <a href={waLink("Quero usar a IA da Kora como apoio do meu atendimento.")} target="_blank" rel="noopener noreferrer"
          class="mt-5 inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white font-semibold px-7 py-3.5 rounded-xl text-sm transition-colors shadow-sm">
          {BRAND.whatsappCta}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

    </article>
  </main>

  <Footer />
</Layout>

<style>
  .ia-prose { color:#334155; font-size:1.125rem; line-height:1.85; }
  .ia-prose .ia-lead { font-size:1.3rem; line-height:1.6; color:#1e293b; font-weight:500; margin-bottom:2rem; }
  .ia-prose h2 { font-family:var(--font-display); font-size:1.875rem; font-weight:700; letter-spacing:-0.02em; margin-top:3rem; margin-bottom:1.1rem; color:#0f172a; line-height:1.2; }
  .ia-prose p { margin-bottom:1.4rem; }
  .ia-prose strong { font-weight:700; color:#0f172a; }

  /* Chat com handoff */
  .ia-chat { margin:2.5rem 0; border:1px solid #e2e8f0; border-radius:1.1rem; overflow:hidden; box-shadow:0 20px 45px -22px rgba(2,6,23,.25); max-width:430px; }
  .ia-chat-head { display:flex; align-items:center; gap:.6rem; background:#075E54; color:#fff; padding:.7rem .9rem; }
  .ia-avatar { width:2rem; height:2rem; border-radius:9999px; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:.8rem; color:#fff; flex-shrink:0; }
  .ia-chat-name { font-size:.8rem; font-weight:600; line-height:1.1; }
  .ia-chat-on { font-size:.65rem; opacity:.8; }
  .ia-chat-body { background:#E5DDD5; padding:.9rem; display:flex; flex-direction:column; gap:.5rem; }
  .ia-time { text-align:center; font-size:.6rem; color:#64748b; background:#fff; align-self:center; padding:.15rem .6rem; border-radius:9999px; }
  .ia-row { display:flex; }
  .ia-row.in { justify-content:flex-start; } .ia-row.out { justify-content:flex-end; }
  .ia-bubble { max-width:85%; font-size:.82rem; line-height:1.4; color:#1e293b; border-radius:.9rem; padding:.5rem .7rem; box-shadow:0 1px 1px rgba(0,0,0,.08); }
  .ia-bubble.in { background:#fff; border-top-left-radius:.2rem; }
  .ia-bubble.out { background:#DCF8C6; border-top-right-radius:.2rem; }
  .ia-tag { font-size:.62rem; font-weight:700; margin-bottom:.2rem; text-transform:uppercase; letter-spacing:.03em; display:inline-flex; align-items:center; gap:.25rem; }
  .ia-tag--ai { color:var(--color-primary-700); }
  .ia-tag--human { color:#7c3aed; }
  .ia-handoff { display:flex; align-items:center; gap:.5rem; align-self:center; font-size:.6rem; font-weight:600; color:#475569; background:#fef3c7; border:1px solid #fde68a; border-radius:9999px; padding:.2rem .7rem; margin:.2rem 0; }
  .ia-handoff span { width:1rem; height:1px; background:#d6b86a; }

  /* Painel de controle (gestão) */
  .ia-panel { background:#fff; border:1px solid #e2e8f0; border-radius:1rem; overflow:hidden; box-shadow:0 20px 45px -22px rgba(2,6,23,.25); margin:2.5rem 0; }
  .ia-winbar { display:flex; align-items:center; gap:.375rem; background:#f8fafc; border-bottom:1px solid #e2e8f0; padding:.6rem .75rem; }
  .ia-winbar span { width:.6rem; height:.6rem; border-radius:9999px; }
  .ia-winbar span:nth-child(1){ background:#fb7185 } .ia-winbar span:nth-child(2){ background:#fbbf24 } .ia-winbar span:nth-child(3){ background:#34d399 }
  .ia-winbar em { font-style:normal; font-size:.625rem; color:#94a3b8; font-weight:500; margin-left:.5rem; }
  .ia-ctrl { border:1px solid #f1f5f9; border-radius:.7rem; padding:.7rem .8rem; margin-bottom:.6rem; background:#fbfdff; }
  .ia-ctrl-h { display:flex; align-items:center; gap:.35rem; font-size:.72rem; font-weight:700; color:#059669; margin-bottom:.5rem; }
  .ia-ctrl-h--amber { color:#d97706; }
  .ia-tags { display:flex; flex-wrap:wrap; gap:.3rem; }
  .ia-tags span { font-size:.66rem; font-weight:500; color:#0369a1; background:#f0f9ff; border:1px solid #bae6fd; border-radius:9999px; padding:.18rem .55rem; }
  .ia-tags--amber span { color:#b45309; background:#fffbeb; border-color:#fde68a; }
  .ia-ctrl-row { display:grid; grid-template-columns:1fr 1fr; gap:.6rem; }
  @media (max-width:520px){ .ia-ctrl-row{ grid-template-columns:1fr; } }
  .ia-toggle { display:flex; align-items:center; justify-content:space-between; gap:.5rem; border:1px solid #f1f5f9; border-radius:.7rem; padding:.6rem .8rem; background:#fbfdff; }
  .ia-toggle-l { font-size:.72rem; font-weight:600; color:#334155; }
  .ia-chip { font-size:.62rem; font-weight:700; color:var(--color-primary-700); background:var(--color-primary-50); border:1px solid var(--color-primary-200); border-radius:9999px; padding:.15rem .5rem; }
  .ia-switch { width:2rem; height:1.1rem; border-radius:9999px; background:var(--color-primary-600); position:relative; flex-shrink:0; }
  .ia-switch span { position:absolute; top:2px; right:2px; width:.75rem; height:.75rem; border-radius:9999px; background:#fff; }

  /* Stats de gestão */
  .ia-stats { display:grid; grid-template-columns:repeat(3,1fr); gap:.75rem; margin:1.5rem 0 2rem; }
  @media (max-width:560px){ .ia-stats{ grid-template-columns:1fr; } }
  .ia-stat { border:1px solid #e2e8f0; border-radius:.9rem; padding:1rem; background:#fff; }
  .ia-stat-v { font-family:var(--font-display); font-size:2rem; font-weight:700; color:#0f172a; line-height:1; font-variant-numeric:tabular-nums; }
  .ia-stat-u { font-size:1rem; color:#64748b; }
  .ia-stat-l { font-size:.72rem; color:#64748b; margin-top:.4rem; line-height:1.35; }
  .ia-stat-l span { display:block; color:#94a3b8; }
  .ia-stat-down { display:inline!important; color:#059669!important; font-weight:600; }
</style>
