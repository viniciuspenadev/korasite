---
import Layout from "@/layouts/Layout.astro"
import Nav from "@/components/Nav.astro"
import Footer from "@/components/Footer.astro"
import { BRAND, waLink } from "@/lib/brand"

const title = "CRM para WhatsApp: funil de vendas em Kanban | Kora"
const description =
  "CRM para WhatsApp da Kora: cada conversa vira um card no funil Kanban, que você arrasta do lead ao ganho com valor, etapa e histórico. Solicite uma demonstração."

const breadcrumbs = [
  { name: "Início", url: new URL("/", Astro.site).toString() },
  { name: "Recursos", url: new URL("/recursos/", Astro.site).toString() },
  { name: "CRM para WhatsApp", url: new URL(Astro.url.pathname, Astro.site).toString() },
]

const channels: Record<string, string> = {
  whatsapp: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.21 3.07.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.07-.12-.27-.2-.57-.35M12.05 21.8h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.99 2.9a9.82 9.82 0 0 1 2.89 6.99c0 5.45-4.44 9.88-9.88 9.88"/></svg>`,
  instagram: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85C2.38 3.92 3.9 2.38 7.15 2.23 8.42 2.17 8.8 2.16 12 2.16M12 0C8.74 0 8.33.01 7.05.07 2.7.27.27 2.69.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.2 4.36 2.62 6.78 6.98 6.98C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c4.35-.2 6.78-2.62 6.98-6.98.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.2-4.35-2.62-6.78-6.98-6.98C15.67.01 15.26 0 12 0m0 5.84A6.16 6.16 0 1 0 12 18.16 6.16 6.16 0 0 0 12 5.84m0 10.16A4 4 0 1 1 12 8a4 4 0 0 1 0 8m6.41-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88"/></svg>`,
  facebook: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.97h-1.52c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8V24C19.61 23.1 24 18.1 24 12.07"/></svg>`,
}

type Card = { name: string; ch: string; chColor: string; msg: string; value: string; who: string; whoC: string; unread?: number }
const board: { stage: string; head: string; dot: string; count: number; cards: Card[] }[] = [
  { stage: "Lead", head: "text-sky-700 bg-sky-50", dot: "bg-sky-500", count: 2, cards: [
    { name: "Lucas Araújo", ch: "whatsapp", chColor: "#25D366", msg: "Pode mandar o orçamento?", value: "R$ 1.290", who: "M", whoC: "bg-violet-500" },
    { name: "Bruna Dias", ch: "instagram", chColor: "#E1306C", msg: "Vi o story, ainda tem?", value: "R$ 540", who: "B", whoC: "bg-sky-500", unread: 2 },
  ]},
  { stage: "Qualificado", head: "text-amber-700 bg-amber-50", dot: "bg-amber-400", count: 2, cards: [
    { name: "Pedro Santos", ch: "facebook", chColor: "#1877F2", msg: "Recebi a proposta 👍", value: "R$ 3.100", who: "M", whoC: "bg-violet-500" },
    { name: "Ana Costa", ch: "whatsapp", chColor: "#25D366", msg: "Qual o prazo?", value: "R$ 880", who: "C", whoC: "bg-emerald-500" },
  ]},
  { stage: "Proposta", head: "text-violet-700 bg-violet-50", dot: "bg-violet-500", count: 1, cards: [
    { name: "Carla Lima", ch: "whatsapp", chColor: "#25D366", msg: "Fechou! Me passa o pix", value: "R$ 2.400", who: "M", whoC: "bg-violet-500" },
  ]},
  { stage: "Ganho", head: "text-emerald-700 bg-emerald-50", dot: "bg-emerald-500", count: 2, cards: [
    { name: "Maria Silva", ch: "whatsapp", chColor: "#25D366", msg: "Acabei de pagar 🙌", value: "R$ 1.780", who: "C", whoC: "bg-emerald-500" },
    { name: "João Pereira", ch: "facebook", chColor: "#1877F2", msg: "Obrigado!", value: "R$ 990", who: "M", whoC: "bg-violet-500" },
  ]},
]
---

<Layout title={title} description={description} ogType="article" breadcrumbs={breadcrumbs}>
  <Nav />

  <header style="background:#0b0c1e" class="relative pt-40 pb-28 overflow-hidden text-center px-6">
    <div class="absolute inset-0 z-0 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[680px] h-[680px] bg-primary-600/15 rounded-full blur-[130px]"></div>
      <div class="absolute inset-0 opacity-[0.05]" style="background-image:linear-gradient(to right,#fff 1px,transparent 1px),linear-gradient(to bottom,#fff 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse 60% 50% at 50% 0%,#000 30%,transparent 100%)"></div>
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <span class="inline-flex items-center gap-2 mb-6 text-xs font-bold tracking-[0.18em] uppercase px-3.5 py-1.5 rounded-full text-primary-300 bg-primary-500/10 border border-primary-400/25">
        <span class="size-1.5 rounded-full bg-primary-400"></span>Recurso
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight text-white">
        Seu funil de vendas<br />é o seu <span class="text-primary-400">WhatsApp.</span>
      </h1>
      <p class="text-lg text-slate-300/90 mt-7 leading-relaxed max-w-xl mx-auto">
        Cada conversa vira um card que você arrasta de "novo contato" até "ganho" —
        com valor, etapa e histórico sempre junto da conversa.
      </p>
      <div class="mt-9 flex items-center justify-center gap-4 flex-wrap">
        <a href={waLink("Quero o CRM Kanban da Kora no meu WhatsApp.")} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-500 text-white font-semibold px-6 py-3.5 rounded-xl text-sm transition-colors ring-1 ring-inset ring-white/15">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.21 3.07.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.07-.12-.27-.2-.57-.35M12.05 21.8h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.99 2.9a9.82 9.82 0 0 1 2.89 6.99c0 5.45-4.44 9.88-9.88 9.88"/></svg>
          Solicitar demonstração
        </a>
        <a href="/recursos/agendamento-whatsapp" class="text-slate-300 hover:text-white text-sm font-semibold transition-colors">Ver agendamento →</a>
      </div>
    </div>
  </header>

  <main style="background:#fff" class="pb-24">
    <article class="cr-prose max-w-3xl mx-auto px-6 pt-16">

      <p class="cr-lead">
        Planilha de um lado, WhatsApp do outro, e a venda escorrendo no meio. No
        Kora, o <strong>CRM e o WhatsApp são a mesma coisa</strong>: a conversa é o
        card, e ele anda pelo funil junto com o valor, a etapa e o histórico.
      </p>

      <h2>Um funil visual que você arrasta</h2>
      <p>
        Colunas por etapa, cartões que você <strong>arrasta e solta</strong>. Vem com
        um funil pronto (Triagem → Lead → Qualificado → Proposta → Ganho → Perdido)
        que você ajusta como quiser — e dá pra ter <strong>vários funis</strong>
        (Vendas, Suporte, Parcerias) e trocar com um clique.
      </p>

      <!-- VISUAL A: quadro kanban -->
      <div class="cr-panel cr-panel--wide">
        <div class="cr-winbar"><span></span><span></span><span></span><em>app.kora.com.br · Funil de Vendas</em>
          <span class="cr-live"><span class="cr-live-dot"></span>tempo real</span>
        </div>
        <div class="cr-board">
          <div class="cr-board-grid">
          {board.map((col) => (
            <div class="cr-col">
              <div class="cr-col-head">
                <span class={`cr-col-pill ${col.head}`}><span class={`size-1.5 rounded-full ${col.dot}`}></span>{col.stage}</span>
                <span class="cr-col-count">{col.count}</span>
              </div>
              <div class="cr-col-cards">
                {col.cards.map((c) => (
                  <div class="cr-card">
                    <div class="cr-card-top">
                      <span class={`cr-card-av ${c.whoC}`}>{c.name[0]}</span>
                      <span class="cr-card-name">{c.name}</span>
                      <span class="cr-card-ch" style={`color:${c.chColor}`} set:html={channels[c.ch]} />
                    </div>
                    <p class="cr-card-msg">{c.msg}</p>
                    <div class="cr-card-foot">
                      <span class="cr-card-val">{c.value}</span>
                      {c.unread ? <span class="cr-card-unread">{c.unread}</span> : <span class={`cr-card-who ${c.whoC}`}>{c.who}</span>}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
          </div>
        </div>
      </div>

      <h2>Cada card é uma conversa de verdade</h2>
      <p>
        O card não é uma fichinha vazia que alguém preenche depois — é a própria
        conversa do WhatsApp, com tudo o que importa pra fechar à vista:
      </p>

      <!-- VISUAL B: anatomia do card -->
      <div class="cr-anatomy">
        <div class="cr-card cr-card--big">
          <div class="cr-card-top">
            <span class="cr-card-av bg-violet-500" style="width:2rem;height:2rem;font-size:.8rem">C</span>
            <span class="cr-card-name" style="font-size:.9rem">Carla Lima</span>
            <span class="cr-card-ch" style="color:#25D366" set:html={channels.whatsapp} />
          </div>
          <p class="cr-card-msg" style="font-size:.8rem">Fechou! Me passa o pix 🙌</p>
          <div class="cr-card-foot">
            <span class="cr-card-val" style="font-size:.85rem">R$ 2.400</span>
            <span class="cr-card-due">fecha 14/06</span>
            <span class="cr-card-who bg-violet-500">M</span>
          </div>
        </div>
        <ul class="cr-fields">
          <li><b>Foto e nome</b> do contato</li>
          <li><b>Prévia</b> da última mensagem</li>
          <li><b>Valor estimado</b> do negócio</li>
          <li><b>Data prevista</b> de fechamento</li>
          <li><b>Atendente responsável</b></li>
          <li><b>Selo do canal</b> (QR / Oficial) e não-lidas</li>
        </ul>
      </div>

      <h2>Arraste pra ganhar — e fica tudo registrado</h2>
      <p>
        Mover o card pra outra etapa atualiza tudo sozinho. <strong>Ganhar ou perder
        é um clique</strong> (registrando quando e o motivo da perda), e cada
        movimento entra no <strong>histórico da conversa</strong>. De quebra, o
        estágio do contato é promovido automaticamente — e nunca rebaixado.
      </p>

      <!-- VISUAL C: histórico da conversa -->
      <div class="cr-panel">
        <div class="cr-winbar"><span></span><span></span><span></span><em>Carla Lima · histórico</em></div>
        <div class="p-4 cr-history">
          <div class="cr-ev"><span class="cr-ev-dot bg-sky-400"></span><div><p class="cr-ev-t">Conversa movida para <b>Qualificado</b></p><span class="cr-ev-time">ontem, 15:20</span></div></div>
          <div class="cr-ev"><span class="cr-ev-dot bg-violet-400"></span><div><p class="cr-ev-t">Conversa movida para <b>Proposta</b></p><span class="cr-ev-time">hoje, 09:42</span></div></div>
          <div class="cr-ev"><span class="cr-ev-dot bg-emerald-500"></span><div><p class="cr-ev-t">🏆 <b>Negócio ganho</b> · R$ 2.400</p><span class="cr-ev-time">hoje, 11:08 · por Marina</span></div></div>
        </div>
      </div>

      <h2>Etapas do seu jeito</h2>
      <p>
        Criar, renomear, reordenar e colorir etapas; definir a <strong>probabilidade
        de fechamento (%)</strong> de cada uma e marcar como Ganho, Perdido ou Triagem.
        Você escolhe até quais etapas aparecem no quadro.
      </p>

      <h2>A gestão vê o time inteiro — em tempo real</h2>
      <p>
        Dono, admin ou supervisor enxergam <strong>todas as conversas ativas
        agrupadas por atendente ou departamento</strong> — um raio-X de quem está com
        o quê. O atendente comum vê só o funil dele (mesma <strong>privacidade</strong>
        do inbox, sem vazar cliente entre a equipe). E o quadro <strong>atualiza
        sozinho</strong> quando algo muda.
      </p>

      <h2>Já vem mais por aí</h2>
      <p>No roadmap do CRM:</p>
      <ul class="cr-roadmap">
        <li>Métricas do funil: conversão por etapa, valor total, tempo médio por etapa</li>
        <li>Automação: o card anda sozinho por gatilho (cliente respondeu → Qualificado)</li>
        <li>Histórico dedicado de ganhos e perdidos, fora do quadro ativo</li>
        <li>Integração com a Agenda: marcar reunião direto do card</li>
        <li>Ficha de cliente: histórico consolidado de negócios por contato</li>
      </ul>

      <div class="mt-10 rounded-2xl bg-slate-50 border border-slate-200 p-6 sm:p-8 text-center">
        <p class="text-lg font-bold text-slate-900">Transforme cada conversa num negócio que anda.</p>
        <p class="text-sm text-slate-600 mt-1.5">Demonstração gratuita · sem compromisso.</p>
        <a href={waLink("Quero o CRM Kanban da Kora no meu WhatsApp.")} target="_blank" rel="noopener noreferrer"
          class="mt-5 inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white font-semibold px-7 py-3.5 rounded-xl text-sm transition-colors shadow-sm">
          {BRAND.whatsappCta}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

    </article>
  </main>

  <Footer />
</Layout>

<style>
  .cr-prose { color:#334155; font-size:1.125rem; line-height:1.85; }
  .cr-prose .cr-lead { font-size:1.3rem; line-height:1.6; color:#1e293b; font-weight:500; margin-bottom:2rem; }
  .cr-prose h2 { font-family:var(--font-display); font-size:1.875rem; font-weight:700; letter-spacing:-0.02em; margin-top:3rem; margin-bottom:1.1rem; color:#0f172a; line-height:1.2; }
  .cr-prose p { margin-bottom:1.4rem; }
  .cr-prose strong { font-weight:700; color:#0f172a; }
  .cr-roadmap { list-style:none; padding:0; margin-bottom:1.5rem; }
  .cr-roadmap li { position:relative; padding-left:1.75rem; margin-bottom:.7rem; font-size:.95rem; color:#475569; }
  .cr-roadmap li::before { content:""; position:absolute; left:0; top:.15rem; width:1.1rem; height:1.1rem; border-radius:9999px; background:var(--color-primary-50); border:1px solid var(--color-primary-200); }
  .cr-roadmap li::after { content:""; position:absolute; left:.4rem; top:.5rem; width:.3rem; height:.3rem; border-radius:9999px; background:var(--color-primary-500); }

  /* Painel (janela de app) */
  .cr-panel { background:#fff; border:1px solid #e2e8f0; border-radius:1rem; overflow:hidden; box-shadow:0 20px 45px -22px rgba(2,6,23,.25); margin:2.5rem 0; }
  .cr-winbar { display:flex; align-items:center; gap:.375rem; background:#f8fafc; border-bottom:1px solid #e2e8f0; padding:.6rem .75rem; }
  .cr-winbar span { width:.6rem; height:.6rem; border-radius:9999px; }
  .cr-winbar span:nth-child(1){ background:#fb7185 } .cr-winbar span:nth-child(2){ background:#fbbf24 } .cr-winbar span:nth-child(3){ background:#34d399 }
  .cr-winbar em { font-style:normal; font-size:.625rem; color:#94a3b8; font-weight:500; margin-left:.5rem; }
  .cr-live { margin-left:auto; display:inline-flex; align-items:center; gap:.3rem; font-size:.6rem; color:#059669; font-weight:600; }
  .cr-live-dot { width:.4rem!important; height:.4rem!important; border-radius:9999px; background:#10b981!important; }

  /* Board (rola na horizontal quando não cabe — ex.: mobile) */
  .cr-board { overflow-x:auto; padding:.7rem; background:#f8fafc; scrollbar-width:thin; }
  .cr-board-grid { display:grid; grid-template-columns:repeat(4, minmax(150px,1fr)); gap:.55rem; }
  .cr-col { background:#fff; border:1px solid #eef2f7; border-radius:.7rem; padding:.5rem; }
  .cr-col-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:.5rem; }
  .cr-col-pill { display:inline-flex; align-items:center; gap:.3rem; font-size:.6rem; font-weight:700; text-transform:uppercase; letter-spacing:.02em; border-radius:9999px; padding:.15rem .45rem; }
  .cr-col-count { font-size:.65rem; font-weight:600; color:#94a3b8; }
  .cr-col-cards { display:flex; flex-direction:column; gap:.4rem; }
  .cr-card { background:#fff; border:1px solid #e2e8f0; border-radius:.55rem; padding:.45rem .5rem; box-shadow:0 1px 2px rgba(2,6,23,.04); }
  .cr-card-top { display:flex; align-items:center; gap:.35rem; }
  .cr-card-av { width:1.15rem; height:1.15rem; border-radius:9999px; color:#fff; font-size:.55rem; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .cr-card-name { font-size:.66rem; font-weight:700; color:#1e293b; flex:1; min-width:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .cr-card-ch { display:inline-flex; flex-shrink:0; } .cr-card-ch :global(svg){ width:.7rem; height:.7rem; }
  .cr-card-msg { font-size:.6rem; color:#94a3b8; margin-top:.2rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .cr-card-foot { display:flex; align-items:center; gap:.35rem; margin-top:.35rem; }
  .cr-card-val { font-size:.66rem; font-weight:700; color:#059669; flex:1; }
  .cr-card-who { width:1.05rem; height:1.05rem; border-radius:9999px; color:#fff; font-size:.5rem; font-weight:700; display:flex; align-items:center; justify-content:center; }
  .cr-card-unread { background:#ef4444; color:#fff; font-size:.5rem; font-weight:700; border-radius:9999px; min-width:1rem; height:1rem; display:flex; align-items:center; justify-content:center; padding:0 .2rem; }
  .cr-card-due { font-size:.58rem; color:#64748b; }

  /* Anatomia do card */
  .cr-anatomy { display:grid; grid-template-columns:auto 1fr; gap:1.5rem; align-items:center; margin:2rem 0 2.5rem; }
  @media (max-width:560px){ .cr-anatomy{ grid-template-columns:1fr; gap:1rem; } }
  .cr-card--big { width:220px; box-shadow:0 18px 40px -18px rgba(2,6,23,.3); border-radius:.8rem; padding:.7rem .8rem; }
  .cr-fields { list-style:none; padding:0; margin:0; display:grid; grid-template-columns:1fr 1fr; gap:.55rem .9rem; }
  @media (max-width:560px){ .cr-fields{ grid-template-columns:1fr; } }
  .cr-fields li { position:relative; padding-left:1.4rem; font-size:.85rem; color:#475569; }
  .cr-fields li b { color:#0f172a; font-weight:700; }
  .cr-fields li::before { content:""; position:absolute; left:0; top:.35em; width:.9rem; height:.5rem; border-left:2px solid var(--color-primary-500); border-bottom:2px solid var(--color-primary-500); transform:rotate(-45deg); }

  /* Histórico */
  .cr-history { display:flex; flex-direction:column; gap:.9rem; }
  .cr-ev { display:flex; gap:.7rem; align-items:flex-start; }
