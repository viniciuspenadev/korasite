---
import Layout from "@/layouts/Layout.astro"
import Nav from "@/components/Nav.astro"
import Footer from "@/components/Footer.astro"
import CtaFinal from "@/components/CtaFinal.astro"

const title = "Recursos da Kora: atendimento, CRM e agenda no WhatsApp | Kora"
const description =
  "Conheça os recursos da Kora para atender e vender no WhatsApp: multiatendimento, CRM com funil de vendas, agendamento, atendente com IA, disparos e relatórios."

const breadcrumbs = [
  { name: "Início", url: new URL("/", Astro.site).toString() },
  { name: "Recursos", url: new URL(Astro.url.pathname, Astro.site).toString() },
]

const icons: Record<string, string> = {
  users:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  calendar:  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>`,
  kanban:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M15 3v18"/></svg>`,
  bot:       `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="7" width="16" height="13" rx="2"/><path d="M12 7V4M8 3h8"/><circle cx="9" cy="13" r="1" fill="currentColor"/><circle cx="15" cy="13" r="1" fill="currentColor"/></svg>`,
  chat:      `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  megaphone: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l15-6v14L3 13z"/><path d="M3 11v2a2 2 0 0 0 2 2h1l1 5h3l-1-5"/></svg>`,
  chart:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 15l3-4 3 2 4-6"/></svg>`,
}

const recursos = [
  { icon: "users",     title: "Multiatendimento no WhatsApp", desc: "Todo o time atendendo no mesmo número oficial, com distribuição automática e visão do gestor.", href: "/recursos/multiatendimento-whatsapp", live: true },
  { icon: "calendar",  title: "Agendamento pelo WhatsApp",    desc: "O cliente marca, confirma e remarca na conversa. Lembretes que derrubam as faltas.", href: "/recursos/agendamento-whatsapp", live: true },
  { icon: "kanban",    title: "CRM para WhatsApp",            desc: "Funil de vendas em Kanban: cada conversa é um card que você arrasta do lead ao ganho.", href: "/recursos/crm-whatsapp", live: true },
  { icon: "bot",       title: "Atendente com IA",             desc: "Apoio que responde na hora pra nenhum lead ficar esquecido — e passa pro humano na hora certa.", href: "/recursos/atendimento-ia-whatsapp", live: true },
  { icon: "chat",      title: "Chat interno",                 desc: "Notas e menções entre atendentes na mesma conversa — o cliente nunca vê os bastidores.", href: "/#produto", live: false },
  { icon: "megaphone", title: "Disparos",                     desc: "Campanhas em massa pelo número oficial, dentro das regras da Meta.", href: "/#produto", live: false },
  { icon: "chart",     title: "Relatórios",                   desc: "Métricas de atendimento e vendas em tempo real, por canal, campanha e atendente.", href: "/#produto", live: false },
]
---

<Layout title={title} description={description} breadcrumbs={breadcrumbs}>
  <Nav />

  <main class="bg-[var(--color-paper)]">
    <!-- Header -->
    <section class="relative pt-36 pb-12 lg:pt-44 lg:pb-16 overflow-hidden">
      <div class="absolute inset-x-0 top-0 h-[55%] bg-gradient-to-b from-primary-50/60 to-transparent -z-10"></div>
      <div class="max-w-6xl mx-auto px-6 text-center">
        <nav class="text-xs text-slate-500 mb-5" aria-label="Trilha">
          <a href="/" class="hover:text-slate-800">Início</a>
          <span class="mx-1.5">/</span>
          <span class="text-slate-700 font-medium">Recursos</span>
        </nav>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 tracking-tight leading-[1.05]">
          Tudo pra atender e vender<br class="hidden sm:block" /> no <span class="text-primary-600">WhatsApp.</span>
        </h1>
        <p class="text-lg text-slate-600 mt-6 max-w-2xl mx-auto leading-relaxed">
          Os recursos da Kora trabalham juntos no mesmo lugar — atendimento, automação,
          funil de vendas e agenda — pra você crescer sem virar bagunça.
        </p>
      </div>
    </section>

    <!-- Grid de recursos -->
    <section class="max-w-6xl mx-auto px-6 pb-24 lg:pb-32">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {recursos.map((r) => (
          <a href={r.href} class="group relative flex flex-col bg-white border border-slate-200 rounded-2xl p-6 hover:border-primary-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary-600/5 transition">
            <div class="flex items-center justify-between mb-4">
              <span class="size-11 rounded-xl bg-primary-50 text-primary-700 flex items-center justify-center group-hover:bg-primary-600 group-hover:text-white transition-colors [&_svg]:size-5" set:html={icons[r.icon]} />
              {r.live && <span class="text-[10px] font-bold uppercase tracking-wide text-emerald-700 bg-emerald-50 border border-emerald-100 rounded-full px-2 py-0.5">Novo</span>}
            </div>
            <h2 class="text-lg font-bold text-slate-900 tracking-tight">{r.title}</h2>
            <p class="text-sm text-slate-600 mt-2 leading-relaxed flex-1">{r.desc}</p>
            <span class="inline-flex items-center gap-1.5 mt-4 text-sm font-semibold text-primary-600 group-hover:gap-2.5 transition-all">
              {r.live ? "Ver recurso" : "Ver na plataforma"}
              <span aria-hidden="true">→</span>
            </span>
          </a>
        ))}
      </div>
    </section>
  </main>

  <CtaFinal />
  <Footer />
</Layout>
