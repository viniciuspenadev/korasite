---
import Layout from "@/layouts/Layout.astro"
import Nav from "@/components/Nav.astro"
import Footer from "@/components/Footer.astro"
import { BRAND, waLink } from "@/lib/brand"

const title = "Agendamento pelo WhatsApp: agenda online integrada | Kora"
const description =
  "Agendamento pelo WhatsApp: o cliente marca, confirma e remarca na conversa. Lembretes automáticos que reduzem faltas, nos canais QR e API oficial. Veja a demonstração."

const breadcrumbs = [
  { name: "Início", url: new URL("/", Astro.site).toString() },
  { name: "Recursos", url: new URL("/recursos/", Astro.site).toString() },
  { name: "Agendamento pelo WhatsApp", url: new URL(Astro.url.pathname, Astro.site).toString() },
]
---

<Layout title={title} description={description} ogType="article" breadcrumbs={breadcrumbs}>
  <Nav />

  <!-- HERO escuro -->
  <header style="background:#0b0c1e" class="relative pt-40 pb-28 overflow-hidden text-center px-6">
    <div class="absolute inset-0 z-0 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[680px] h-[680px] bg-primary-600/15 rounded-full blur-[130px]"></div>
      <div class="absolute inset-0 opacity-[0.05]" style="background-image:linear-gradient(to right,#fff 1px,transparent 1px),linear-gradient(to bottom,#fff 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse 60% 50% at 50% 0%,#000 30%,transparent 100%)"></div>
    </div>

    <div class="relative z-10 max-w-3xl mx-auto">
      <span class="inline-flex items-center gap-2 mb-6 text-xs font-bold tracking-[0.18em] uppercase px-3.5 py-1.5 rounded-full text-primary-300 bg-primary-500/10 border border-primary-400/25">
        <span class="size-1.5 rounded-full bg-primary-400"></span>
        Recurso
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight text-white">
        A agenda que mora<br />dentro do <span class="text-primary-400">WhatsApp.</span>
      </h1>
      <p class="text-lg text-slate-300/90 mt-7 leading-relaxed max-w-xl mx-auto">
        O cliente marca, confirma e remarca pela própria conversa. Você organiza
        equipe e horários — e os lembretes automáticos fazem as faltas despencarem.
      </p>
      <div class="mt-9 flex items-center justify-center gap-4 flex-wrap">
        <a href={waLink("Quero a Agenda Kora dentro do meu WhatsApp.")} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-500 text-white font-semibold px-6 py-3.5 rounded-xl text-sm transition-colors ring-1 ring-inset ring-white/15">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.21 3.07.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.07-.12-.27-.2-.57-.35M12.05 21.8h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.99 2.9a9.82 9.82 0 0 1 2.89 6.99c0 5.45-4.44 9.88-9.88 9.88"/></svg>
          Quero ativar a Agenda
        </a>
        <a href="/recursos/multiatendimento-whatsapp" class="text-slate-300 hover:text-white text-sm font-semibold transition-colors">Ver multiatendimento →</a>
      </div>
    </div>
  </header>

  <!-- CORPO branco -->
  <main style="background:#fff" class="pb-24">
    <article class="ag-prose max-w-3xl mx-auto px-6 pt-16">

      <p class="ag-lead">
        Agenda no caderno, no print, no "me confirma amanhã?". Cada remarcação vira
        novela e, no fim do mês, a conta das faltas pesa. A Agenda Kora resolve isso
        onde o cliente já está: <strong>na conversa do WhatsApp</strong>.
      </p>

      <h2>O cliente agenda na própria conversa</h2>
      <p>
        Nada de link externo ou app pra baixar. O cliente pede, a Kora oferece os
        <strong>horários que realmente existem</strong> em botões, ele toca e pronto —
        reserva feita, confirmação na hora.
      </p>

      <!-- VISUAL A: conversa de agendamento -->
      <div class="ag-chat">
        <div class="ag-chat-head">
          <span class="ag-avatar" style="background:#a855f7">V</span>
          <div><p class="ag-chat-name">Studio Vita · Estética</p><p class="ag-chat-on">online</p></div>
          <svg class="ml-auto text-emerald-300" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.21 3.07.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.07-.12-.27-.2-.57-.35"/></svg>
        </div>
        <div class="ag-chat-body">
          <div class="ag-row out"><div class="ag-bubble out">Oi! Queria agendar uma limpeza de pele 💆</div></div>
          <div class="ag-row in"><div class="ag-bubble in">
            <p class="ag-bot">🤖 Agenda Kora</p>
            Claro! Pra <b>sexta (14/06)</b> eu tenho:
            <div class="ag-btns">
              <span class="ag-btn">14:00</span>
              <span class="ag-btn ag-btn--pick">16:00</span>
              <span class="ag-btn">Sáb 10:00</span>
            </div>
          </div></div>
          <div class="ag-row out"><div class="ag-bubble out">Sex, 16:00 👍</div></div>
          <div class="ag-row in"><div class="ag-bubble in ag-confirm">
            <p class="ag-confirm-top"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="3"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg> Agendado</p>
            <p class="ag-confirm-line"><b>Limpeza de pele</b><br/>Sexta, 14/06 · 16:00 · com Marina</p>
          </div></div>
        </div>
      </div>

      <h2>Confirma e remarca sozinho — e a falta cai</h2>
      <p>
        Antes do horário, o cliente recebe um lembrete e <strong>confirma ou remarca
        com um toque</strong>. O status muda sozinho, sem atendente, sem IA. Se ele
        remarcar, a Kora lista os horários reais pra ele escolher. Quem só quer
        cancelar cai pra um humano (retenção).
      </p>

      <!-- VISUAL B: lembrete confirma/remarca -->
      <div class="ag-chat">
        <div class="ag-chat-head">
          <span class="ag-avatar" style="background:#a855f7">V</span>
          <div><p class="ag-chat-name">Studio Vita · Estética</p><p class="ag-chat-on">online</p></div>
        </div>
        <div class="ag-chat-body">
          <div class="ag-row in"><div class="ag-bubble in">
            <p class="ag-bot">🗓️ Lembrete</p>
            Oi Marina! Sua <b>limpeza de pele</b> é amanhã (sex) às <b>16:00</b>. Posso confirmar?
            <div class="ag-btns ag-btns--stack">
              <span class="ag-btn ag-btn--pick">✓ Confirmar</span>
              <span class="ag-btn">↻ Remarcar</span>
            </div>
          </div></div>
          <div class="ag-row out"><div class="ag-bubble out">Confirmar</div></div>
          <div class="ag-row in"><div class="ag-bubble in ag-status">
            <span class="ag-pill">Status: Confirmado ✓</span>
            <p class="ag-status-sub">Tudo certo! Te esperamos amanhã às 16:00 🌸</p>
          </div></div>
        </div>
      </div>

      <h2>Horários que existem de verdade</h2>
      <p>
        Por trás dos botões tem um motor que calcula a disponibilidade real:
        horário de trabalho, capacidade da agenda, reservas já feitas, bloqueios
        (feriados, intervalos), folga entre atendimentos, antecedência mínima e fuso.
        <strong>A Kora nunca oferece um horário que não dá</strong> — e é a mesma fonte
        usada pra agendar e pra remarcar.
      </p>

      <h2>Uma agenda pra cada pessoa — e pra equipe</h2>
      <p>
        Cada atendente tem a sua agenda; salas e equipamentos têm agendas
        compartilhadas. Você define serviços (com duração e folga), capacidade
        individual ou coletiva (turma/sala), e o que cada um enxerga.
      </p>

      <!-- VISUAL C: agenda do dia -->
      <div class="ag-panel">
        <div class="ag-winbar"><span></span><span></span><span></span><em>app.kora.com.br · Agenda</em></div>
        <div class="p-4">
          <div class="flex items-center justify-between mb-3">
            <div>
              <p class="text-sm font-bold text-slate-900">Sexta, 14 de junho</p>
              <p class="text-[11px] text-slate-400">Marina · Estética</p>
            </div>
            <div class="flex gap-1">
              <span class="ag-chip ag-chip--on">Dia</span>
              <span class="ag-chip">Semana</span>
              <span class="ag-chip">Lista</span>
            </div>
          </div>
          <div class="space-y-1">
            <div class="ag-slot"><span class="ag-time">09:00</span><span class="ag-free">livre</span></div>
            <div class="ag-slot"><span class="ag-time">10:00</span><div class="ag-event ag-event--sky"><b>Ana Costa</b> · Limpeza de pele</div></div>
            <div class="ag-slot"><span class="ag-time">11:00</span><span class="ag-free">livre</span></div>
            <div class="ag-slot"><span class="ag-time">14:00</span><div class="ag-event ag-event--amber"><b>João P.</b> · Avaliação</div></div>
            <div class="ag-slot"><span class="ag-time">16:00</span><div class="ag-event ag-event--primary"><b>Marina S.</b> · Limpeza de pele <span class="ag-event-tag">novo</span></div></div>
            <div class="ag-slot"><span class="ag-time">18:00</span><div class="ag-event ag-event--blocked">Bloqueado · fechamento</div></div>
          </div>
          <div class="mt-3 pt-3 border-t border-slate-100 flex items-center justify-between text-[11px]">
            <span class="text-slate-500"><strong class="text-slate-800">3</strong> agendamentos hoje</span>
            <span class="text-slate-500">Ocupação <strong class="text-emerald-700">62%</strong></span>
          </div>
        </div>
      </div>

      <h2>Funciona nos dois canais</h2>
      <p>
        Todo o fluxo roda tanto no WhatsApp via QR quanto no número oficial — e no
        oficial a gente respeita as regras da Meta à risca (já validado em produção):
      </p>
      <div class="ag-channels">
        <div class="ag-channel">
          <span class="ag-channel-ic" style="color:#25D366"><svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.21 3.07.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.07-.12-.27-.2-.57-.35M12.05 21.8h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.99 2.9a9.82 9.82 0 0 1 2.89 6.99c0 5.45-4.44 9.88-9.88 9.88"/></svg></span>
          <p class="ag-channel-t">WhatsApp via QR</p>
          <p class="ag-channel-s">Rápido de ativar, sem burocracia.</p>
        </div>
        <div class="ag-channel">
          <span class="ag-channel-ic" style="color:#1877F2"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <p class="ag-channel-t">Cloud API oficial (Meta)</p>
          <p class="ag-channel-s">Janela de 24h, templates aprovados e botões interativos nativos.</p>
        </div>
      </div>

      <h2>O negócio sabe na hora</h2>
      <p>
        Confirmou, remarcou ou cancelou? O dono da agenda (e os co-hosts) recebem
        <strong>aviso no sininho + push</strong> no celular, mesmo com o app fechado.
        E os modelos de mensagem (confirmação, lembrete) saem de uma biblioteca pronta,
        com variáveis como <code class="ag-code">{`{{nome}}`}</code>, <code class="ag-code">{`{{servico}}`}</code> e <code class="ag-code">{`{{hora}}`}</code> inseridas por botão — sem digitar código.
      </p>

      <h2>Já vem mais por aí</h2>
      <p>No roadmap da Agenda, já em desenvolvimento:</p>
      <ul class="ag-roadmap">
        <li>IA na Agenda: a própria IA oferece horários e agenda na conversa</li>
        <li>Falta automática (no-show) + resumo matinal por push</li>
        <li>Lista de espera: vaga cancelada vira oferta pro próximo</li>
        <li>Link público de agendamento (estilo Calendly)</li>
        <li>Espelho com o Google Calendar</li>
        <li>Relatórios: taxa de falta, ocupação por agenda e serviço</li>
      </ul>

      <!-- CTA -->
      <div class="mt-10 rounded-2xl bg-slate-50 border border-slate-200 p-6 sm:p-8 text-center">
        <p class="text-lg font-bold text-slate-900">Pare de perder horário (e cliente) por falta de aviso.</p>
        <p class="text-sm text-slate-600 mt-1.5">Sem cartão. Resposta em minutos no horário comercial.</p>
        <a href={waLink("Quero a Agenda Kora dentro do meu WhatsApp.")} target="_blank" rel="noopener noreferrer"
          class="mt-5 inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white font-semibold px-7 py-3.5 rounded-xl text-sm transition-colors shadow-sm">
          {BRAND.whatsappCta}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

    </article>
  </main>

  <Footer />
</Layout>

<style>
  .ag-prose { color:#334155; font-size:1.125rem; line-height:1.85; }
  .ag-prose .ag-lead { font-size:1.3rem; line-height:1.6; color:#1e293b; font-weight:500; margin-bottom:2rem; }
  .ag-prose h2 { font-family:var(--font-display); font-size:1.875rem; font-weight:700; letter-spacing:-0.02em; margin-top:3rem; margin-bottom:1.1rem; color:#0f172a; line-height:1.2; }
  .ag-prose p { margin-bottom:1.4rem; }
  .ag-prose strong { font-weight:700; color:#0f172a; }
  .ag-code { background:#eef2ff; color:#003db8; font-size:.85em; padding:.05em .35em; border-radius:.3rem; font-family:ui-monospace,monospace; }
  .ag-roadmap { list-style:none; padding:0; margin-bottom:1.5rem; }
  .ag-roadmap li { position:relative; padding-left:1.75rem; margin-bottom:.7rem; font-size:.95rem; color:#475569; }
  .ag-roadmap li::before { content:""; position:absolute; left:0; top:.15rem; width:1.1rem; height:1.1rem; border-radius:9999px; background:var(--color-primary-50); border:1px solid var(--color-primary-200); }
  .ag-roadmap li::after { content:""; position:absolute; left:.4rem; top:.5rem; width:.3rem; height:.3rem; border-radius:9999px; background:var(--color-primary-500); }

  /* Chat mockup */
  .ag-chat { margin:2.5rem 0; border:1px solid #e2e8f0; border-radius:1.1rem; overflow:hidden; box-shadow:0 20px 45px -22px rgba(2,6,23,.25); max-width:420px; }
  .ag-chat-head { display:flex; align-items:center; gap:.6rem; background:#075E54; color:#fff; padding:.7rem .9rem; }
  .ag-avatar { width:2rem; height:2rem; border-radius:9999px; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:.8rem; color:#fff; flex-shrink:0; }
  .ag-chat-name { font-size:.8rem; font-weight:600; line-height:1.1; }
  .ag-chat-on { font-size:.65rem; opacity:.8; }
  .ag-chat-body { background:#E5DDD5; padding:.9rem; display:flex; flex-direction:column; gap:.5rem; }
  .ag-row { display:flex; }
  .ag-row.in { justify-content:flex-start; } .ag-row.out { justify-content:flex-end; }
  .ag-bubble { max-width:85%; font-size:.82rem; line-height:1.4; color:#1e293b; border-radius:.9rem; padding:.5rem .7rem; box-shadow:0 1px 1px rgba(0,0,0,.08); }
  .ag-bubble.in { background:#fff; border-top-left-radius:.2rem; }
  .ag-bubble.out { background:#DCF8C6; border-top-right-radius:.2rem; }
  .ag-bot { font-size:.65rem; font-weight:700; color:var(--color-primary-700); margin-bottom:.2rem; text-transform:uppercase; letter-spacing:.03em; }
  .ag-btns { display:flex; flex-wrap:wrap; gap:.35rem; margin-top:.55rem; }
  .ag-btns--stack { flex-direction:column; }
  .ag-btn { font-size:.74rem; font-weight:600; color:var(--color-primary-700); background:#fff; border:1px solid var(--color-primary-200); border-radius:.5rem; padding:.32rem .6rem; text-align:center; }
  .ag-btns--stack .ag-btn { width:100%; }
  .ag-btn--pick { background:var(--color-primary-600); color:#fff; border-color:var(--color-primary-600); }
  .ag-confirm { border-left:3px solid #10b981; }
  .ag-confirm-top { display:flex; align-items:center; gap:.3rem; font-size:.68rem; font-weight:700; color:#059669; text-transform:uppercase; letter-spacing:.04em; margin-bottom:.25rem; }
  .ag-confirm-line { font-size:.8rem; color:#1e293b; }
  .ag-status { }
  .ag-pill { display:inline-block; font-size:.72rem; font-weight:700; color:#065f46; background:#d1fae5; border:1px solid #6ee7b7; border-radius:9999px; padding:.2rem .6rem; }
  .ag-status-sub { font-size:.8rem; color:#1e293b; margin-top:.35rem; }

  /* Agenda do dia */
  .ag-panel { background:#fff; border:1px solid #e2e8f0; border-radius:1rem; overflow:hidden; box-shadow:0 20px 45px -22px rgba(2,6,23,.25); margin:2.5rem 0; }
  .ag-winbar { display:flex; align-items:center; gap:.375rem; background:#f8fafc; border-bottom:1px solid #e2e8f0; padding:.6rem .75rem; }
  .ag-winbar span { width:.6rem; height:.6rem; border-radius:9999px; }
  .ag-winbar span:nth-child(1){ background:#fb7185 } .ag-winbar span:nth-child(2){ background:#fbbf24 } .ag-winbar span:nth-child(3){ background:#34d399 }
  .ag-winbar em { font-style:normal; font-size:.625rem; color:#94a3b8; font-weight:500; margin-left:.5rem; }
  .ag-chip { font-size:.62rem; font-weight:600; color:#64748b; background:#f1f5f9; border-radius:.4rem; padding:.2rem .5rem; }
  .ag-chip--on { background:var(--color-primary-600); color:#fff; }
  .ag-slot { display:flex; align-items:center; gap:.6rem; }
  .ag-time { font-size:.68rem; font-weight:600; color:#94a3b8; width:2.6rem; flex-shrink:0; font-variant-numeric:tabular-nums; }
  .ag-free { flex:1; font-size:.66rem; color:#cbd5e1; border-bottom:1px dashed #e2e8f0; padding:.4rem 0; }
  .ag-event { flex:1; font-size:.7rem; color:#1e293b; border-radius:.45rem; padding:.4rem .55rem; border:1px solid; display:flex; align-items:center; gap:.4rem; }
  .ag-event b { font-weight:700; }
  .ag-event--sky { background:#f0f9ff; border-color:#bae6fd; }
  .ag-event--amber { background:#fffbeb; border-color:#fde68a; }
  .ag-event--primary { background:var(--color-primary-50); border-color:var(--color-primary-200); }
  .ag-event--blocked { background:#f8fafc; border-color:#e2e8f0; color:#94a3b8; font-style:italic; }
  .ag-event-tag { font-size:.55rem; font-weight:700; text-transform:uppercase; color:#fff; background:var(--color-primary-600); border-radius:.25rem; padding:.05rem .3rem; margin-left:auto; }

  /* Canais */
  .ag-channels { display:grid; grid-template-columns:1fr 1fr; gap:.75rem; margin:1.5rem 0 2rem; }
  @media (max-width:560px){ .ag-channels{ grid-template-columns:1fr; } }
  .ag-channel { border:1px solid #e2e8f0; border-radius:.9rem; padding:1rem; background:#fff; }
  .ag-channel-ic { display:inline-flex; align-items:center; justify-content:center; width:2.4rem; height:2.4rem; border-radius:.6rem; background:#f8fafc; border:1px solid #f1f5f9; margin-bottom:.6rem; }
  .ag-channel-t { font-size:.95rem; font-weight:700; color:#0f172a; }
  .ag-channel-s { font-size:.8rem; color:#64748b; margin-top:.2rem; line-height:1.4; }
</style>
