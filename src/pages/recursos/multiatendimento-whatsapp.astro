---
import Layout from "@/layouts/Layout.astro"
import Nav from "@/components/Nav.astro"
import Footer from "@/components/Footer.astro"
import { BRAND, waLink } from "@/lib/brand"

const title = "Multiatendimento no WhatsApp: vários atendentes, 1 número | Kora"
const description =
  "Multiatendimento no WhatsApp: todo o time no mesmo número oficial, com distribuição automática, transferência invisível e visão do gestor. Peça uma demonstração."

const breadcrumbs = [
  { name: "Início", url: new URL("/", Astro.site).toString() },
  { name: "Recursos", url: new URL("/recursos/", Astro.site).toString() },
  { name: "Multiatendimento no WhatsApp", url: new URL(Astro.url.pathname, Astro.site).toString() },
]
---

<Layout title={title} description={description} ogType="article" breadcrumbs={breadcrumbs}>
  <Nav />

  <!-- HERO escuro (estilo artigo) -->
  <header style="background:#0b0c1e" class="relative pt-40 pb-28 overflow-hidden text-center px-6">
    <!-- atmosfera: glow azul + grid -->
    <div class="absolute inset-0 z-0 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[680px] h-[680px] bg-primary-600/15 rounded-full blur-[130px]"></div>
      <div class="absolute inset-0 opacity-[0.05]" style="background-image:linear-gradient(to right,#fff 1px,transparent 1px),linear-gradient(to bottom,#fff 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse 60% 50% at 50% 0%,#000 30%,transparent 100%)"></div>
    </div>

    <div class="relative z-10 max-w-3xl mx-auto">
      <span class="inline-flex items-center gap-2 mb-6 text-xs font-bold tracking-[0.18em] uppercase px-3.5 py-1.5 rounded-full text-primary-300 bg-primary-500/10 border border-primary-400/25">
        <span class="size-1.5 rounded-full bg-primary-400"></span>
        Recurso
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight text-white">
        Seu time inteiro<br />no <span class="text-primary-400">mesmo número.</span>
      </h1>
      <p class="text-lg text-slate-300/90 mt-7 leading-relaxed max-w-xl mx-auto">
        Vários atendentes, um só WhatsApp oficial. Cada conversa organizada,
        distribuída pra pessoa certa — e nada de celular passando de mão em mão.
      </p>
      <div class="mt-9 flex items-center justify-center gap-4 flex-wrap">
        <a href={waLink("Quero ativar o Multiatendimento na Kora.")} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-500 text-white font-semibold px-6 py-3.5 rounded-xl text-sm transition-colors ring-1 ring-inset ring-white/15">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.21 3.07.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.07-.12-.27-.2-.57-.35M12.05 21.8h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.99 2.9a9.82 9.82 0 0 1 2.89 6.99c0 5.45-4.44 9.88-9.88 9.88"/></svg>
          Falar no WhatsApp
        </a>
        <a href="/#produto" class="text-slate-300 hover:text-white text-sm font-semibold transition-colors">Ver a plataforma →</a>
      </div>
    </div>
  </header>

  <!-- CORPO branco -->
  <main style="background:#fff" class="pb-24">
    <article class="ma-prose max-w-3xl mx-auto px-6 pt-16">

      <p class="ma-lead">
        Quantas vendas já esfriaram porque o celular da empresa estava "ocupado"
        com outro cliente? Um número, um aparelho, uma pessoa por vez. Esse é o
        gargalo silencioso que trava o atendimento de quem está crescendo.
      </p>

      <h2>O problema: um número, um celular, uma pessoa</h2>
      <p>
        No WhatsApp comum, todas as conversas caem num único aparelho. Quando o
        movimento aperta, vira fila: o cliente manda mensagem e espera, o atendente
        se perde entre dezenas de conversas abertas, e ninguém sabe quem já
        respondeu o quê. O lead quente vira lead frio — e some.
      </p>

      <!-- DIAGRAMA: gargalo (antes) -->
      <div class="ma-card">
        <div class="ma-card-glow" style="background:rgba(239,68,68,0.12)"></div>
        <div class="text-center mb-6 relative z-10">
          <h4 class="text-rose-400 font-bold uppercase tracking-[0.16em] text-xs mb-1">Cenário comum</h4>
          <p class="text-slate-400 text-xs">Um celular tentando dar conta de todo mundo.</p>
        </div>
        <div class="relative z-10 flex items-center justify-center gap-3 sm:gap-5">
          <!-- fila de mensagens -->
          <div class="flex flex-col gap-1.5 w-24 sm:w-28">
            <div class="ma-msg ma-msg-in">Oi, tem em estoque?</div>
            <div class="ma-msg ma-msg-in">Qual o valor?</div>
            <div class="ma-msg ma-msg-in">Alguém aí?</div>
            <div class="ma-msg ma-msg-in opacity-50">...</div>
          </div>
          <svg class="text-slate-600 shrink-0" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <!-- 1 celular sobrecarregado -->
          <div class="relative shrink-0">
            <div class="absolute -top-2 -right-2 z-20 bg-rose-500 text-white text-[10px] font-bold px-2 py-0.5 rounded-full animate-pulse">99+</div>
            <div class="w-16 h-28 sm:w-20 sm:h-32 rounded-[1.1rem] bg-slate-800 border-2 border-rose-500/60 shadow-[0_0_22px_rgba(239,68,68,0.25)] flex flex-col items-center justify-center gap-1.5">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="#22c55e"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.21 3.07.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.07-.12-.27-.2-.57-.35"/></svg>
              <span class="text-[9px] text-slate-400 font-medium">1 aparelho</span>
            </div>
          </div>
          <svg class="text-slate-600 shrink-0" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <!-- atendente travado -->
          <div class="flex flex-col items-center gap-1.5 w-20 sm:w-24 shrink-0">
            <div class="size-10 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-white font-bold text-sm">1</div>
            <div class="flex items-center gap-1 text-amber-400">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2" stroke-linecap="round"/></svg>
              <span class="text-[10px] font-bold">+15 min</span>
            </div>
            <span class="text-[9px] text-slate-500 text-center">sobrecarregado</span>
          </div>
        </div>
      </div>

      <h2>A solução: um número, o time inteiro</h2>
      <p>
        O <strong>Multiatendimento</strong> da Kora conecta toda a sua equipe ao
        mesmo número oficial. Cada atendente entra com login e senha próprios, vê só
        as conversas dele, e atende em paralelo — do computador ou do celular. O
        cliente continua falando com "a empresa"; por trás, o time inteiro trabalha junto.
      </p>

      <!-- DIAGRAMA: hub multiatendimento (depois) -->
      <div class="ma-card">
        <div class="ma-card-glow" style="background:rgba(0,74,221,0.22)"></div>
        <div class="text-center mb-7 relative z-10">
          <h4 class="text-primary-300 font-bold uppercase tracking-[0.16em] text-xs mb-1">Com a Kora</h4>
          <p class="text-slate-400 text-xs">Um número distribuído pro time todo, em tempo real.</p>
        </div>
        <div class="relative z-10 grid grid-cols-1 sm:grid-cols-[150px_1fr] gap-6 items-center">
          <!-- número único -->
          <div class="mx-auto sm:mx-0 flex flex-col items-center gap-2 bg-slate-900 border border-primary-500/50 rounded-2xl px-4 py-4 shadow-[0_0_26px_rgba(0,74,221,0.3)] w-[150px]">
            <span class="size-9 rounded-xl bg-emerald-500/15 flex items-center justify-center text-emerald-400">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.21 3.07.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.07-.12-.27-.2-.57-.35M12.05 21.8h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.99 2.9a9.82 9.82 0 0 1 2.89 6.99c0 5.45-4.44 9.88-9.88 9.88"/></svg>
            </span>
            <p class="text-xs font-bold text-white text-center leading-tight">1 número<br/>oficial Meta</p>
            <span class="text-[9px] text-primary-300 font-medium">+47 conversas ativas</span>
          </div>
          <!-- atendentes -->
          <div class="grid grid-cols-1 gap-2">
            {[
              { i: "M", c: "from-violet-400 to-purple-500", n: "Marina", t: "Vendas", a: "4 ativas", on: true },
              { i: "B", c: "from-sky-400 to-blue-500", n: "Bruno", t: "Vendas", a: "3 ativas", on: true },
              { i: "P", c: "from-emerald-400 to-teal-500", n: "Patrícia", t: "Suporte", a: "6 ativas", on: true },
            ].map((p) => (
              <div class="ma-attendant flex items-center gap-3 bg-slate-800/70 border border-slate-700 rounded-xl px-3 py-2">
                <div class="relative shrink-0">
                  <div class={`size-8 rounded-full bg-gradient-to-br ${p.c} flex items-center justify-center text-white text-xs font-bold`}>{p.i}</div>
                  <span class="absolute -bottom-0.5 -right-0.5 size-2.5 rounded-full bg-emerald-500 border-2 border-slate-800"></span>
                </div>
                <div class="min-w-0 flex-1">
                  <p class="text-xs font-bold text-white leading-tight">{p.n} <span class="text-slate-400 font-medium">· {p.t}</span></p>
                </div>
                <span class="text-[10px] font-semibold text-emerald-400 tabular-nums shrink-0">{p.a}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <h2>Cada conversa no atendente certo</h2>
      <p>
        Você decide como o lead é distribuído — e a Kora cuida do resto, sem
        ninguém pisar no atendimento do outro:
      </p>
      <ul>
        <li><strong>Automática:</strong> por departamento, fila ou disponibilidade. O próximo lead cai com quem está livre.</li>
        <li><strong>Manual:</strong> o gestor (ou a IA) puxa a conversa pro especialista certo.</li>
        <li><strong>Por etiqueta:</strong> "orçamento", "suporte", "VIP" — regras que direcionam sozinhas.</li>
      </ul>

      <h2>Transferência que o cliente não percebe</h2>
      <p>
        Precisou passar do vendedor pro financeiro? A conversa muda de mãos
        <strong>com todo o histórico junto</strong> — sem "vou te transferir, aguarde",
        sem repetir tudo de novo. Pro cliente, é a mesma conversa fluida do início ao fim.
      </p>

      <h2>O gestor enxerga tudo</h2>
      <p>
        Em vez de adivinhar o que acontece num celular trancado na gaveta, você
        acompanha a operação ao vivo: quem está online, quantas conversas cada um
        toca, tempo de resposta e o que ainda está sem atendimento.
      </p>

      <!-- DIAGRAMA: painel da equipe (claro) -->
      <div class="ma-panel">
        <div class="ma-winbar"><span></span><span></span><span></span><em>app.kora.com.br · Equipe</em></div>
        <div class="p-4">
          <div class="flex items-center justify-between mb-3">
            <p class="text-sm font-bold text-slate-900">Atendentes ativos</p>
            <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold text-emerald-700">
              <span class="size-1.5 rounded-full bg-emerald-500"></span> 4 online
            </span>
          </div>
          <div class="space-y-1.5">
            {[
              { i: "M", c: "from-violet-400 to-purple-500", n: "Marina Silva", t: "Vendas", tc: "bg-rose-50 text-rose-700", a: "4 ativas", s: "Em conversa", sc: "text-emerald-600" },
              { i: "B", c: "from-sky-400 to-blue-500", n: "Bruno Costa", t: "Vendas", tc: "bg-rose-50 text-rose-700", a: "3 ativas", s: "Online", sc: "text-emerald-600" },
              { i: "P", c: "from-emerald-400 to-teal-500", n: "Patrícia Lima", t: "Suporte", tc: "bg-sky-50 text-sky-700", a: "6 ativas", s: "Em conversa", sc: "text-amber-600" },
              { i: "C", c: "from-amber-400 to-orange-500", n: "Carlos Mendes", t: "Suporte", tc: "bg-sky-50 text-sky-700", a: "2 ativas", s: "Online", sc: "text-emerald-600" },
            ].map((p) => (
              <div class="flex items-center gap-3 px-2.5 py-2 rounded-lg hover:bg-slate-50 transition-colors">
                <div class="relative shrink-0">
                  <div class={`size-9 rounded-full bg-gradient-to-br ${p.c} flex items-center justify-center text-white text-xs font-bold`}>{p.i}</div>
                  <span class="absolute bottom-0 right-0 size-2.5 rounded-full bg-emerald-500 border-2 border-white"></span>
                </div>
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-semibold text-slate-900 leading-tight">{p.n}</p>
                  <span class={`inline-flex text-[9px] font-semibold mt-0.5 px-1.5 py-0.5 rounded ${p.tc}`}>{p.t}</span>
                </div>
                <div class="text-right shrink-0">
                  <p class="text-[11px] font-bold text-slate-900 tabular-nums">{p.a}</p>
                  <p class={`text-[9px] font-medium ${p.sc}`}>{p.s}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-3 pt-3 border-t border-slate-100 flex items-center justify-between text-[11px]">
            <span class="text-slate-500"><strong class="text-slate-800 tabular-nums">15</strong> conversas ativas</span>
            <span class="text-slate-500"><strong class="text-emerald-700 tabular-nums">1m 12s</strong> resposta média</span>
          </div>
        </div>
      </div>

      <h2>Pronto pra tirar o time do celular único?</h2>
      <p>
        Multiatendimento é o primeiro passo pra escalar atendimento sem virar
        bagunça. Em poucos minutos, todo o seu time entra no mesmo número — com
        organização, histórico e métricas de verdade.
      </p>

      <!-- CTA final -->
      <div class="mt-10 rounded-2xl bg-slate-50 border border-slate-200 p-6 sm:p-8 text-center">
        <p class="text-lg font-bold text-slate-900">Coloque o time inteiro no mesmo número.</p>
        <p class="text-sm text-slate-600 mt-1.5">Sem cartão. Resposta em minutos no horário comercial.</p>
        <a href={waLink("Quero ativar o Multiatendimento na Kora.")} target="_blank" rel="noopener noreferrer"
          class="mt-5 inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white font-semibold px-7 py-3.5 rounded-xl text-sm transition-colors shadow-sm">
          {BRAND.whatsappCta}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

    </article>
  </main>

  <Footer />
</Layout>

<style>
  /* Tipografia do artigo (espelha o estilo do blog, sempre light) */
  .ma-prose { color: #334155; font-size: 1.125rem; line-height: 1.85; }
  .ma-prose .ma-lead { font-size: 1.3rem; line-height: 1.6; color: #1e293b; font-weight: 500; margin-bottom: 2rem; }
  .ma-prose h2 {
    font-family: var(--font-display);
    font-size: 1.875rem; font-weight: 700; letter-spacing: -0.02em;
    margin-top: 3rem; margin-bottom: 1.1rem; color: #0f172a; line-height: 1.2;
  }
  .ma-prose p { margin-bottom: 1.4rem; }
  .ma-prose strong { font-weight: 700; color: #0f172a; }
  .ma-prose ul { list-style: disc; padding-left: 1.6rem; margin-bottom: 1.5rem; }
  .ma-prose li { margin-bottom: 0.6rem; }

  /* Cards de diagrama (escuros) */
  .ma-card {
    position: relative; overflow: hidden;
    background: #0f172a; border: 1px solid #1e293b; border-radius: 1.25rem;
    padding: 1.5rem; margin: 2.5rem 0;
  }
  .ma-card-glow { position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 320px; height: 320px; border-radius: 9999px; filter: blur(80px); pointer-events: none; }

  .ma-msg { background:#1e293b; border:1px solid #334155; color:#cbd5e1; font-size:9px; border-radius:0.5rem; padding:0.3rem 0.45rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .ma-msg-in { animation: maQueue 3s ease-in-out infinite; }
  .ma-msg-in:nth-child(2){ animation-delay:.4s } .ma-msg-in:nth-child(3){ animation-delay:.8s } .ma-msg-in:nth-child(4){ animation-delay:1.2s }
  @keyframes maQueue { 0%,100%{ transform:translateX(0); opacity:.85 } 50%{ transform:translateX(3px); opacity:1 } }

  .ma-attendant { animation: maPop .5s ease-out both; }
  .ma-attendant:nth-child(2){ animation-delay:.12s } .ma-attendant:nth-child(3){ animation-delay:.24s }
  @keyframes maPop { from{ opacity:0; transform:translateY(8px) } to{ opacity:1; transform:translateY(0) } }

  /* Painel claro (janela de app) */
  .ma-panel { background:#fff; border:1px solid #e2e8f0; border-radius:1rem; overflow:hidden; box-shadow:0 20px 45px -22px rgba(2,6,23,.25); margin:2.5rem 0; }
  .ma-winbar { display:flex; align-items:center; gap:.375rem; background:#f8fafc; border-bottom:1px solid #e2e8f0; padding:.6rem .75rem; }
  .ma-winbar span { width:.6rem; height:.6rem; border-radius:9999px; }
  .ma-winbar span:nth-child(1){ background:#fb7185 } .ma-winbar span:nth-child(2){ background:#fbbf24 } .ma-winbar span:nth-child(3){ background:#34d399 }
  .ma-winbar em { font-style:normal; font-size:.625rem; color:#94a3b8; font-weight:500; margin-left:.5rem; }

  @media (prefers-reduced-motion: reduce) {
    .ma-msg-in, .ma-attendant { animation: none !important; }
  }
</style>
