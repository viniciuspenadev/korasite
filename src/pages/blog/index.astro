---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Blog Kora | Tudo sobre Automação de WhatsApp"
  description="Conteúdos sobre CRM, atendimento, multiatendimento e automação no WhatsApp — guias práticos para vender e atender melhor pelo canal que o seu cliente já usa."
>
  <Nav />
  
  <main class="pt-32 pb-24 bg-slate-50 dark:bg-slate-900 min-h-screen transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <header class="text-center mb-16 max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-white mb-6">
          Blog da Kora
        </h1>
        <p class="text-lg text-slate-600 dark:text-slate-400">
          Descubra dicas, tutoriais e estratégias para dominar o atendimento e as vendas via WhatsApp.
        </p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedPosts.map(post => (
          <a href={`/blog/${post.slug}`} class="group flex flex-col bg-white dark:bg-slate-950 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-800 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="aspect-video w-full overflow-hidden relative">
              {post.data.image ? (
                <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              ) : (
                <div class="w-full h-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center">
                  <span class="text-slate-400">Kora Blog</span>
                </div>
              )}
              <div class="absolute top-4 left-4">
                <span class="px-3 py-1 bg-white/90 dark:bg-slate-900/90 backdrop-blur text-[var(--color-primary-600)] dark:text-[var(--color-primary-400)] text-xs font-bold rounded-full shadow-sm">
                  {post.data.category}
                </span>
              </div>
            </div>
            <div class="p-6 flex flex-col flex-1">
              <time class="text-xs font-semibold text-slate-500 dark:text-slate-400 mb-3">
                {post.data.date.toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
              <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3 group-hover:text-[var(--color-primary-600)] dark:group-hover:text-[var(--color-primary-400)] transition-colors line-clamp-2">
                {post.data.title}
              </h3>
              <p class="text-slate-600 dark:text-slate-400 text-sm line-clamp-3 mb-6">
                {post.data.description}
              </p>
              <div class="mt-auto text-sm font-semibold text-[var(--color-primary-600)] dark:text-[var(--color-primary-400)] flex items-center gap-1 group-hover:gap-2 transition-all">
                Ler artigo completo <span aria-hidden="true">&rarr;</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
