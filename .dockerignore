# Tudo que NÃO precisa entrar no build context do Docker.
# Reduz tempo de COPY e mantém o build determinístico.

# Dependências (são reinstaladas via npm ci no Dockerfile)
node_modules

# Build output (regenerado dentro do container)
dist
.output
.astro

# Git e CI
.git
.gitignore
.github

# Editor / OS
.vscode
.idea
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Env locais (NÃO devem ir pra produção)
.env
.env.local
.env.*.local

# Docker (não precisa do próprio Dockerfile dentro da imagem)
Dockerfile
.dockerignore

# Docs e scripts de dev
README.md
*.md
